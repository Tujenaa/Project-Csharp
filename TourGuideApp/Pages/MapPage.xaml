<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:TourGuideApp.Services"
    x:Class="TourGuideApp.Pages.MapPage"
    Title="{services:Translate Key='map_title'}"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!-- ═══ Layer 0: Map toàn màn hình ════════════════════════════════════ -->
        <WebView x:Name="mapWebView"
                 HorizontalOptions="Fill" VerticalOptions="Fill"
                 Navigating="OnWebViewNavigating"/>

        <!-- ═══ Layer 1: Thanh lộ trình (luôn hiện trên đầu) ════════════════ -->
        <Border BackgroundColor="White" Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="Fill" VerticalOptions="Start"
                Margin="12,12,12,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#35000000" Offset="0,4" Radius="14"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="0">
                <!-- Banner: Đang trong Tour -->
                <Border x:Name="activeTourBanner"
                        BackgroundColor="#512BD4"
                        Stroke="Transparent" StrokeThickness="0"
                        Margin="0,0,0,0"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding IsTourActive}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18,18,0,0"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*, Auto" Padding="14,8">
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Ellipse Fill="#4ADE80" WidthRequest="8" HeightRequest="8"/>
                            <Label VerticalOptions="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{services:Translate Key='in_tour_prefix'}" FontSize="12" TextColor="#E0E7FF"/>
                                        <Span Text="{Binding CurrentTour.Name}" FontSize="12" FontAttributes="Bold" TextColor="White"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </HorizontalStackLayout>
                        <Button Grid.Column="1" Text="{services:Translate Key='cancel'}" 
                                FontSize="11" HeightRequest="28" Padding="10,0"
                                BackgroundColor="#312E81" TextColor="White"
                                CornerRadius="8" Command="{Binding CancelTourCommand}"/>
                    </Grid>
                </Border>

                <!-- Thanh lộ trình: bấm để mở/đóng search -->
                <Grid ColumnSpacing="10" Padding="14,13,14,13">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Đường chấm dọc -->
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                        <Ellipse Fill="#2563EB" WidthRequest="9" HeightRequest="9"
                                 HorizontalOptions="Center"/>
                        <BoxView BackgroundColor="#CBD5E1" WidthRequest="2" HeightRequest="12"
                                 HorizontalOptions="Center"/>
                        <Ellipse Fill="#EF4444" WidthRequest="9" HeightRequest="9"
                                 HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Text lộ trình -->
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="{services:Translate Key='my_location_label'}"
                               FontSize="12" TextColor="#94A3B8"/>
                        <BoxView BackgroundColor="#E2E8F0" HeightRequest="1"/>
                        <Label x:Name="lblRouteDestination"
                               Text="{Binding CurrentDestinationName}"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="#1A1035" LineBreakMode="TailTruncation"/>
                    </VerticalStackLayout>

                    <!-- Nút xóa lộ trình (chỉ hiện khi đã chọn điểm đến) -->
                    <Border x:Name="btnClearRoute"
                            Grid.Column="2" BackgroundColor="#FEE2E2"
                            Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="32" HeightRequest="32"
                            VerticalOptions="Center" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="9"/>
                        </Border.StrokeShape>
                        <Label Text="✕" FontSize="13" TextColor="#EF4444"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClearRouteTapped"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Vùng tap để mở search (phủ lên toàn thanh lộ trình) -->
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRouteBarTapped"/>
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Panel tìm kiếm (ẩn mặc định, hiện khi bấm thanh lộ trình) -->
                <VerticalStackLayout x:Name="searchPanel" IsVisible="False" Spacing="0">

                    <!-- Ô tìm kiếm -->
                    <Border BackgroundColor="#F8F7FD" Stroke="#E8E3F5" StrokeThickness="1"
                            Margin="12,0,12,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid ColumnSpacing="8" Padding="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Source="ic_search.svg"
                                   WidthRequest="16" HeightRequest="16" VerticalOptions="Center"/>

                            <Entry Grid.Column="1"
                                   x:Name="searchEntry"
                                   Placeholder="{services:Translate Key='search_location_placeholder'}"
                                   PlaceholderColor="#94A3B8"
                                   FontSize="13" TextColor="#1A1035"
                                   BackgroundColor="Transparent"
                                   HeightRequest="42"
                                   TextChanged="OnSearchTextChanged"/>

                            <Border x:Name="btnClearSearch"
                                    Grid.Column="2" BackgroundColor="#E2E8F0"
                                    Stroke="Transparent" StrokeThickness="0"
                                    WidthRequest="22" HeightRequest="22"
                                    VerticalOptions="Center" IsVisible="False">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="11"/>
                                </Border.StrokeShape>
                                <Label Text="✕" FontSize="11" TextColor="#64748B"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnClearSearchTapped"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Kết quả tìm kiếm -->
                    <CollectionView x:Name="searchResultList"
                                    IsVisible="False"
                                    Margin="12,0,12,12"
                                    HeightRequest="200">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="White" Stroke="#E8E3F5" StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ShowPOIOnMapCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnSpacing="12" Padding="12,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="#F3F4F6" 
                                                WidthRequest="40" HeightRequest="40" VerticalOptions="Center">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8"/>
                                            </Border.StrokeShape>
                                            <Image Source="{Binding MainImage}" Aspect="AspectFill"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   TextColor="#1A1035"/>
                                            <Label Text="{Binding DistanceText}"
                                                   FontSize="11" TextColor="#94A3B8"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>



                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>

        <!-- ═══ Layer 2: Nút "vị trí của tôi" ════════════════════════════════ -->
        <Border BackgroundColor="#512BD4" Stroke="Transparent" StrokeThickness="0"
                WidthRequest="52" HeightRequest="52"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="16,0,16,88">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#50512BD4" Offset="0,4" Radius="12"/>
            </Border.Shadow>
            <Image Source="ic_my_location.svg" WidthRequest="22" HeightRequest="22"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCurrentLocationTapped"/>
            </Border.GestureRecognizers>
        </Border>

        <!-- ═══ Layer 3: Nút toggle danh sách POI ════════════════════════════ -->
        <Border BackgroundColor="White" Stroke="#E8E3F5" StrokeThickness="1"
                WidthRequest="52" HeightRequest="52"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="16,0,16,28">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,4" Radius="12"/>
            </Border.Shadow>
            <Image Source="ic_list.svg" WidthRequest="22" HeightRequest="22"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnTogglePOIListTapped"/>
            </Border.GestureRecognizers>
        </Border>

        <!-- ═══ Layer 4: POI Bottom Sheet ════════════════════════════════════ -->
        <Border x:Name="poiBottomSheet"
                BackgroundColor="White" Stroke="#E8E3F5" StrokeThickness="0"
                VerticalOptions="End" HorizontalOptions="Fill"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,-4" Radius="20"/>
            </Border.Shadow>

            <Grid RowSpacing="0" HeightRequest="400">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Padding="20,14,20,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <BoxView BackgroundColor="#DDD6F3" WidthRequest="36" HeightRequest="4"
                                 CornerRadius="2" HorizontalOptions="Start"/>

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10" Margin="0,8,10,0">
                            <VerticalStackLayout Grid.Column="0" Spacing="0">
                                <Label x:Name="lblBottomSheetTitle" Text="{services:Translate Key='tourist_locations_header'}"
                                       FontSize="17" FontAttributes="Bold"
                                       TextColor="#1A1035"/>
                                <Label x:Name="lblPoiCount" Text="{services:Translate Key='loading_text'}"
                                       FontSize="12" TextColor="#94A3B8"/>
                            </VerticalStackLayout>

                            <!-- Nút Bắt đầu tham quan (chỉ hiện khi chọn tour và chưa bắt đầu) -->
                            <Border Grid.Column="1" 
                                    BackgroundColor="#512BD4" 
                                    Stroke="Transparent" 
                                    Padding="12,6"
                                    VerticalOptions="Center">
                                <Border.Triggers>
                                    <!-- Hiện khi IsTourSelected=true VÀ IsTourActive=false -->
                                    <MultiTrigger TargetType="Border">
                                        <MultiTrigger.Conditions>
                                            <BindingCondition Binding="{Binding IsTourSelected}" Value="True"/>
                                            <BindingCondition Binding="{Binding IsTourActive}" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="IsVisible" Value="True"/>
                                    </MultiTrigger>
                                    <!-- Ẩn mặc định -->
                                    <DataTrigger TargetType="Border" Binding="{Binding IsTourSelected}" Value="False">
                                        <Setter Property="IsVisible" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsTourActive}" Value="True">
                                        <Setter Property="IsVisible" Value="False"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="{services:Translate Key='start_button'}" FontSize="12" FontAttributes="Bold" TextColor="White"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding StartTourCommand}"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <Border Grid.Column="1" BackgroundColor="#F4F2FB"
                            Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="34" HeightRequest="34" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="✕" FontSize="15" TextColor="#512BD4"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTogglePOIListTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Tour selector -->
                <ScrollView Grid.Row="1" Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            Margin="16,0,16,10">
                    <HorizontalStackLayout x:Name="tourChipPanel" Spacing="8">

                        <!-- Chip "Tất cả" -->
                        <Border x:Name="chipAll"
                                BackgroundColor="#512BD4"
                                Stroke="Transparent" StrokeThickness="0"
                                Padding="14,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTourChipAllTapped"/>
                            </Border.GestureRecognizers>
                            <Label Text="{services:Translate Key='all_chip'}" FontSize="12" FontAttributes="Bold" TextColor="White"/>
                        </Border>

                        <!-- Tour chips — populated from code-behind using BindableLayout -->
                        <HorizontalStackLayout x:Name="tourChipsContainer" Spacing="8"
                                               BindableLayout.ItemsSource="{Binding AllTours}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F4F2FB"
                                            Stroke="#DDD6F3" StrokeThickness="1"
                                            Padding="14,7">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectTourCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding Name}" FontSize="12" TextColor="#512BD4"
                                               LineBreakMode="TailTruncation" MaximumWidthRequest="130"/>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>
                </ScrollView>

                <CollectionView Grid.Row="2" x:Name="poiCollectionView"
                                ItemsSource="{Binding NearbyPOI}"
                                Margin="16,0,16,16">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#F8F7FD" Stroke="#E8E3F5"
                                    StrokeThickness="1" Padding="0">
                                <Border.Triggers>
                                    <!-- Highlight mặc định khi đang phát -->
                                    <DataTrigger TargetType="Border" Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#F0E7FF"/>
                                        <Setter Property="Stroke" Value="#512BD4"/>
                                        <Setter Property="StrokeThickness" Value="2"/>
                                    </DataTrigger>

                                    <!-- Highlight đặc biệt nếu POI thuộc Tour và đang phát -->
                                    <MultiTrigger TargetType="Border">
                                        <MultiTrigger.Conditions>
                                            <BindingCondition Binding="{Binding IsPlaying}" Value="True"/>
                                            <BindingCondition Binding="{Binding IsInAnyTour}" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="BackgroundColor" Value="#F0E7FF"/>
                                        <Setter Property="Stroke" Value="#512BD4"/>
                                        <Setter Property="StrokeThickness" Value="2"/>
                                    </MultiTrigger>
                                </Border.Triggers>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToDetailCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>

                                <Grid ColumnSpacing="10" Padding="14,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BackgroundColor="#512BD4"
                                            Stroke="Transparent" StrokeThickness="0"
                                            WidthRequest="36" HeightRequest="36" VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding IndexLabel}"
                                               FontSize="14" FontAttributes="Bold" TextColor="White"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="#F3F4F6" WidthRequest="36" HeightRequest="36" VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding MainImage}" Aspect="AspectFill"/>
                                    </Border>

                                    <VerticalStackLayout Grid.Column="2" Spacing="3" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold"
                                                   TextColor="#1A1035" LineBreakMode="TailTruncation"
                                                   VerticalOptions="Center"/>
                                            
                                            <!-- Badge TOUR nhỏ -->
                                            <Border BackgroundColor="#512BD4" StrokeThickness="0"
                                                    Padding="4,1" VerticalOptions="Center"
                                                    IsVisible="{Binding IsInAnyTour}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="4"/>
                                                </Border.StrokeShape>
                                                <Label Text="TOUR" FontSize="9" FontAttributes="Bold" TextColor="White"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding DistanceText}" FontSize="12" TextColor="#64748B"/>
                                    </VerticalStackLayout>

                                    <!-- Icon chỉ đường (chọn làm điểm đến) -->
                                    <Border Grid.Column="3" BackgroundColor="#DBEAFE"
                                            Stroke="Transparent" StrokeThickness="0"
                                            WidthRequest="36" HeightRequest="36" VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectRouteDestCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Image Source="ic_directions.svg"
                                               WidthRequest="16" HeightRequest="16"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Play / Pause audio -->
                                    <Grid Grid.Column="4" VerticalOptions="Center"
                                              WidthRequest="36" HeightRequest="36">

                                        <!-- Nút Play (ẩn khi đang phát) -->
                                        <Border BackgroundColor="#EDE7FF"
                                                    Stroke="Transparent" StrokeThickness="0"
                                                    WidthRequest="36" HeightRequest="36">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsPlaying}" Value="True">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10"/>
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PlayAudioCommand}"
                                                        CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="ic_play.svg" WidthRequest="15" HeightRequest="15"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>

                                        <!-- Nút Pause (chỉ hiện khi đang phát) -->
                                        <Border BackgroundColor="#FCE7F3"
                                                    Stroke="Transparent" StrokeThickness="0"
                                                    WidthRequest="36" HeightRequest="36"
                                                    IsVisible="False">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsPlaying}" Value="True">
                                                    <Setter Property="IsVisible" Value="True"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10"/>
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PauseAudioCommand}"
                                                        CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="ic_pause.svg" WidthRequest="15" HeightRequest="15"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>

                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- ═══ Layer 5: POI Detail Card ═════════════════════════════════════ -->
        <Border x:Name="poiDetailCard"
                BackgroundColor="White" Stroke="#E8E3F5" StrokeThickness="1"
                HorizontalOptions="Fill" VerticalOptions="End"
                Margin="12,0,12,16"
                IsVisible="False">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#50000000" Offset="0,-2" Radius="16"/>
            </Border.Shadow>

            <Grid RowSpacing="0" Padding="16,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="lblCardName"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#1A1035" LineBreakMode="TailTruncation"/>
                        <Label x:Name="lblCardDistance" FontSize="12" TextColor="#64748B"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="1" BackgroundColor="#F4F2FB"
                            Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="32" HeightRequest="32" VerticalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="9"/>
                        </Border.StrokeShape>
                        <Label Text="✕" FontSize="14" TextColor="#512BD4"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseDetailCardTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <Label x:Name="lblCardDesc" Grid.Row="1"
                       FontSize="13" TextColor="#475569"
                       LineBreakMode="WordWrap" MaxLines="3"
                       Margin="0,8,0,0"/>

                <Grid Grid.Row="2" ColumnSpacing="10" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Audio – play and pause icons -->
                    <Grid Grid.Column="0" VerticalOptions="Center">
                        <!-- Play/Pause Button -->
                        <Border x:Name="btnCardPlayAudio"
                                BackgroundColor="#EDE7FF"
                                Stroke="Transparent" StrokeThickness="0"
                                WidthRequest="46" HeightRequest="46">
                            <Border.Triggers>
                                <!-- Bind to VM since it's the Detail Card? No, MapViewModel doesn't have IsPlaying. 
                                     The code-behind actually controls btnCardPlayAudio and btnCardPauseAudio visibility manually it seems. -->
                            </Border.Triggers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardPlayAudioTapped"/>
                            </Border.GestureRecognizers>
                            <Image Source="ic_play.svg"
                                   WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <!-- Pause Button -->
                        <Border x:Name="btnCardPauseAudio"
                                BackgroundColor="#FCE7F3"
                                Stroke="Transparent" StrokeThickness="0"
                                WidthRequest="46" HeightRequest="46"
                                IsVisible="False">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardPauseAudioTapped"/>
                            </Border.GestureRecognizers>
                            <Image Source="ic_pause.svg"
                                   WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <!-- Chỉ đường – icon only -->
                    <Border Grid.Column="1" BackgroundColor="#DBEAFE"
                            Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="46" HeightRequest="46">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardNavigateTapped"/>
                        </Border.GestureRecognizers>
                        <Image Source="ic_directions.svg"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Xem chi tiết -->
                    <Border Grid.Column="2" BackgroundColor="#512BD4"
                            Stroke="Transparent" StrokeThickness="0" HeightRequest="46">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCardDetailTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="{services:Translate Key='view_details_button'}"
                               FontSize="13" FontAttributes="Bold" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
