<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="TourGuideApp.Pages.MapPage"
    Title="Bản đồ lộ trình">

    <Grid RowSpacing="0">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="260"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <mapsui:MapControl
                x:Name="RouteMap"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"/>

            <Frame
                BackgroundColor="#e94560"
                CornerRadius="30"
                Padding="15"
                WidthRequest="60"
                HeightRequest="60"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20">

                <Label
                    Text="📍"
                    FontSize="24"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCurrentLocationTapped"/>
                </Frame.GestureRecognizers>

            </Frame>
        </Grid>

        <Frame
            Grid.Row="1"
            Padding="0"
            CornerRadius="30"
            BackgroundColor="White">

            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <VerticalStackLayout Grid.Row="0" Padding="0,10,0,15">
                    <BoxView
                        BackgroundColor="#cbd5e1"
                        WidthRequest="40"
                        HeightRequest="4"
                        CornerRadius="2"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="📍 Địa điểm gần đây"
                        FontSize="20"
                        FontAttributes="Bold"
                        Margin="20,10,20,0"
                        TextColor="#1a1a2e"/>

                    <Label
                        Text="Các địa điểm trong bán kính 500m"
                        FontSize="13"
                        Margin="20,5,20,0"
                        TextColor="#64748b"/>
                </VerticalStackLayout>

                <ScrollView
                    Grid.Row="1"
                    Orientation="Horizontal"
                    Padding="20,0,20,20">

                    <HorizontalStackLayout Spacing="15">

                        <Frame BackgroundColor="White" CornerRadius="20" WidthRequest="260">
                            <VerticalStackLayout Padding="15">
                                <Label Text="Nhà thờ Đức Bà" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e"/>
                                <Label Text="⭐ 4.8 • 300m" FontSize="13" TextColor="#64748b" Margin="0,0,0,10"/>
                                <Button Text="▶ Audio giới thiệu" BackgroundColor="#fef3f2" TextColor="#e94560" CornerRadius="10" HeightRequest="40"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame BackgroundColor="White" CornerRadius="20" WidthRequest="260">
                            <VerticalStackLayout Padding="15">
                                <Label Text="Dinh Độc Lập" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e"/>
                                <Label Text="⭐ 4.7 • 450m" FontSize="13" TextColor="#64748b" Margin="0,0,0,10"/>
                                <Button Text="▶ Audio giới thiệu" BackgroundColor="#fef3f2" TextColor="#e94560" CornerRadius="10" HeightRequest="40"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame BackgroundColor="White" CornerRadius="20" WidthRequest="260">
                            <VerticalStackLayout Padding="15">
                                <Label Text="Chợ Bến Thành" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e"/>
                                <Label Text="⭐ 4.6 • 500m" FontSize="13" TextColor="#64748b" Margin="0,0,0,10"/>
                                <Button Text="▶ Audio giới thiệu" BackgroundColor="#fef3f2" TextColor="#e94560" CornerRadius="10" HeightRequest="40"/>
                            </VerticalStackLayout>
                        </Frame>

                    </HorizontalStackLayout>
                </ScrollView>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>