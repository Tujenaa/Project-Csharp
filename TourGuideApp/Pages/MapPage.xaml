<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="TourGuideApp.Pages.MapPage"
    Title="Bản đồ lộ trình"
    Shell.NavBarIsVisible="False">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="270"/>
        </Grid.RowDefinitions>

        <!-- Map + FAB -->
        <Grid Grid.Row="0">
            <mapsui:MapControl
                x:Name="map"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"/>

            <!-- Nút vị trí hiện tại -->
            <Border
                BackgroundColor="#512BD4"
                Stroke="Transparent"
                StrokeThickness="0"
                WidthRequest="52"
                HeightRequest="52"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow
                        Brush="#50512BD4"
                        Offset="0,4"
                        Radius="12"/>
                </Border.Shadow>
                <Image
                    Source="ic_my_location.svg"
                    WidthRequest="22"
                    HeightRequest="22"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCurrentLocationTapped"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <!-- Bottom panel -->
        <Border
            Grid.Row="1"
            Padding="0"
            BackgroundColor="White"
            Stroke="#E8E3F5"
            StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28,28,0,0"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow
                    Brush="#20512BD4"
                    Offset="0,-4"
                    Radius="16"/>
            </Border.Shadow>

            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Handle + header -->
                <VerticalStackLayout Grid.Row="0" Padding="0,10,0,12">
                    <BoxView
                        BackgroundColor="#DDD6F3"
                        WidthRequest="36"
                        HeightRequest="4"
                        CornerRadius="2"
                        HorizontalOptions="Center"/>
                    <Label
                        Text="Địa điểm gần đây"
                        FontSize="17"
                        FontAttributes="Bold"
                        Margin="20,10,20,0"
                        TextColor="#1A1035"/>
                    <Label
                        Text="Trong bán kính 500m"
                        FontSize="12"
                        Margin="20,3,20,0"
                        TextColor="#94A3B8"/>
                </VerticalStackLayout>

                <!-- POI list -->
                <CollectionView
                    Grid.Row="1"
                    ItemsSource="{Binding NearbyPOI}"
                    ItemsLayout="HorizontalList"
                    Margin="16,0,16,16">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                BackgroundColor="#F4F2FB"
                                Stroke="#E8E3F5"
                                StrokeThickness="1"
                                WidthRequest="240"
                                Margin="0,0,12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18"/>
                                </Border.StrokeShape>

                                <VerticalStackLayout Padding="16" Spacing="6">
                                    <Label
                                        Text="{Binding Name}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="#1A1035"
                                        LineBreakMode="TailTruncation"/>
                                    <Label
                                        Text="Địa điểm gần bạn"
                                        FontSize="12"
                                        TextColor="#94A3B8"/>

                                    <!-- Nút phát audio -->
                                    <Border
                                        BackgroundColor="#EDE7FF"
                                        Stroke="Transparent"
                                        StrokeThickness="0"
                                        HeightRequest="38"
                                        Margin="0,4,0,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image
                                                Grid.Column="0"
                                                Source="ic_play.svg"
                                                WidthRequest="16"
                                                HeightRequest="16"
                                                Margin="14,0,8,0"
                                                VerticalOptions="Center"/>
                                            <Label
                                                Grid.Column="1"
                                                Text="Audio giới thiệu"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                TextColor="#512BD4"
                                                VerticalOptions="Center"/>
                                        </Grid>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PlayAudioCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
