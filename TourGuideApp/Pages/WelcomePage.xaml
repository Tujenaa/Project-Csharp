<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:TourGuideApp.Services"
    x:Class="TourGuideApp.Pages.WelcomePage"
    Title=""
    BackgroundColor="#1A1035"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <Grid MinimumHeightRequest="820">

            <!-- Background decorative ellipses -->
            <Ellipse Fill="#2D1B6E" WidthRequest="340" HeightRequest="340"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Margin="0,-80,-80,0" Opacity="0.45"/>
            <Ellipse Fill="#2D1B6E" WidthRequest="220" HeightRequest="220"
                     HorizontalOptions="Start" VerticalOptions="End"
                     Margin="-60,0,0,-60" Opacity="0.35"/>
            
            <!-- Language Selector -->
            <Border HorizontalOptions="End" VerticalOptions="Start"
                    Margin="0,52,24,0" Padding="12,8"
                    BackgroundColor="#2D1B6E" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLanguageTapped" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <Label x:Name="LanguageLabel" Text="🇻🇳" FontSize="18" VerticalOptions="Center"/>
                    <Label Text="›" FontSize="20" TextColor="#9B7FEA" VerticalOptions="Center" Margin="0,-2,0,0"/>
                </HorizontalStackLayout>
            </Border>

            <VerticalStackLayout Padding="32,0" VerticalOptions="Center">

                <!-- Brand -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,72,0,0">
                    <Border BackgroundColor="#512BD4" WidthRequest="68" HeightRequest="68"
                            HorizontalOptions="Center" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Label Text="TG" FontSize="24" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="{services:Translate Key='app_name'}" FontSize="28" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="{services:Translate Key='explore_around_desc'}" FontSize="13"
                           TextColor="#9B7FEA" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Welcome Box with Start Button -->
                <Border BackgroundColor="White" Stroke="Transparent"
                        StrokeThickness="0" Margin="0,40,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="24,32" Spacing="0">
                        
                        <Label Text="{services:Translate Key='app_name'}" FontSize="21" FontAttributes="Bold"
                               TextColor="#1A1035" Margin="0,0,0,12" HorizontalOptions="Center"/>
                        
                        <Label Text="{services:Translate Key='language_desc'}" FontSize="13"
                               TextColor="#6B7280" Margin="0,0,0,32" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                        <Button Text="{services:Translate Key='start_button'}"
                                BackgroundColor="#512BD4" TextColor="White"
                                FontSize="15" FontAttributes="Bold"
                                CornerRadius="13" HeightRequest="50"
                                Clicked="OnStartClicked">
                            <Button.Shadow>
                                <Shadow Brush="#40512BD4" Offset="0,6" Radius="16"/>
                            </Button.Shadow>
                        </Button>

                    </VerticalStackLayout>
                </Border>
                
                <BoxView HeightRequest="40" Color="Transparent"/>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
