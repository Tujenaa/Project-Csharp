<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourGuideApp.Pages.SettingsPage"
    Title="Cài đặt"
    BackgroundColor="#f8f9fa">

    <ScrollView>
        <VerticalStackLayout Padding="0,20,0,30" Spacing="0">

            <Frame Margin="20,0,20,20" BackgroundColor="White" CornerRadius="20" Padding="20">
                <Grid ColumnSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Source="profile.png" WidthRequest="70" HeightRequest="70">
                        <Image.Clip>
                            <EllipseGeometry Center="35,35" RadiusX="35" RadiusY="35"/>
                        </Image.Clip>
                    </Image>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="Người dùng" FontSize="18" FontAttributes="Bold" TextColor="#1a1a2e"/>
                        <Label Text="tourguide@email.com" FontSize="13" TextColor="#64748b"/>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Label Text="Cài đặt ứng dụng" Margin="25,10,20,10" FontSize="14" FontAttributes="Bold" TextColor="#64748b"/>

            <Frame Margin="20,0,20,20" BackgroundColor="White" CornerRadius="20" Padding="0">
                <VerticalStackLayout>

                    <Grid Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Text="Sử dụng GPS" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="True" OnColor="#e94560"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#e2e8f0"/>

                    <Grid Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Text="Audio hướng dẫn" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="True" OnColor="#e94560"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#e2e8f0"/>

                    <Grid Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Text="Ngôn ngữ" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Tiếng Việt" TextColor="#64748b" VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <Label Text="Thông tin" Margin="25,10,20,10" FontSize="14" FontAttributes="Bold" TextColor="#64748b"/>

            <Frame Margin="20,0,20,20" BackgroundColor="White" CornerRadius="20" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Tour Guide App" FontSize="16" FontAttributes="Bold"/>
                    <Label Text="Phiên bản 1.0" FontSize="13" TextColor="#64748b"/>
                    <Label Text="Ứng dụng hướng dẫn du lịch sử dụng bản đồ và GPS để khám phá các địa điểm." FontSize="13" TextColor="#64748b"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Đăng xuất" BackgroundColor="#e94560" TextColor="White" CornerRadius="15" HeightRequest="50" Margin="20,10,20,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>