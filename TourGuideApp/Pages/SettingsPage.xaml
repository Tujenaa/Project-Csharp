<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourGuideApp.Pages.SettingsPage"
    xmlns:local="clr-namespace:TourGuideApp.Services"
    Title="Cài đặt"
    BackgroundColor="#F4F2FB"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid BackgroundColor="#1A1035" Padding="22,52,22,26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Text="Cài đặt"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="White" Margin="0,0,0,16"/>

                <!-- Profile card -->
                <Border Grid.Row="1" BackgroundColor="#2D1B6E"
                        Stroke="#512BD4" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Grid Padding="16" ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BackgroundColor="#512BD4"
                                WidthRequest="52" HeightRequest="52" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Label Text="U" FontSize="20" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                            <Label Text="Người dùng" FontSize="16" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="tourguide@email.com" FontSize="12" TextColor="#9B7FEA"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── ỨNG DỤNG group ──────────────────────────────────── -->
            <Label Text="ỨNG DỤNG" Margin="22,20,20,8"
                   FontSize="11" FontAttributes="Bold"
                   TextColor="#94A3B8" CharacterSpacing="1"/>

            <Border Margin="18,0" BackgroundColor="White"
                    Stroke="#E8E3F5" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <!-- GPS -->
                    <Grid Padding="18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="Sử dụng GPS" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"/>
                            <Label Text="Xác định vị trí của bạn trên bản đồ"
                                   FontSize="11" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" x:Name="switchGps"
                                IsToggled="{Binding GpsEnabled, Source={x:Static local:SettingService.Instance}}"
                                OnColor="#512BD4"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#F1EEF9" Margin="18,0"/>

                    <!-- Audio hướng dẫn -->
                    <Grid Padding="18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="Audio hướng dẫn" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"/>
                            <Label Text="Tự động phát khi đến gần điểm tham quan"
                                   FontSize="11" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding AutoPlay, Source={x:Static local:SettingService.Instance}}"
                                OnColor="#512BD4"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#F1EEF9" Margin="18,0"/>

                    <!-- Language picker -->
                    <Grid Padding="18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="Ngôn ngữ" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"/>
                            <Label Text="Ngôn ngữ thuyết minh và giao diện"
                                   FontSize="11" TextColor="#94A3B8"/>
                        </VerticalStackLayout>

                        <!-- Tappable language badge -->
                        <Border Grid.Column="1" BackgroundColor="#EDE7FF"
                                Stroke="Transparent" StrokeThickness="0"
                                Padding="10,6" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label x:Name="lblLanguage"
                                       Text="{Binding LanguageDisplayName, Source={x:Static local:SettingService.Instance}}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#512BD4" VerticalOptions="Center"/>
                                <Image Source="ic_chevron_right.svg"
                                       WidthRequest="14" HeightRequest="14"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ── THÔNG TIN group ─────────────────────────────────── -->
            <Label Text="THÔNG TIN" Margin="22,20,20,8"
                   FontSize="11" FontAttributes="Bold"
                   TextColor="#94A3B8" CharacterSpacing="1"/>

            <Border Margin="18,0" BackgroundColor="White"
                    Stroke="#E8E3F5" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout Padding="18" Spacing="6">
                    <Label Text="Tour Guide App" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"/>
                    <Label Text="Phiên bản 1.0" FontSize="13" TextColor="#6B7280"/>
                    <Label Text="Ứng dụng hướng dẫn du lịch sử dụng bản đồ và GPS để khám phá các địa điểm."
                           FontSize="13" TextColor="#94A3B8" LineHeight="1.5"/>
                </VerticalStackLayout>
            </Border>

            <Button Text="Đăng xuất"
                    BackgroundColor="#FEF0F3" TextColor="#E94560"
                    BorderColor="#FCA5A5" BorderWidth="1"
                    CornerRadius="14" HeightRequest="50"
                    FontSize="14" FontAttributes="Bold"
                    Margin="18,16,18,32"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
