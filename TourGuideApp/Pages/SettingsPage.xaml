<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:TourGuideApp.Services"
    x:Class="TourGuideApp.Pages.SettingsPage"
    Title="{services:Translate Key='settings_title'}"
    BackgroundColor="#F4F2FB"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ── Header ── -->
            <Grid BackgroundColor="#1A1035" Padding="22,52,22,26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Text="{services:Translate Key='settings_title'}"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="White" Margin="0,0,0,16"/>

                <!-- Profile card — tappable → AccountPage -->
                <Border Grid.Row="1" BackgroundColor="#2D1B6E"
                        Stroke="#512BD4" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileCardTapped"/>
                    </Border.GestureRecognizers>
                    <Grid Padding="16" ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar -->
                        <Border Grid.Column="0" BackgroundColor="#512BD4"
                                WidthRequest="52" HeightRequest="52" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Label x:Name="AvatarLabel" Text="U" FontSize="20" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <!-- Name / email -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                            <Label x:Name="NameLabel" Text="{services:Translate Key='user'}"
                                   FontSize="16" FontAttributes="Bold" TextColor="White"/>
                            <Label x:Name="EmailLabel" Text=""
                                   FontSize="12" TextColor="#9B7FEA"/>
                        </VerticalStackLayout>

                        <!-- Arrow -->
                        <Label Grid.Column="2" Text="›" FontSize="24"
                               TextColor="#9B7FEA" VerticalOptions="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── ỨNG DỤNG ── -->
            <Label Text="{services:Translate Key='app_settings_section'}" Margin="22,20,20,8"
                   FontSize="11" FontAttributes="Bold"
                   TextColor="#94A3B8" CharacterSpacing="1"/>

            <Border Margin="18,0" BackgroundColor="White"
                    Stroke="#E8E3F5" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <!-- GPS -->
                    <Grid Padding="18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="{services:Translate Key='use_gps'}" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"/>
                            <Label Text="{services:Translate Key='use_gps_desc'}"
                                   FontSize="11" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding GpsEnabled, Source={x:Static services:SettingService.Instance}}"
                                OnColor="#512BD4"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#F1EEF9" Margin="18,0"/>

                    <!-- Audio -->
                    <Grid Padding="18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="{services:Translate Key='audio_guidance'}" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"/>
                            <Label Text="{services:Translate Key='audio_guidance_desc'}"
                                   FontSize="11" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding AutoPlay, Source={x:Static services:SettingService.Instance}}"
                                OnColor="#512BD4"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#F1EEF9" Margin="18,0"/>

                    <!-- Language -->
                    <Grid Padding="18,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="{services:Translate Key='language_label'}" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"/>
                            <Label Text="{services:Translate Key='language_desc'}"
                                   FontSize="11" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="#EDE7FF"
                                Stroke="Transparent" StrokeThickness="0"
                                Padding="10,6" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                            </Border.GestureRecognizers>
                            <Label x:Name="lblLanguage"
                                   Text="{Binding LanguageDisplayName, Source={x:Static services:SettingService.Instance}}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#512BD4" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── THÔNG TIN ── -->
            <Label Text="{services:Translate Key='info_section_header'}" Margin="22,20,20,8"
                   FontSize="11" FontAttributes="Bold"
                   TextColor="#94A3B8" CharacterSpacing="1"/>

            <Border Margin="18,0" BackgroundColor="White"
                    Stroke="#E8E3F5" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout Padding="18" Spacing="6">
                    <Label Text="{services:Translate Key='app_name'}" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"/>
                    <Label Text="{services:Translate Key='version'}" FontSize="13" TextColor="#6B7280"/>
                    <Label Text="{services:Translate Key='app_desc'}"
                           FontSize="13" TextColor="#94A3B8" LineHeight="1.5"/>
                </VerticalStackLayout>
            </Border>

            <!-- Logout -->
            <Button Text="{services:Translate Key='logout_button'}"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#FEF0F3"
                    TextColor="#E94560"
                    BorderColor="#FCA5A5"
                    BorderWidth="1"
                    CornerRadius="14"
                    HeightRequest="50"
                    FontSize="14"
                    FontAttributes="Bold"
                    Margin="18,16,18,32"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
