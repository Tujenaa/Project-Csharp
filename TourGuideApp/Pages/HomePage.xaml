<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourGuideApp.Pages.HomePage"
    Title="Tour Guide"
    BackgroundColor="#F4F2FB"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header banner -->
            <Grid HeightRequest="220" BackgroundColor="#1A1035">
                <Image
                    Source="map_preview.png"
                    Aspect="AspectFill"
                    Opacity="0.18"/>

                <!-- Gradient overlay -->
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#CC1A1035" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <VerticalStackLayout
                    VerticalOptions="End"
                    Padding="24,0,24,28"
                    Spacing="10">
                    <Label
                        Text="Vị trí hiện tại"
                        TextColor="#9B7FEA"
                        FontSize="12"
                        FontAttributes="Bold"
                        CharacterSpacing="1"/>
                    <Label
                        x:Name="LocationLabel"
                        Text="Đang xác định..."
                        TextColor="White"
                        FontSize="22"
                        FontAttributes="Bold"/>
                    <Button
                        Text="Mở bản đồ"
                        BackgroundColor="#512BD4"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="44"
                        WidthRequest="160"
                        FontSize="14"
                        FontAttributes="Bold"
                        Clicked="OnMapButtonClicked"
                        HorizontalOptions="Start">
                        <Button.Shadow>
                            <Shadow
                                Brush="#40512BD4"
                                Offset="0,4"
                                Radius="12"/>
                        </Button.Shadow>
                    </Button>
                </VerticalStackLayout>
            </Grid>

            <!-- Stats row (overlap hero) -->
            <Grid
                Padding="18,0"
                ColumnSpacing="10"
                Margin="0,-22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    BackgroundColor="White"
                    Stroke="#E8E3F5"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="12,14" Spacing="4">
                        <Label
                            Text="24"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#1A1035"
                            HorizontalOptions="Center"/>
                        <Label
                            Text="Địa điểm"
                            FontSize="11"
                            TextColor="#6B7280"
                            HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Column="1"
                    BackgroundColor="White"
                    Stroke="#E8E3F5"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="12,14" Spacing="4">
                        <Label
                            Text="24"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#1A1035"
                            HorizontalOptions="Center"/>
                        <Label
                            Text="Audio"
                            FontSize="11"
                            TextColor="#6B7280"
                            HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Column="2"
                    BackgroundColor="White"
                    Stroke="#E8E3F5"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Padding="12,14" Spacing="4">
                        <Label
                            Text="2.5 km"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#1A1035"
                            HorizontalOptions="Center"/>
                        <Label
                            Text="Lộ trình"
                            FontSize="11"
                            TextColor="#6B7280"
                            HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Section title -->
            <Grid Padding="20,22,20,10">
                <Label
                    Text="Địa điểm nổi bật"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="#1A1035"/>
            </Grid>

            <!-- Place list -->
            <CollectionView
                Margin="18,0,18,24"
                SelectionMode="Single"
                SelectionChanged="OnPlaceSelected">
                <CollectionView.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Nhà thờ Đức Bà</x:String>
                        <x:String>Dinh Độc Lập</x:String>
                        <x:String>Chợ Bến Thành</x:String>
                        <x:String>Bưu điện Thành phố</x:String>
                        <x:String>Bảo tàng lịch sử</x:String>
                    </x:Array>
                </CollectionView.ItemsSource>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,10"
                            BackgroundColor="White"
                            Stroke="#E8E3F5"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18"/>
                            </Border.StrokeShape>
                            <Grid Padding="16,14" ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <VerticalStackLayout
                                    Grid.Column="0"
                                    VerticalOptions="Center"
                                    Spacing="3">
                                    <Label
                                        Text="{Binding .}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="#1A1035"
                                        LineBreakMode="TailTruncation"/>
                                    <Label
                                        Text="4.8  ·  500m"
                                        FontSize="12"
                                        TextColor="#6B7280"/>
                                    <Label
                                        Text="Địa điểm du lịch nổi bật"
                                        FontSize="12"
                                        TextColor="#94A3B8"/>
                                </VerticalStackLayout>

                                <!-- Play icon từ SVG asset -->
                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#EDE7FF"
                                    Stroke="Transparent"
                                    StrokeThickness="0"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Image
                                        Source="ic_play.svg"
                                        WidthRequest="18"
                                        HeightRequest="18"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
