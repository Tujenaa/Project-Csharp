<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourGuideApp.Pages.HomePage"
    Title="Tour Guide"
    BackgroundColor="#F4F2FB"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ═══ Header banner ═══════════════════════════════════════════ -->
                <Grid HeightRequest="220" BackgroundColor="#1A1035">
                    <Image Source="map_preview.png" Aspect="AspectFill" Opacity="0.18"/>
                    <BoxView>
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#CC1A1035" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <VerticalStackLayout VerticalOptions="End" Padding="24,0,24,40" Spacing="8">
                        <Label Text="Vị trí hiện tại" TextColor="#9B7FEA" FontSize="12" FontAttributes="Bold" CharacterSpacing="1"/>
                        <Label x:Name="LocationLabel" Text="Đang xác định..." TextColor="White" FontSize="22" FontAttributes="Bold"/>
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Start">
                            <Button Text="Mở bản đồ" BackgroundColor="#512BD4" TextColor="White"
                                    CornerRadius="12" HeightRequest="44" WidthRequest="140"
                                    FontSize="14" FontAttributes="Bold" Clicked="OnMapButtonClicked">
                                <Button.Shadow>
                                    <Shadow Brush="#40512BD4" Offset="0,4" Radius="12"/>
                                </Button.Shadow>
                            </Button>
                            <ImageButton Source="ic_qr.svg" BackgroundColor="#9B7FEA"
                                         CornerRadius="12" HeightRequest="44" WidthRequest="44"
                                         Padding="10" Clicked="OnScanQrClicked">
                                <ImageButton.Shadow>
                                    <Shadow Brush="#409B7FEA" Offset="0,4" Radius="12"/>
                                </ImageButton.Shadow>
                            </ImageButton>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- ═══ Stats cards ══════════════════════════════════════════════ -->
                <Grid Padding="18,0" ColumnSpacing="10" Margin="0,-22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BackgroundColor="White" Stroke="#E8E3F5" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="12,14" Spacing="4">
                            <Label Text="{Binding TourCount}" FontSize="20" FontAttributes="Bold" TextColor="#1A1035" HorizontalOptions="Center"/>
                            <Label Text="Tour" FontSize="11" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="White" Stroke="#E8E3F5" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="8,14" Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding NearestPoiName}" FontSize="15" FontAttributes="Bold" TextColor="#1A1035"
                                   LineBreakMode="TailTruncation" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding NearestPoiDist, StringFormat='Nơi gần nhất: {0}'}" FontSize="11" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ═══ Địa điểm nổi bật ════════════════════════════════════════ -->
                <Grid Padding="20,22,20,10">
                    <Label Text="Địa điểm nổi bật" FontSize="18" FontAttributes="Bold" TextColor="#1A1035"/>
                </Grid>

                <CollectionView Margin="18,0,18,8" ItemsSource="{Binding TopPOIs}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" BackgroundColor="White" Stroke="#E8E3F5" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18"/>
                                </Border.StrokeShape>
                                <Grid Padding="16,14" ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="#F3F4F6" WidthRequest="60" HeightRequest="60" VerticalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding MainImage}" Aspect="AspectFill"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToDetailCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </VerticalStackLayout.GestureRecognizers>
                                        <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold" TextColor="#1A1035" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding DistanceText}" FontSize="12" TextColor="#6B7280"/>
                                        <Label Text="{Binding Description}" FontSize="12" TextColor="#94A3B8" LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                        <Border BackgroundColor="#EDE7FF" StrokeThickness="1" Stroke="#512BD4" Padding="12,6">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToMapWithPoiCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="Bản đồ" FontSize="12" FontAttributes="Bold" TextColor="#512BD4" VerticalOptions="Center"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ═══ Tour nổi bật ════════════════════════════════════════════ -->
                <Grid Padding="20,14,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Text="Tour nổi bật" FontSize="18" FontAttributes="Bold" TextColor="#1A1035" VerticalOptions="Center"/>
                    <Border Grid.Column="1" BackgroundColor="#EDE7FF" Stroke="Transparent" StrokeThickness="0" Padding="10,6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewAllToursTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="Xem tất cả" FontSize="12" FontAttributes="Bold" TextColor="#512BD4"/>
                    </Border>
                </Grid>

                <!-- Tour 2 cột -->
                <CollectionView Margin="18,0,18,24" ItemsSource="{Binding FeaturedTours}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" Stroke="#E8E3F5" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#15000000" Offset="0,4" Radius="10"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="0">
                                    <!-- Thumbnail ảnh -->
                                    <Border HeightRequest="110" StrokeThickness="0" BackgroundColor="#F3F4F6">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18,18,0,0"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding ThumbnailOrFirstPoi}" Aspect="AspectFill"/>
                                    </Border>
                                    <!-- Info -->
                                    <VerticalStackLayout Padding="12,10" Spacing="3">
                                        <Label Text="{Binding Name}" FontSize="13" FontAttributes="Bold" TextColor="#1A1035" LineBreakMode="TailTruncation" MaxLines="2"/>
                                        <Label Text="{Binding PoiCountText}" FontSize="11" TextColor="#9B7FEA"/>
                                        <Label Text="{Binding Description}" FontSize="11" TextColor="#94A3B8" LineBreakMode="TailTruncation" MaxLines="2"/>
                                    </VerticalStackLayout>
                                    <!-- Nút xem bản đồ -->
                                    <Border BackgroundColor="#512BD4" Stroke="Transparent" StrokeThickness="0" Margin="12,0,12,12" HeightRequest="36">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToTourMapCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                            <Image Source="ic_directions.svg" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"/>
                                            <Label Text="Xem trên bản đồ" FontSize="12" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ Now Playing Bar (Floating at Bottom) ════════════════════════ -->
        <Border Grid.Row="1" BackgroundColor="White" Stroke="#512BD4" StrokeThickness="1" 
                Margin="12,0,12,12" Padding="12" IsVisible="{Binding IsPoiPlaying}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#401A1035" Offset="0,4" Radius="15"/>
            </Border.Shadow>
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Ảnh thumbnail -->
                <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="#F3F4F6" WidthRequest="40" HeightRequest="40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Image Source="{Binding CurrentPlayedPoi.MainImage}" Aspect="AspectFill"/>
                </Border>

                <!-- Tên POI + progress — bấm để mở bản đồ -->
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding GoToMapWithPoiCommand}"
                            CommandParameter="{Binding CurrentPlayedPoi}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="Đang thuyết minh" FontSize="10" TextColor="#9B7FEA" FontAttributes="Bold"/>
                    <Label Text="{Binding CurrentPlayedPoi.Name}" FontSize="14" FontAttributes="Bold"
                           TextColor="#1A1035" LineBreakMode="TailTruncation"/>
                    <ProgressBar Progress="{Binding CurrentPlayedPoi.AudioProgress}" ProgressColor="#512BD4" HeightRequest="4"/>
                </VerticalStackLayout>

                <!-- Nút Play / Pause -->
                <Grid Grid.Column="2" VerticalOptions="Center" WidthRequest="36" HeightRequest="36">
                    <!-- Play (hiện khi đang pause) -->
                    <Border BackgroundColor="#EDE7FF" Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="36" HeightRequest="36">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding CurrentPlayedPoi.IsPlaying}" Value="True">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PlayAudioCommand}" CommandParameter="{Binding CurrentPlayedPoi}"/>
                        </Border.GestureRecognizers>
                        <Image Source="ic_play.svg" WidthRequest="16" HeightRequest="16"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <!-- Pause (hiện khi đang phát) -->
                    <Border BackgroundColor="#FCE7F3" Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="36" HeightRequest="36" IsVisible="False">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding CurrentPlayedPoi.IsPlaying}" Value="True">
                                <Setter Property="IsVisible" Value="True"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PauseAudioCommand}" CommandParameter="{Binding CurrentPlayedPoi}"/>
                        </Border.GestureRecognizers>
                        <Image Source="ic_pause.svg" WidthRequest="16" HeightRequest="16"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Nút Stop (dừng hẳn, ẩn thanh) -->
                <Border Grid.Column="3" BackgroundColor="#FEE2E2" Stroke="Transparent" StrokeThickness="0"
                        WidthRequest="36" HeightRequest="36" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding StopAudioCommand}"/>
                    </Border.GestureRecognizers>
                    <Image Source="ic_white_stop.svg" WidthRequest="14" HeightRequest="14"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

            </Grid>
        </Border>
    </Grid>
</ContentPage>