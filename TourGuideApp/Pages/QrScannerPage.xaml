<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:BarcodeScanner.Mobile;assembly=BarcodeScanner.Mobile.Maui"
             xmlns:services="clr-namespace:TourGuideApp.Services"
             x:Class="TourGuideApp.Pages.QrScannerPage"
             Title="{services:Translate Key='qr_scanner_title'}"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">

    <!--
        Layout 2 tầng:
          Row 0 (*) → Camera + khung quét (chiếm hết phần trên)
          Row 1 (Auto) → Result card (ẩn mặc định, hiện khi quét xong)
        Camera trải Grid.RowSpan="2" làm nền toàn màn hình.
    -->
    <Grid RowDefinitions="*, Auto">

        <!-- ── CAMERA nền toàn màn hình ── -->
        <m:CameraView x:Name="BarcodeReader"
                      Grid.RowSpan="2"
                      OnDetected="OnBarcodesDetected"
                      ScanInterval="500"/>

        <!-- ── ROW 0: Top bar + khung quét ── -->
        <Grid Grid.Row="0" RowDefinitions="Auto,*">

            <!-- Top bar -->
            <Grid Grid.Row="0" Padding="15,48,15,10" ColumnDefinitions="Auto,*">
                <ImageButton Source="ic_back.svg"
                             WidthRequest="40" HeightRequest="40"
                             BackgroundColor="Transparent"
                             Clicked="OnBackClicked"/>
                <Label Grid.Column="1"
                       Text="{services:Translate Key='qr_scanner_title'}"
                       TextColor="White" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       Margin="0,0,40,0"/>
            </Grid>

            <!-- Khung quét -->
            <Grid Grid.Row="1">
                <!-- Dimmed overlay -->
                <Path Fill="#88000000" Aspect="Fill"
                      Data="M 0,0 L 1,0 L 1,1 L 0,1 Z M 0.12,0.15 L 0.88,0.15 L 0.88,0.8 L 0.12,0.8 Z"
                      HorizontalOptions="Fill" VerticalOptions="Fill"/>

                <!-- Corner brackets -->
                <Grid x:Name="ScannerFrame"
                      WidthRequest="268" HeightRequest="268"
                      HorizontalOptions="Center" VerticalOptions="Center">
                    <BoxView WidthRequest="32" HeightRequest="4" BackgroundColor="#9B7FEA" HorizontalOptions="Start" VerticalOptions="Start" CornerRadius="2"/>
                    <BoxView WidthRequest="4" HeightRequest="32" BackgroundColor="#9B7FEA" HorizontalOptions="Start" VerticalOptions="Start" CornerRadius="2"/>
                    <BoxView WidthRequest="32" HeightRequest="4" BackgroundColor="#9B7FEA" HorizontalOptions="End"   VerticalOptions="Start" CornerRadius="2"/>
                    <BoxView WidthRequest="4" HeightRequest="32" BackgroundColor="#9B7FEA" HorizontalOptions="End"   VerticalOptions="Start" CornerRadius="2"/>
                    <BoxView WidthRequest="32" HeightRequest="4" BackgroundColor="#9B7FEA" HorizontalOptions="Start" VerticalOptions="End"   CornerRadius="2"/>
                    <BoxView WidthRequest="4" HeightRequest="32" BackgroundColor="#9B7FEA" HorizontalOptions="Start" VerticalOptions="End"   CornerRadius="2"/>
                    <BoxView WidthRequest="32" HeightRequest="4" BackgroundColor="#9B7FEA" HorizontalOptions="End"   VerticalOptions="End"   CornerRadius="2"/>
                    <BoxView WidthRequest="4" HeightRequest="32" BackgroundColor="#9B7FEA" HorizontalOptions="End"   VerticalOptions="End"   CornerRadius="2"/>

                    <BoxView x:Name="ScannerLine"
                             WidthRequest="244" HeightRequest="2"
                             BackgroundColor="#9B7FEA"
                             HorizontalOptions="Center" VerticalOptions="Start"
                             Margin="0,22,0,0">
                        <BoxView.Shadow>
                            <Shadow Brush="#9B7FEA" Offset="0,0" Radius="10" Opacity="0.9"/>
                        </BoxView.Shadow>
                    </BoxView>
                </Grid>

                <Label Text="{services:Translate Key='move_camera_to_qr_desc'}"
                       TextColor="#CCCCCC" FontSize="13"
                       HorizontalOptions="Center" VerticalOptions="End"
                       Margin="0,0,0,20"/>
            </Grid>
        </Grid>

        <!-- ── ROW 1: Result card — nằm ngay dưới khung quét ────────────────
             IsVisible="False" mặc định.
             Code-behind set IsVisible=True khi quét thành công.
        ─────────────────────────────────────────────────────────────────── -->
        <Border x:Name="ResultCard"
                Grid.Row="1"
                BackgroundColor="White"
                Stroke="#E8E3F5" StrokeThickness="1"
                IsVisible="False"
                Margin="12,0,12,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#50000000" Offset="0,-3" Radius="18"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="0" Padding="16,14">

                <!-- ── Ảnh + Tên + Khoảng cách + Nút đóng ── -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="64,*,Auto"
                      ColumnSpacing="12"
                      Margin="0,0,0,12">

                    <Border Grid.Column="0"
                            WidthRequest="64" HeightRequest="64"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Image Source="{Binding ScannedPoi.MainImage}" Aspect="AspectFill"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                        <Label Text="{Binding ScannedPoi.Name}"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#1A1035" LineBreakMode="TailTruncation"/>
                        <Label Text="{Binding ScannedPoi.DistanceText}"
                               FontSize="12" TextColor="#64748B"/>
                        <Label Text="{Binding ScannedPoi.Description}"
                               FontSize="12" TextColor="#475569"
                               MaxLines="2" LineBreakMode="TailTruncation"/>
                    </VerticalStackLayout>

                    <!-- Nút đóng -->
                    <Border Grid.Column="2"
                            BackgroundColor="#F4F2FB"
                            Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="32" HeightRequest="32"
                            VerticalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="9"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseResultClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="✕" FontSize="14" TextColor="#512BD4"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- ── Progress bar + Duration ── -->
                <VerticalStackLayout Grid.Row="1" Margin="0,0,0,12" Spacing="2">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="{services:Translate Key='listening_progress_label'}" FontSize="11" TextColor="#64748B" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding ScannedPoi.AudioDuration}" 
                               FontSize="11" FontAttributes="Bold" TextColor="#512BD4" VerticalOptions="Center"/>
                    </Grid>
                    <Slider Minimum="0" Maximum="1"
                            Value="{Binding ScannedPoi.AudioProgress}"
                            MinimumTrackColor="#9B7FEA"
                            MaximumTrackColor="#E8E3F5"
                            ThumbColor="#512BD4"
                            IsEnabled="False"/>
                </VerticalStackLayout>

                <!-- ── Audio controls + Nút xem chi tiết ──────────────────────
                     IsPlaying=False → Play HIỆN, Pause+Stop ẨN
                     IsPlaying=True  → Play ẨN,  Pause+Stop HIỆN
                ─────────────────────────────────────────────────────────────-->
                <Grid Grid.Row="2"
                      ColumnDefinitions="Auto,Auto,Auto,*"
                      ColumnSpacing="10">

                    <!-- PLAY -->
                    <Border Grid.Column="0"
                            BackgroundColor="#EDE7FF"
                            Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="46" HeightRequest="46">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding ScannedPoi.IsPlaying}" Value="True">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPlayAudioClicked"/>
                        </Border.GestureRecognizers>
                        <Image Source="ic_play.svg"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- PAUSE -->
                    <Border Grid.Column="1"
                            BackgroundColor="#FCE7F3"
                            Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="46" HeightRequest="46"
                            IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding ScannedPoi.IsPlaying}" Value="True">
                                <Setter Property="IsVisible" Value="True"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPauseAudioClicked"/>
                        </Border.GestureRecognizers>
                        <Image Source="ic_pause.svg"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- STOP -->
                    <Border Grid.Column="2"
                            BackgroundColor="#F1F5F9"
                            Stroke="Transparent" StrokeThickness="0"
                            WidthRequest="46" HeightRequest="46"
                            IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding ScannedPoi.IsPlaying}" Value="True">
                                <Setter Property="IsVisible" Value="True"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStopAudioClicked"/>
                        </Border.GestureRecognizers>
                        <Image Source="ic_white_stop.svg"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Xem chi tiết -->
                    <Border Grid.Column="3"
                            BackgroundColor="#512BD4"
                            Stroke="Transparent" StrokeThickness="0"
                            HeightRequest="46">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDetailClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="{services:Translate Key='view_details_button'}"
                               FontSize="13" FontAttributes="Bold" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
