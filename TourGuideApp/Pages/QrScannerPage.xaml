<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:BarcodeScanner.Mobile;assembly=BarcodeScanner.Mobile.Maui"
             x:Class="TourGuideApp.Pages.QrScannerPage"
             Title="Quét mã QR"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Camera View (Google ML Kit) -->
        <m:CameraView x:Name="BarcodeReader"
                      Grid.RowSpan="3"
                      OnDetected="OnBarcodesDetected"
                      ScanInterval="500" />

        <!-- Top Bar -->
        <Grid Grid.Row="0" Padding="15,40,15,10" ColumnDefinitions="Auto, *">
            <ImageButton Source="ic_back.svg"
                         WidthRequest="40"
                         HeightRequest="40"
                         Clicked="OnBackClicked"
                         BackgroundColor="Transparent"/>
            <Label Grid.Column="1" 
                   Text="Quét mã QR" 
                   TextColor="White" 
                   FontSize="18" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="0,0,40,0"/>
        </Grid>

        <!-- Scanner Viewport Layer -->
        <Grid Grid.Row="1">
            <!-- Dimmed background with cutout -->
            <Path Fill="#80000000"
                  Aspect="Fill"
                  Data="M 0,0 L 1,0 L 1,1 L 0,1 Z M 0.15,0.3 L 0.85,0.3 L 0.85,0.6 L 0.15,0.6 Z"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill"/>

            <!-- Scanner Frame Corners -->
            <Grid x:Name="ScannerFrame" 
                  WidthRequest="260" 
                  HeightRequest="260" 
                  HorizontalOptions="Center" 
                  VerticalOptions="Center">
                <!-- Top-Left -->
                <BoxView WidthRequest="30" HeightRequest="4" BackgroundColor="#9B7FEA" HorizontalOptions="Start" VerticalOptions="Start" CornerRadius="2"/>
                <BoxView WidthRequest="4" HeightRequest="30" BackgroundColor="#9B7FEA" HorizontalOptions="Start" VerticalOptions="Start" CornerRadius="2"/>
                
                <!-- Top-Right -->
                <BoxView WidthRequest="30" HeightRequest="4" BackgroundColor="#9B7FEA" HorizontalOptions="End" VerticalOptions="Start" CornerRadius="2"/>
                <BoxView WidthRequest="4" HeightRequest="30" BackgroundColor="#9B7FEA" HorizontalOptions="End" VerticalOptions="Start" CornerRadius="2"/>

                <!-- Bottom-Left -->
                <BoxView WidthRequest="30" HeightRequest="4" BackgroundColor="#9B7FEA" HorizontalOptions="Start" VerticalOptions="End" CornerRadius="2"/>
                <BoxView WidthRequest="4" HeightRequest="30" BackgroundColor="#9B7FEA" HorizontalOptions="Start" VerticalOptions="End" CornerRadius="2"/>

                <!-- Bottom-Right -->
                <BoxView WidthRequest="30" HeightRequest="4" BackgroundColor="#9B7FEA" HorizontalOptions="End" VerticalOptions="End" CornerRadius="2"/>
                <BoxView WidthRequest="4" HeightRequest="30" BackgroundColor="#9B7FEA" HorizontalOptions="End" VerticalOptions="End" CornerRadius="2"/>

                <!-- Scanning Animation Line -->
                <BoxView x:Name="ScannerLine"
                         WidthRequest="240"
                         HeightRequest="2"
                         BackgroundColor="#9B7FEA"
                         HorizontalOptions="Center"
                         VerticalOptions="Start"
                         Margin="0,20,0,0">
                    <BoxView.Shadow>
                        <Shadow Brush="#9B7FEA" Offset="0,0" Radius="10" Opacity="0.8"/>
                    </BoxView.Shadow>
                </BoxView>
            </Grid>

            <Label Text="Di chuyển camera đến mã QR để quét"
                   TextColor="#CCCCCC"
                   FontSize="14"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   Margin="0,0,0,40"/>
        </Grid>

        <!-- Result Tab (Bottom Sheet) -->
        <Border x:Name="ResultCard"
                Grid.Row="2"
                BackgroundColor="White"
                Padding="20"
                TranslationY="400"
                HeightRequest="320">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="20" Opacity="0.2"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto, Auto, Auto, *">
                <!-- Handle -->
                <BoxView Grid.Row="0" 
                         WidthRequest="40" 
                         HeightRequest="4" 
                         CornerRadius="2" 
                         BackgroundColor="#E5E7EB" 
                         HorizontalOptions="Center" 
                         Margin="0,0,0,15"/>

                <!-- POI Info -->
                <Grid Grid.Row="1" ColumnDefinitions="70, *" ColumnSpacing="15" Margin="0,0,0,20">
                    <Border Grid.Column="0" WidthRequest="70" HeightRequest="70" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Image Source="{Binding ScannedPoi.MainImage}" Aspect="AspectFill" />
                    </Border>
                    
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding ScannedPoi.Name}" 
                               FontSize="18" 
                               FontAttributes="Bold" 
                               TextColor="#1A1035"/>
                        <Label Text="{Binding ScannedPoi.Description}" 
                               FontSize="13" 
                               TextColor="#6B7280"
                               MaxLines="2"
                               LineBreakMode="TailTruncation"/>
                    </VerticalStackLayout>
                    
                    <ImageButton Grid.Column="1" 
                                 Source="ic_back.svg" 
                                 HorizontalOptions="End" 
                                 VerticalOptions="Start"
                                 WidthRequest="24"
                                 HeightRequest="24"
                                 Clicked="OnCloseResultClicked"/>
                </Grid>

                <!-- Audio Controls -->
                <VerticalStackLayout Grid.Row="2" Spacing="15">
                    <!-- Progress Bar -->
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="5">
                        <Slider Minimum="0" Maximum="100" 
                                Value="{Binding ScannedPoi.AudioProgress}"
                                MinimumTrackColor="#9B7FEA"
                                MaximumTrackColor="#E8E3F5"
                                ThumbColor="#512BD4"/>
                        <Grid Grid.Row="1" ColumnDefinitions="*, *">
                            <Label Text="1:24" FontSize="11" TextColor="#94A3B8"/>
                            <Label Grid.Column="1" Text="3:45" FontSize="11" TextColor="#94A3B8" HorizontalOptions="End"/>
                        </Grid>
                    </Grid>

                    <!-- Play/Stop Buttons -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="30">
                        <Border BackgroundColor="#FCE7F3" WidthRequest="60" HeightRequest="60" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30"/>
                            </Border.StrokeShape>
                            <Image Source="ic_white_stop.svg" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStopAudioClicked"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <Border BackgroundColor="#EDE7FF" WidthRequest="80" HeightRequest="80" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="40"/>
                            </Border.StrokeShape>
                            <Image x:Name="PlayPauseIcon" 
                                   Source="ic_white_play.svg" 
                                   WidthRequest="32" 
                                   HeightRequest="32" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPlayPauseAudioClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                
                <!-- Action Button -->
                <Button Grid.Row="3" 
                        Text="Xem chi tiết địa điểm"
                        BackgroundColor="#512BD4"
                        TextColor="White"
                        CornerRadius="16"
                        HeightRequest="54"
                        FontAttributes="Bold"
                        VerticalOptions="End"
                        Margin="0,15,0,0"
                        Clicked="OnDetailClicked"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
