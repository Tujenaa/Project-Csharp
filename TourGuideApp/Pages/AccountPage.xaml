<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:TourGuideApp.Services"
    x:Class="TourGuideApp.Pages.AccountPage"
    Title=""
    BackgroundColor="#F4F2FB"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Custom header ── -->
        <Grid Grid.Row="0" BackgroundColor="#1A1035" Padding="16,52,16,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Back button -->
            <Border Grid.Column="0" BackgroundColor="#2D1B6E"
                    WidthRequest="40" HeightRequest="40"
                    StrokeThickness="0" VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Border.GestureRecognizers>
                <Label Text="‹" FontSize="22" TextColor="White"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Label Grid.Column="1" Text="{services:Translate Key='account_info_header'}"
                   FontSize="18" FontAttributes="Bold" TextColor="White"
                   VerticalOptions="Center" Margin="12,0,0,0"/>
        </Grid>

        <!-- ── Scrollable content ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,40">

                <!-- Avatar section -->
                <VerticalStackLayout HorizontalOptions="Center" Margin="0,28,0,24" Spacing="10">
                    <Border BackgroundColor="#512BD4" WidthRequest="80" HeightRequest="80"
                            StrokeThickness="0" HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24"/>
                        </Border.StrokeShape>
                        <Label x:Name="BigAvatarLabel" Text="U"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label x:Name="HeaderNameLabel" Text="{services:Translate Key='user'}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="#1A1035" HorizontalOptions="Center"/>
                    <Label x:Name="HeaderEmailLabel" Text=""
                           FontSize="13" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Edit form -->
                <!-- ── Personal Information Header ── -->
                <Grid Margin="22,12,22,8" ColumnDefinitions="*, Auto">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleProfileFormCommand}"/>
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0" Text="{services:Translate Key='personal_info_section_header'}"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#94A3B8" CharacterSpacing="1"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="⌵" FontSize="18"
                           TextColor="#94A3B8" VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Rotation="{Binding IsProfileFormVisible, Converter={StaticResource RotationConverter}}"/>
                </Grid>

                <VerticalStackLayout IsVisible="{Binding IsProfileFormVisible}">
                    <Border Margin="18,0" BackgroundColor="White"
                            Stroke="#E8E3F5" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="20,18" Spacing="0">
                            <Label Text="{services:Translate Key='username_label'}" FontSize="11" FontAttributes="Bold"
                                   TextColor="#94A3B8" Margin="0,0,0,6" CharacterSpacing="0.8"/>
                            <Border BackgroundColor="#F4F2FB" Stroke="#E8E3F5" StrokeThickness="1.5"
                                    Margin="0,0,0,16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="13"/>
                                </Border.StrokeShape>
                                <Entry x:Name="UsernameEntry" 
                                       Text="{Binding Username}"
                                       PlaceholderColor="#1A1035" TextColor="#1A1035"
                                       FontSize="15" BackgroundColor="Transparent"
                                       Margin="6,0" HeightRequest="48"
                                       IsEnabled="False"/>        
                            </Border>
                            <!-- Full name -->
                            <Label Text="{services:Translate Key='full_name_label'}" FontSize="11" FontAttributes="Bold"
                                   TextColor="#94A3B8" Margin="0,0,0,6" CharacterSpacing="0.8"/>
                            <Border BackgroundColor="#F4F2FB" Stroke="#E8E3F5" StrokeThickness="1.5"
                                    Margin="0,0,0,16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="13"/>
                                </Border.StrokeShape>
                                <Entry x:Name="NameEntry" 
                                       Text="{Binding Name}"
                                       Placeholder="{services:Translate Key='name_placeholder'}"
                                       PlaceholderColor="#B0ADBB" TextColor="#1A1035"
                                       FontSize="15" BackgroundColor="Transparent"
                                       Margin="6,0" HeightRequest="48"/>
                            </Border>

                            <!-- Email (read-only) -->
                            <Label Text="{services:Translate Key='email_label'}" FontSize="11" FontAttributes="Bold"
                                   TextColor="#94A3B8" Margin="0,0,0,6" CharacterSpacing="0.8"/>
                            <Border BackgroundColor="#EEEAF8" Stroke="#E8E3F5" StrokeThickness="1.5"
                                    Margin="0,0,0,16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="13"/>
                                </Border.StrokeShape>
                                <Entry x:Name="EmailEntry" 
                                       Text="{Binding Email}"
                                       PlaceholderColor="#B0ADBB" TextColor="#6B7280"
                                       FontSize="15" Keyboard="Email" IsReadOnly="True"
                                       BackgroundColor="Transparent"
                                       Margin="6,0" HeightRequest="48"
                                       IsEnabled="False"/>
                            </Border>

                            <!-- Phone -->
                            <Label Text="{services:Translate Key='phone_number_label'}" FontSize="11" FontAttributes="Bold"
                                   TextColor="#94A3B8" Margin="0,0,0,6" CharacterSpacing="0.8"/>
                            <Border BackgroundColor="#F4F2FB" Stroke="#E8E3F5" StrokeThickness="1.5"
                                    Margin="0,0,0,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="13"/>
                                </Border.StrokeShape>
                                <Entry x:Name="PhoneEntry" 
                                       Text="{Binding Phone}"
                                       Placeholder="{services:Translate Key='phone_placeholder'}"
                                       PlaceholderColor="#B0ADBB" TextColor="#1A1035"
                                       FontSize="15" Keyboard="Telephone"
                                       BackgroundColor="Transparent"
                                       Margin="6,0" HeightRequest="48"/>
                            </Border>

                            <Label Text="{services:Translate Key='readonly_note'}"
                                   FontSize="11" TextColor="#94A3B8" Margin="4,6,0,0"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Save button -->
                    <Button x:Name="SaveButton" 
                            Text="{services:Translate Key='save_changes_button'}"
                            Command="{Binding SaveProfileCommand}"
                            BackgroundColor="#512BD4" TextColor="White"
                            FontSize="15" FontAttributes="Bold"
                            CornerRadius="14" HeightRequest="50"
                            Margin="18,16,18,0">
                        <Button.Shadow>
                            <Shadow Brush="#40512BD4" Offset="0,6" Radius="16"/>
                        </Button.Shadow>
                    </Button>
                </VerticalStackLayout>

                <!-- Error/success message -->
                <Label 
                    Text="{Binding StatusMessage}"
                    TextColor="{Binding IsError, Converter={StaticResource ErrorColorConverter}}"
                    IsVisible="{Binding HasMessage}"
                    HorizontalOptions="Center"
                    Margin="12,6"/>

                <!-- ── Change password section Header ── -->
                <Grid Margin="22,28,22,8" ColumnDefinitions="*, Auto">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding TogglePasswordFormCommand}"/>
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0" Text="{services:Translate Key='security_section_header'}"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#94A3B8" CharacterSpacing="1"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="⌵" FontSize="18"
                           TextColor="#94A3B8" VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Rotation="{Binding IsPasswordFormVisible, Converter={StaticResource RotationConverter}}"/>
                </Grid>

                <VerticalStackLayout IsVisible="{Binding IsPasswordFormVisible}">
                    <Border Margin="18,0" BackgroundColor="White"
                            Stroke="#E8E3F5" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="20,18" Spacing="16">
                            <!-- Old Password -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{services:Translate Key='old_password_label'}" FontSize="11" FontAttributes="Bold"
                                       TextColor="#94A3B8" CharacterSpacing="0.8"/>
                                <Border BackgroundColor="#F4F2FB" Stroke="#E8E3F5" StrokeThickness="1.5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="13"/>
                                    </Border.StrokeShape>
                                    <Entry IsPassword="True" 
                                           Text="{Binding OldPassword}"
                                           PlaceholderColor="#B0ADBB" TextColor="#1A1035"
                                           FontSize="15" BackgroundColor="Transparent"
                                           Margin="6,0" HeightRequest="48"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- New Password -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{services:Translate Key='new_password_label'}" FontSize="11" FontAttributes="Bold"
                                       TextColor="#94A3B8" CharacterSpacing="0.8"/>
                                <Border BackgroundColor="#F4F2FB" Stroke="#E8E3F5" StrokeThickness="1.5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="13"/>
                                    </Border.StrokeShape>
                                    <Entry IsPassword="True" 
                                           Text="{Binding NewPassword}"
                                           PlaceholderColor="#B0ADBB" TextColor="#1A1035"
                                           FontSize="15" BackgroundColor="Transparent"
                                           Margin="6,0" HeightRequest="48"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Confirm Password -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{services:Translate Key='confirm_password_label'}" FontSize="11" FontAttributes="Bold"
                                       TextColor="#94A3B8" CharacterSpacing="0.8"/>
                                <Border BackgroundColor="#F4F2FB" Stroke="#E8E3F5" StrokeThickness="1.5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="13"/>
                                    </Border.StrokeShape>
                                    <Entry IsPassword="True" 
                                           Text="{Binding ConfirmPassword}"
                                           PlaceholderColor="#B0ADBB" TextColor="#1A1035"
                                           FontSize="15" BackgroundColor="Transparent"
                                           Margin="6,0" HeightRequest="48"/>
                                </Border>
                            </VerticalStackLayout>

                            <Button Text="{services:Translate Key='update_password_button'}"
                                    Command="{Binding ChangePasswordCommand}"
                                    BackgroundColor="#512BD4" TextColor="White"
                                    FontSize="14" FontAttributes="Bold"
                                    CornerRadius="12" HeightRequest="44"
                                    Margin="0,4,0,0">
                            </Button>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                   IsVisible="{Binding IsBusy}"
                                   Color="#512BD4" Margin="0,20"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

    <ContentPage.Resources>
        <ResourceDictionary>
            <services:ErrorColorConverter x:Key="ErrorColorConverter"/>
            <services:RotationConverter x:Key="RotationConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>
</ContentPage>
