@page
@model GPSGuide.Web.Pages.PoisModel
@{
    ViewData["Title"] = "Điểm thuyết minh"; ViewData["Active"] = "pois";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pois.css" asp-append-version="true" />
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i> @Model.Error</div>
}

<div class="poi-shell">
    <div class="poi-map-wrap">
        <div class="map-topbar">
            <span class="map-count"><i class="bi bi-geo-alt-fill"></i> @Model.Pois.Count điểm thuyết minh</span>
            <button class="btn btn-primary btn-sm" onclick="openModal()">
                <i class="bi bi-plus-lg"></i> Thêm POI
            </button>
        </div>
        <div id="mainMap"></div>
    </div>

    <div class="poi-right-panel" id="poiRightPanel">
        <div class="poi-list-wrap">
            <div class="poi-list-header">
                <div style="display:flex;gap:6px;align-items:center">
                    <input class="poi-search" id="poiSearch" placeholder="🔍  Tìm địa điểm..."
                           oninput="filterList(this.value)" style="flex:1" />
                    <button class="btn btn-ghost btn-icon btn-sm" title="Xem tất cả trên map"
                            onclick="resetMap()" style="flex-shrink:0;padding:6px 8px">
                        <i class="bi bi-fullscreen"></i>
                    </button>
                </div>
            </div>
            <div class="poi-list" id="poiList">
                @foreach (var p in Model.Pois)
                {
                    <div class="poi-item" id="item-@p.Id" data-id="@p.Id" onclick="selectPoiById(@p.Id)">
                        @{
                            var thumb = p.Status == "REJECTED" ? null : (p.ImageUrl ?? (p.Images.FirstOrDefault(i => i.IsThumbnail)?.ImageUrl ?? p.Images.FirstOrDefault()?.ImageUrl));
                            var fullThumb = string.IsNullOrEmpty(thumb) ? "" : "/img-proxy?url=" + System.Net.WebUtility.UrlEncode(thumb);
                        }
                        <img class="poi-item-thumb" src="@fullThumb" />

                        <div class="poi-item-body">
                            <div style="display:flex;align-items:center;gap:6px">
                                <div class="poi-item-name">@p.Name</div>
                                @if (p.Status == "PENDING") {
                                    <span style="font-size:10px;background:#fef3c7;color:#92400e;padding:1px 6px;border-radius:10px;font-weight:600">⏳ Chờ duyệt</span>
                                } else if (p.Status == "REJECTED") {
                                    <span style="font-size:10px;background:#fee2e2;color:#991b1b;padding:1px 6px;border-radius:10px;font-weight:600" title="@p.RejectReason">❌ Từ chối</span>
                                }
                            </div>
                            <div class="poi-item-meta">
                                <span class="poi-item-coord">@p.Latitude.ToString("F4"), @p.Longitude.ToString("F4")</span>
                                <span class="poi-item-r">@p.Radius m</span>
                            </div>
                        </div>
                        <i class="bi bi-chevron-right poi-item-arrow"></i>
                    </div>
                }
                @if (!Model.Pois.Any())
                {
                    <div class="poi-empty">
                        <i class="bi bi-geo-alt" style="font-size:36px;opacity:.25;display:block;margin-bottom:10px"></i>
                        Chưa có điểm nào.<br />
                        <a href="#" onclick="openModal();return false;" style="color:var(--accent)">Thêm POI đầu tiên</a>
                    </div>
                }
            </div>
        </div>

        <div class="poi-detail" id="poiDetail">
            <div class="detail-nav">
                <button class="btn-back" onclick="closeDetail()" title="Quay lại danh sách"><i class="bi bi-arrow-left"></i></button>
                <h4 id="detailNavTitle">Chi tiết địa điểm</h4>
            </div>

            <div class="detail-placeholder" id="detailPlaceholder">
                <i class="bi bi-cursor" style="font-size:32px;opacity:.2"></i>
                <p>Chọn một địa điểm<br />để xem chi tiết</p>
            </div>
            <div class="detail-content" id="detailContent" style="display:none">
                <div class="detail-img-wrap">
                    <img id="detailImg" src="" alt="" />
                    <div class="detail-img-overlay">
                        <span class="detail-badge" id="detailRadius"></span>
                    </div>
                </div>
                <div id="detailThumbs" style="display:none;padding:6px 8px;background:#f3f4f6;gap:6px;overflow-x:auto;flex-shrink:0"></div>
                <div class="detail-body">
                    <h3 id="detailName"></h3>
                    <p class="detail-desc" id="detailDesc"></p>
                    <div class="detail-info-grid">
                        <div class="detail-info-item"><span class="dii-label">Vĩ độ</span><span class="dii-val mono" id="detailLat"></span></div>
                        <div class="detail-info-item"><span class="dii-label">Kinh độ</span><span class="dii-val mono" id="detailLng"></span></div>
                        <div class="detail-info-item"><span class="dii-label">Bán kính</span><span class="dii-val" id="detailR"></span></div>
                        <div class="detail-info-item"><span class="dii-label">Chủ sở hữu</span><span class="dii-val" id="detailOwner"></span></div>
                    </div>
                    <div class="detail-actions">
                        <button class="btn btn-outline btn-sm" onclick="editCurrentPoi()"><i class="bi bi-pencil"></i> Sửa</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteCurrentPoi()"><i class="bi bi-trash"></i> Xoá</button>
                    </div>

                    <div id="poiToursPanel" style="margin-top:18px;border-top:1px solid var(--border);padding-top:14px;display:none">
                        <div style="font-size:11px;font-weight:700;color:#5b21b6;text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px">
                            <i class="bi bi-map"></i> Tour có điểm này
                        </div>
                        <div id="poiToursList"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="poiModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4 id="modalTitle">Thêm điểm thuyết minh</h4>
            <button class="btn btn-ghost btn-icon" onclick="closeModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <form id="poiForm" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="fId" value="0" />
            <div class="modal-body">
                <div class="tab-nav">
                    <button type="button" class="tab-btn active" id="btnTabBasic" onclick="showTab('tab-basic','btnTabBasic')"><i class="bi bi-info-circle"></i> Thông tin</button>
                    <button type="button" class="tab-btn" id="btnTabLoc" onclick="showTab('tab-loc','btnTabLoc')"><i class="bi bi-geo-alt"></i> Vị trí</button>
                    @if (Model.AllTours.Any()) { <button type="button" class="tab-btn" id="btnTabTour" onclick="showTab('tab-tour','btnTabTour')"><i class="bi bi-map"></i> Tour</button> }
                </div>
                
                <div id="tab-basic" class="tab-pane">
                    <div class="form-group">
                        <label class="form-label">Tên điểm <span class="req">*</span></label>
                        <input type="text" name="Name" id="fName" class="form-control" required maxlength="255" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Mô tả</label>
                        <textarea name="Description" id="fDescription" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Hình ảnh POI <span style="font-size:11px;color:#9ca3af;font-weight:400;margin-left:4px">tối đa 5 ảnh, mỗi ảnh 5MB</span></label>
                        
                        <div id="currentImagesWrap" style="display:none;margin-bottom:10px">
                            <div style="font-size:12px;color:#6b7280;margin-bottom:6px">Ảnh hiện tại:</div>
                            <div id="currentImagesGrid" style="display:grid;grid-template-columns:repeat(auto-fill, minmax(80px, 1fr));gap:8px"></div>
                        </div>

                        <div id="previewGrid" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px"></div>
                        <div id="imageUploadArea" style="border:2px dashed #d1d5db;border-radius:8px;padding:14px;text-align:center;cursor:pointer;background:#fafafa" onclick="document.getElementById('imageFileInput').click()">
                            <i class="bi bi-cloud-upload" style="font-size:22px;color:#9ca3af;display:block;margin-bottom:4px"></i>
                            <span style="font-size:13px;color:#6b7280">Click hoặc kéo thả ảnh vào đây</span><br/>
                        </div>
                        <input type="file" name="ImageFiles" id="imageFileInput" accept="image/jpeg,image/png,image/webp" multiple style="display:none" onchange="previewImages(this)" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Bán kính (m) <span class="req">*</span></label>
                            <input type="number" name="Radius" id="fRadius" class="form-control" min="1" max="5000" value="5" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Chủ sở hữu</label>
                            @if (Model.IsAdmin)
                            {
                                <select name="OwnerId" id="fOwnerId" class="form-control">
                                    <option value="">-- Không có --</option>
                                    @foreach (var o in Model.Owners) { <option value="@o.Id">@o.Username (#@o.Id)</option> }
                                </select>
                            }
                            else
                            {
                                <input type="hidden" name="OwnerId" id="fOwnerId" value="@Model.MyUserIdVal" />
                                <input type="text" class="form-control" value="#@Model.MyUserIdVal — @(HttpContext.Session.GetString("Username"))" readonly disabled style="opacity:.6;cursor:not-allowed" />
                            }
                        </div>
                    </div>
                </div>

                <div id="tab-loc" class="tab-pane" style="display:none">
                    <div class="form-row">
                        <div class="form-group"><label class="form-label">Vĩ độ <span class="req">*</span></label><input type="number" name="Latitude" id="fLat" class="form-control" step="0.000001" required /></div>
                        <div class="form-group"><label class="form-label">Kinh độ <span class="req">*</span></label><input type="number" name="Longitude" id="fLng" class="form-control" step="0.000001" required /></div>
                    </div>
                    <div class="map-toolbar">
                        <button type="button" class="btn btn-sm btn-outline" onclick="getMyLocation()"><i class="bi bi-crosshair"></i> Vị trí hiện tại</button>
                    </div>
                    <div id="pickMap" style="height:280px;border-radius:8px;border:1px solid var(--border);margin-top:10px;overflow:hidden"></div>
                </div>

                @if (Model.AllTours.Any())
                {
                    <div id="tab-tour" class="tab-pane" style="display:none">
                        <div style="display:flex;flex-direction:column;gap:6px;max-height:260px;overflow-y:auto" id="tourCheckList">
                            @foreach (var t in Model.AllTours)
                            {
                                <label data-tourid="@t.Id" style="display:flex;align-items:center;gap:8px;padding:8px 10px;border:1px solid var(--border);border-radius:7px;cursor:pointer">
                                    <input type="checkbox" name="TourIds" value="@t.Id" style="width:15px;height:15px;accent-color:var(--accent);flex-shrink:0" />
                                    <div style="flex:1;min-width:0">
                                        <div style="font-size:13px;font-weight:500;display:flex;align-items:center;gap:5px">@t.Name<span class="tour-status-badge" data-tourid="@t.Id" style="display:none"></span></div>
                                    </div>
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary" id="submitBtn"><i class="bi bi-check-lg"></i> Lưu</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="modal-backdrop" style="display:none" onclick="closeDelete()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
        <div class="modal-header"><h4>Xác nhận xoá</h4><button class="btn btn-ghost btn-icon" onclick="closeDelete()"><i class="bi bi-x-lg"></i></button></div>
        <div class="modal-body"><p>Bạn có chắc muốn xoá <strong id="delName"></strong>?</p></div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeDelete()">Huỷ</button>
            <form method="post" asp-page-handler="Delete" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeleteId" id="fDelId" />
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Xoá</button>
            </form>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    const API_BASE  = '@Model.ApiBaseUrl';
    const IS_ADMIN   = @(Model.IsAdmin ? "true" : "false");
    const ROLE_HDR   = { 'Content-Type': 'application/json', 'X-Role': IS_ADMIN ? 'ADMIN' : 'OWNER' };
    
    // BIẾN THEO DÕI THAY ĐỔI FORM (Chống gửi nhầm POI PENDING)
    let isPoiDirty = false;

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('poiForm').addEventListener('input', function(e) {
            if (e.target.name !== 'TourIds') isPoiDirty = true;
        });
        const imgInput = document.getElementById('imageFileInput');
        if(imgInput) imgInput.addEventListener('change', () => isPoiDirty = true);

        let clat=10.7769, clng=106.7009;
        if(POIS.length){ clat=POIS.reduce((s,p)=>s+p.lat,0)/POIS.length; clng=POIS.reduce((s,p)=>s+p.lng,0)/POIS.length; }
        mainMap=L.map('mainMap').setView([clat,clng],14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19}).addTo(mainMap);
        POIS.forEach(p=>{
            const m=L.marker([p.lat,p.lng],{icon:mkIcon(false)}).addTo(mainMap);
            m.bindTooltip(`<b>${p.name}</b>`,{direction:'top',offset:[0,-20]});
            m.on('click',()=>selectPoiById(p.id));
            markers[p.id]=m;
            circles[p.id]=L.circle([p.lat,p.lng],{radius:p.radius,color:'#e94560',fillColor:'#e94560',fillOpacity:.08,weight:1.5}).addTo(mainMap);
        });
    });

    function toAbsUrl(url) { return url ? '/img-proxy?url=' + encodeURIComponent(url) : ''; }

    const POIS = JSON.parse('@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Pois.Select(p => new {
        id     = p.Id,
        name   = p.Name,
        desc   = p.Description ?? "",
        lat    = p.Latitude,
        lng    = p.Longitude,
        radius = p.Radius,
        owner  = p.OwnerId.HasValue ? "#" + p.OwnerId.Value : "—",
        njs    = p.Name,
        djs    = p.Description ?? "",
        oarg   = p.OwnerId.HasValue ? p.OwnerId.Value.ToString() : "null",
        img    = p.ImageUrl ?? "",
        status = p.Status,
        images = p.Images.Select(i => new { id = i.Id, imageUrl = i.ImageUrl, isThumbnail = i.IsThumbnail })
    })).Replace("'", "\\'"))');

    let mainMap, markers={}, circles={}, selectedId=null;

    function mkIcon(active){
        return L.divIcon({className:'',html:`<div class="poi-pin${active?' active':''}"></div>`,iconSize:[22,22],iconAnchor:[11,22],popupAnchor:[0,-24]});
    }

    function selectPoiById(id){
        const poi=POIS.find(p=>p.id===id); if(!poi) return;
        if(selectedId!==null){
            const oldEl=document.getElementById('item-'+selectedId);
            if(oldEl) oldEl.classList.remove('selected');
            if(markers[selectedId]) markers[selectedId].setIcon(mkIcon(false));
        }
        selectedId=id;
        const el=document.getElementById('item-'+id);
        if(el){ el.classList.add('selected'); el.scrollIntoView({behavior:'smooth',block:'nearest'}); }
        if(markers[id]){ markers[id].setIcon(mkIcon(true)); mainMap.flyTo([poi.lat,poi.lng],16,{duration:.8}); }
        document.getElementById('poiRightPanel').classList.add('detail-active');
        showDetail(poi);
    }

    function closeDetail() {
        document.getElementById('poiRightPanel').classList.remove('detail-active');
        if(selectedId!==null){
            const el=document.getElementById('item-'+selectedId);
            if(el) el.classList.remove('selected');
            if(markers[selectedId]) markers[selectedId].setIcon(mkIcon(false));
            selectedId = null;
        }
    }

    function showDetail(poi){
        document.getElementById('detailPlaceholder').style.display='none';
        document.getElementById('detailContent').style.display='flex';

        let thumb = (poi.status !== 'REJECTED' && poi.images && poi.images.length > 0)
            ? (poi.images.find(i => i.isThumbnail) || poi.images[0])
            : null;

        let finalImgUrl = '';
        if (thumb && thumb.imageUrl) finalImgUrl = toAbsUrl(thumb.imageUrl);
        else if (poi.status !== 'REJECTED' && poi.img) finalImgUrl = toAbsUrl(poi.img);

        document.getElementById('detailImg').src = finalImgUrl;
        
        const thumbsWrap = document.getElementById('detailThumbs');
        if (poi.status !== 'REJECTED' && poi.images && poi.images.length > 1) {
            thumbsWrap.style.display = 'flex';
            thumbsWrap.innerHTML = poi.images.map(img => `<img src="${toAbsUrl(img.imageUrl)}" onclick="document.getElementById('detailImg').src='${toAbsUrl(img.imageUrl)}'" style="width:52px;height:40px;object-fit:cover;border-radius:5px;cursor:pointer;border:2px solid ${img.isThumbnail ? '#7c3aed' : '#e5e7eb'};flex-shrink:0" />`).join('');
        } else {
            thumbsWrap.style.display = 'none';
        }

        document.getElementById('detailRadius').textContent = poi.radius + ' m';
        document.getElementById('detailName').textContent = poi.name;
        document.getElementById('detailNavTitle').textContent = poi.name;
        document.getElementById('detailDesc').textContent = poi.desc || 'Chưa có mô tả.';
        document.getElementById('detailLat').textContent = poi.lat.toFixed(6);
        document.getElementById('detailLng').textContent = poi.lng.toFixed(6);
        document.getElementById('detailR').textContent = poi.radius + ' m';
        document.getElementById('detailOwner').textContent = poi.owner;
        loadPoiTours(poi.id);
    }

    function editCurrentPoi(){ const p=POIS.find(x=>x.id===selectedId); if(p) editPoi(p.id,p.njs,p.djs,p.lat,p.lng,p.radius,p.oarg,p.img); }
    function deleteCurrentPoi(){ const p=POIS.find(x=>x.id===selectedId); if(p) confirmDelete(p.id,p.name); }

    // XÓA ẢNH - KHÔNG CẦN CONFIRM
    async function deleteImage(imageId) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const formData = new FormData();
        formData.append('ImageIdToDelete', imageId);
        formData.append('__RequestVerificationToken', token);
        try {
            const res = await fetch(window.location.pathname + '?handler=DeleteImage', { method: 'POST', body: formData });
            if (res.ok) {
                const imgWrap = document.getElementById('imgwrap-' + imageId);
                if (imgWrap) imgWrap.remove();
                const poi = POIS.find(p => p.id === selectedId);
                if (poi && poi.images) poi.images = poi.images.filter(i => i.id !== imageId);
                const grid = document.getElementById('currentImagesGrid');
                if (grid && grid.children.length === 0) document.getElementById('currentImagesWrap').style.display = 'none';
            } else alert('Lỗi từ server khi xoá ảnh.');
        } catch (err) { alert('Lỗi kết nối.'); }
    }

    async function loadPoiTours(poiId) {
        const panel = document.getElementById('poiToursPanel');
        const list  = document.getElementById('poiToursList');
        panel.style.display = 'none';
        try {
            const [toursRes, pendRes, approvedRes, removeRes, rejectedRes] = await Promise.all([
                fetch(`${API_BASE}/api/tours/by-poi/${poiId}`),
                fetch(`${API_BASE}/api/tours/pois/all-pending`),
                fetch(`${API_BASE}/api/tours/pois/all-approved`),
                fetch(`${API_BASE}/api/tours/pois/all-remove-pending`),
                fetch(`${API_BASE}/api/tours/pois/all-rejected`)
            ]);
            const approvedTours = toursRes.ok ? await toursRes.json() : [];
            const allPending = pendRes.ok ? await pendRes.json() : [];
            const allApproved = approvedRes.ok ? await approvedRes.json() : [];
            const allRemove = removeRes.ok ? await removeRes.json() : [];
            const allRejected = rejectedRes.ok ? await rejectedRes.json() : [];

            const statusMap = {};
            allApproved.filter(tp => tp.poiId === poiId).forEach(tp => statusMap[tp.tourId] = { name: tp.tourName, status: 'APPROVED' });
            allPending.filter(tp => tp.poiId === poiId).forEach(tp => statusMap[tp.tourId] = { name: tp.tourName, status: 'PENDING' });
            allRemove.filter(tp => tp.poiId === poiId).forEach(tp => statusMap[tp.tourId] = { name: tp.tourName, status: 'REMOVE_PENDING' });
            allRejected.filter(tp => tp.poiId === poiId).forEach(tp => statusMap[tp.tourId] = { name: tp.tourName, status: 'REJECTED' });

            const entries = Object.entries(statusMap);
            list.innerHTML = '';
            if (entries.length === 0) return;

            panel.style.display = 'block';
            list.innerHTML = entries.map(([tourId, info]) => {
                const label = info.status === 'APPROVED' ? '✅ Thành viên' : (info.status === 'PENDING' ? '⏳ Chờ vào tour' : '🚪 Chờ rời tour');
                const bg = info.status === 'APPROVED' ? '#dcfce7' : '#fef3c7';
                const col = info.status === 'APPROVED' ? '#166534' : '#92400e';
                return `<div style="background:#f9f8ff;border:1px solid #e5e7eb;border-radius:8px;padding:10px;margin-bottom:8px;display:flex;justify-content:space-between">
                            <strong style="color:#4c1d95;font-size:13px">${info.name}</strong>
                            <span style="background:${bg};color:${col};font-size:10px;padding:2px 8px;border-radius:10px;font-weight:700">${label}</span>
                        </div>`;
            }).join('');
        } catch (e) {}
    }

    var _pm=null,_pmk=null,_pmc=null;
    function initPickMap(lat,lng,r){
        if(_pm){_pm.remove();_pm=null;_pmk=null;_pmc=null;}
        _pm=L.map('pickMap').setView([lat,lng],15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(_pm);
        placeMarker(lat,lng,r);
        _pm.on('click',e=>placeMarker(e.latlng.lat,e.latlng.lng,parseFloat(document.getElementById('fRadius').value)||5));
    }
    
    function placeMarker(lat,lng,r){
        isPoiDirty = true; // Đánh dấu form có thay đổi khi đặt marker mới
        if(_pmk)_pm.removeLayer(_pmk); drawCircle(lat,lng,r);
        _pmk=L.marker([lat,lng],{draggable:true}).addTo(_pm);
        document.getElementById('fLat').value=lat.toFixed(6); document.getElementById('fLng').value=lng.toFixed(6);
        _pmk.on('dragend',e=>{
            isPoiDirty = true; // Cập nhật biến theo dõi
            const p=e.target.getLatLng();
            document.getElementById('fLat').value=p.lat.toFixed(6);
            document.getElementById('fLng').value=p.lng.toFixed(6);
            drawCircle(p.lat,p.lng,parseFloat(document.getElementById('fRadius').value)||5);
        });
    }

    function getMyLocation() {
        if (!navigator.geolocation) {
            alert("Trình duyệt không hỗ trợ định vị.");
            return;
        }
        const btn = event.currentTarget;
        const oldHtml = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lấy vị trí...';
        btn.disabled = true;

        navigator.geolocation.getCurrentPosition(
            (pos) => {
                const lat = pos.coords.latitude;
                const lng = pos.coords.longitude;
                const radius = parseFloat(document.getElementById('fRadius').value) || 5;
                if (_pm) {
                    _pm.setView([lat, lng], 17);
                    placeMarker(lat, lng, radius);
                }
                btn.innerHTML = oldHtml;
                btn.disabled = false;
            },
            (err) => {
                alert("Không thể lấy vị trí hiện tại: " + err.message);
                btn.innerHTML = oldHtml;
                btn.disabled = false;
            },
            { enableHighAccuracy: true, timeout: 10000 }
        );
    }
    function drawCircle(lat,lng,r){if(_pmc)_pm.removeLayer(_pmc);_pmc=L.circle([lat,lng],{radius:r,color:'#e94560',fillColor:'#e94560',fillOpacity:.2}).addTo(_pm);}

    function openModal(){
        isPoiDirty = false;
        document.getElementById('poiForm').reset();
        document.getElementById('fId').value='0';
        document.getElementById('modalTitle').textContent='Thêm điểm thuyết minh';
        document.getElementById('submitBtn').innerHTML='<i class="bi bi-check-lg"></i> Lưu';
        _selectedFiles = new DataTransfer();
        document.getElementById('imageFileInput').files = _selectedFiles.files;
        document.getElementById('previewGrid').innerHTML = '';
        document.getElementById('currentImagesWrap').style.display = 'none';
        
        document.querySelectorAll('input[name="TourIds"]').forEach(cb => { cb.checked=false; cb.disabled=false; cb.dataset.origStatus=''; });
        document.querySelectorAll('.tour-status-badge').forEach(b => { b.style.display='none'; });

        showTab('tab-basic','btnTabBasic');
        document.getElementById('poiModal').style.display='flex';
        setTimeout(()=>initPickMap(10.7769,106.7009,5),150);
    }
    function closeModal(){document.getElementById('poiModal').style.display='none';}

    async function editPoi(id,name,desc,lat,lng,radius,ownerId,imageUrl){
        isPoiDirty = false;
        document.getElementById('fId').value=id;
        document.getElementById('fName').value=name;
        document.getElementById('fDescription').value=desc;
        document.getElementById('fLat').value=lat;
        document.getElementById('fLng').value=lng;
        document.getElementById('fRadius').value=radius;
        document.getElementById('fOwnerId').value=(ownerId===null||ownerId==='null')?'':ownerId;
        document.getElementById('modalTitle').textContent='Chỉnh sửa: '+name;
        document.getElementById('submitBtn').innerHTML='<i class="bi bi-check-lg"></i> Cập nhật';

        const poi = POIS.find(p => p.id === id);
        const imgGrid = document.getElementById('currentImagesGrid');
        if (poi && poi.images && poi.images.length > 0) {
            document.getElementById('currentImagesWrap').style.display = 'block';
            let html = '';
            if (poi.status === 'REJECTED') {
                html += `<div style="grid-column: 1/-1; background: #fee2e2; color: #991b1b; padding: 8px; border-radius: 6px; font-size: 12px; margin-bottom: 8px;">
                            <i class="bi bi-exclamation-triangle"></i> Cảnh báo: Ảnh dưới đây đã bị từ chối. Vui lòng thêm ảnh hợp lệ để gửi duyệt lại.
                         </div>`;
            }
            poi.images.forEach(img => {
                const absUrl = toAbsUrl(img.imageUrl);
                const imgStyle = poi.status === 'REJECTED' ? 'filter: grayscale(1) opacity(0.5);' : '';
                html += `<div style="position:relative;width:80px;height:80px" id="imgwrap-${img.id}">
                            <img src="${absUrl}" style="width:80px;height:80px;object-fit:cover;border-radius:6px;border:2px solid ${img.isThumbnail ? 'var(--accent)' : '#e5e7eb'}; ${imgStyle}" />
                            <button type="button" onclick="event.preventDefault();deleteImage(${img.id})"
                                style="position:absolute;top:-6px;right:-6px;width:20px;height:20px;border-radius:50%;background:#dc2626;color:#fff;border:none;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center">✕</button>
                        </div>`;
            });
            imgGrid.innerHTML = html;
        } else {
            document.getElementById('currentImagesWrap').style.display = 'none';
        }

        document.querySelectorAll('input[name="TourIds"]').forEach(cb => { cb.checked=false; cb.disabled=false; cb.dataset.origStatus=''; });
        try {
            const [pRes, aRes, rRes, rmRes] = await Promise.all([
                fetch(`${API_BASE}/api/tours/pois/all-pending`), fetch(`${API_BASE}/api/tours/pois/all-approved`),
                fetch(`${API_BASE}/api/tours/pois/all-rejected`), fetch(`${API_BASE}/api/tours/pois/all-remove-pending`)
            ]);
            const pend=pRes.ok?await pRes.json():[], appr=aRes.ok?await aRes.json():[], rej=rRes.ok?await rRes.json():[], rem=rmRes.ok?await rmRes.json():[];
            const sMap = {};
            appr.filter(x=>x.poiId===id).forEach(x=>sMap[x.tourId]={s:'APPROVED'});
            pend.filter(x=>x.poiId===id).forEach(x=>sMap[x.tourId]={s:'PENDING'});
            rej.filter(x=>x.poiId===id).forEach(x=>sMap[x.tourId]={s:'REJECTED'});
            rem.filter(x=>x.poiId===id).forEach(x=>sMap[x.tourId]={s:'REMOVE_PENDING'});

            document.querySelectorAll('input[name="TourIds"]').forEach(cb => {
                const info = sMap[parseInt(cb.value)];
                if(!info) return;
                cb.dataset.origStatus = info.s;
                if(info.s==='APPROVED'){ cb.checked=true; }
                else if(info.s==='PENDING' || info.s==='REMOVE_PENDING'){ cb.indeterminate=true; if(info.s==='REMOVE_PENDING') cb.disabled=true; }
            });
        } catch (e) {}

        _selectedFiles = new DataTransfer();
        document.getElementById('imageFileInput').files = _selectedFiles.files;
        document.getElementById('previewGrid').innerHTML = '';
        
        showTab('tab-basic','btnTabBasic');
        document.getElementById('poiModal').style.display='flex';
        setTimeout(()=>initPickMap(parseFloat(lat),parseFloat(lng),parseInt(radius)),150);
    }

    function showTab(tabId,btnId){
        document.querySelectorAll('.tab-pane').forEach(p=>p.style.display='none');
        document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
        document.getElementById(tabId).style.display='block'; document.getElementById(btnId).classList.add('active');
        if(tabId==='tab-loc')setTimeout(()=>{if(_pm)_pm.invalidateSize();},80);
    }

    function confirmDelete(id,name){document.getElementById('fDelId').value=id;document.getElementById('delName').textContent=name;document.getElementById('deleteModal').style.display='flex';}
    function closeDelete(){document.getElementById('deleteModal').style.display='none';}

    let _selectedFiles = new DataTransfer();
    function previewImages(input) {
        for (const file of input.files) {
            if (_selectedFiles.items.length >= 5) { alert('Tối đa 5 ảnh.'); break; }
            if (file.size > 5*1024*1024) { alert(file.name + ': quá 5MB'); continue; }
            _selectedFiles.items.add(file);
        }
        document.getElementById('imageFileInput').files = _selectedFiles.files;
        renderPreviewGrid();
    }
    function renderPreviewGrid() {
        const grid = document.getElementById('previewGrid'); grid.innerHTML = '';
        Array.from(_selectedFiles.files).forEach((file, i) => {
            const reader = new FileReader();
            reader.onload = e => {
                const wrap = document.createElement('div');
                wrap.style.cssText = 'position:relative;width:80px;height:80px;flex-shrink:0';
                wrap.innerHTML = `<img src="${e.target.result}" style="width:80px;height:80px;object-fit:cover;border-radius:6px;border:1px solid #e5e7eb" />
                                  <button type="button" onclick="removeFile(${i})" style="position:absolute;top:-6px;right:-6px;width:20px;height:20px;border-radius:50%;background:#dc2626;color:#fff;border:none;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center">✕</button>`;
                grid.appendChild(wrap);
            };
            reader.readAsDataURL(file);
        });
    }
    function removeFile(index) {
        const dt = new DataTransfer();
        Array.from(_selectedFiles.files).forEach((f, i) => { if (i !== index) dt.items.add(f); });
        _selectedFiles = dt; document.getElementById('imageFileInput').files = _selectedFiles.files; renderPreviewGrid();
    }

    // NATIVE SUBMIT FIX CHỐNG GỬI KÉP POI
    document.getElementById('poiForm').addEventListener('submit', async function(e) {
        e.preventDefault(); 
        const poiId = parseInt(document.getElementById('fId').value);
        
        const submitBtn = document.getElementById('submitBtn');
        submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang xử lý...';
        submitBtn.disabled = true;

        if (poiId > 0) {
            const changes = [];
            document.querySelectorAll('input[name="TourIds"]').forEach(cb => {
                if (cb.disabled) return; 
                const orig = cb.dataset.origStatus || '';
                if (orig === '' && cb.checked) changes.push({ tourId: cb.value, action: 'add' });
                else if (orig === 'APPROVED' && !cb.checked) changes.push({ tourId: cb.value, action: 'remove' });
                else if (orig === 'REJECTED' && cb.checked) changes.push({ tourId: cb.value, action: 'add' });
                else if (orig === 'PENDING' && !cb.checked) changes.push({ tourId: cb.value, action: 'cancel' });
            });
            
            let tourChanged = changes.length > 0;
            
            const apiCalls = changes.map(async ({ tourId, action }) => {
                try {
                    if (action === 'add') await fetch(`${API_BASE}/api/tours/${tourId}/pois`, { method: 'POST', headers: ROLE_HDR, body: JSON.stringify({ poiId }) });
                    else if (action === 'remove') {
                        if (IS_ADMIN) await fetch(`${API_BASE}/api/tours/${tourId}/pois/${poiId}`, { method: 'DELETE', headers: ROLE_HDR });
                        else await fetch(`${API_BASE}/api/tours/${tourId}/pois/${poiId}/request-remove`, { method: 'PUT', headers: ROLE_HDR });
                    }
                    else if (action === 'cancel') await fetch(`${API_BASE}/api/tours/${tourId}/pois/${poiId}`, { method: 'DELETE', headers: ROLE_HDR });
                } catch (err) {}
            });
            await Promise.all(apiCalls);

            // Chỉ load lại trang nếu POI KHÔNG hề bị sửa chữ/ảnh
            if (!isPoiDirty) {
                if (tourChanged) {
                    alert('Đã gửi yêu cầu tham gia/rời Tour thành công!');
                }
                window.location.reload();
                return;
            }
        }

        // Nếu isPoiDirty = true, cho phép Browser Native Submit để gửi ảnh + text
        document.querySelectorAll('input[name="TourIds"]').forEach(cb => cb.removeAttribute('name'));
        HTMLFormElement.prototype.submit.call(this); 
    });
</script>