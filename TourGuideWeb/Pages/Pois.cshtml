            /* ── TTS Preview ──────────────────────────────────────── */
    if (window.speechSynthesis) {
        window.speechSynthesis.getVoices();
        window.speechSynthesis.onvoiceschanged = function () {
            window._ttsVoices = window.speechSynthesis.getVoices();
        };
    }

    function previewTTS() {
        var text = document.getElementById('fTtsScript').value.trim();
        var lang = document.getElementById('fLanguage').value;
        if (!text) { alert('Chưa nhập script TTS'); return; }
        if (!window.speechSynthesis) { alert('Trình duyệt không hỗ trợ TTS'); return; }
        window.speechSynthesis.cancel();
        var utter = new SpeechSynthesisUtterance(text);
        utter.lang = lang;
        function doSpeak() {
            var voices = window.speechSynthesis.getVoices();
            var matched = voices.find(function(v) { return v.lang === lang; })
                       || voices.find(function(v) { return v.lang.startsWith(lang.split('-')[0]); });
            if (matched) utter.voice = matched;
            window.speechSynthesis.speak(utter);
        }
        if (window.speechSynthesis.getVoices().length > 0) doSpeak();
        else window.speechSynthesis.onvoiceschanged = function() { doSpeak(); };
    }

    /* ── Audio URL preview ────────────────────────────────── */
    document.getElementById('fAudioUrl').addEventListener('input', function() {
        var url = this.value.trim();
        var wrap = document.getElementById('audioPreviewWrap');
        var audio = document.getElementById('audioPreview');
        if (url) {
            audio.src = url;
            wrap.style.display = 'block';
        } else {
            wrap.style.display = 'none';
            audio.src = '';
        }
    });
    });
