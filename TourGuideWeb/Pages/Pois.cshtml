@page
@model GPSGuide.Web.Pages.PoisModel
@{

    ViewData["Title"] = "Điểm thuyết minh (POI)";
    ViewData["Active"] = "pois";

    ViewData["Title"] = "Điểm thuyết minh (POI)"; ViewData["Active"] = "pois";
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> @Model.Error</div>
}

<div class="page-header">
    <div>
        <h2>Điểm thuyết minh</h2>
        <div class="sub">Quản lý toàn bộ POI — tọa độ, bán kính, nội dung TTS</div>
    </div>
    <button class="btn btn-primary" onclick="openModal()">
        <i class="bi bi-plus-lg"></i> Thêm POI
    </button>
</div>

<div class="card">
    <table class="tg-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên điểm</th>
                <th>Mô tả</th>
                <th>Tọa độ</th>
                <th>Bán kính</th>
                <th>Chủ sở hữu</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Pois)
            {
                var lat = p.Latitude.ToString("F6", System.Globalization.CultureInfo.InvariantCulture);
                var lng = p.Longitude.ToString("F6", System.Globalization.CultureInfo.InvariantCulture);
                var nJs = p.Name.Replace("\\", "\\\\").Replace("'", "\\'");
                var dJs = (p.Description ?? "").Replace("\\", "\\\\").Replace("'", "\\'");
                var oArg = p.OwnerId.HasValue ? p.OwnerId.Value.ToString() : "null";

                <tr>
                    <td class="text-muted">#@p.Id</td>
                    <td style="font-weight:600">@p.Name</td>
                    <td class="text-muted"
                        style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                        title="@p.Description">
                        @p.Description
                    </td>
                    <td>
                        <a class="coord-link"
                           href="https://maps.google.com/?q=@lat,@lng" target="_blank">
                            @p.Latitude.ToString("F4"), @p.Longitude.ToString("F4")
                        </a>
                    </td>
                    <td><span class="badge badge-blue">@p.Radius m</span></td>
                    <td class="text-muted">@(p.OwnerId.HasValue ? "#" + p.OwnerId.Value : "—")</td>
                    <td>
                        <div class="action-group">
                            <button class="btn btn-ghost btn-sm btn-icon" title="Bản đồ"
                                    onclick="openPreview(@lat,@lng,'@nJs',@p.Radius)">
                                <i class="bi bi-map"></i>
                            </button>
                            <button class="btn btn-ghost btn-sm btn-icon" title="Sửa"
                                    onclick="editPoi(@p.Id,'@nJs','@dJs',@lat,@lng,@p.Radius,@oArg)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-ghost btn-sm btn-icon text-danger" title="Xoá"
                                    onclick="confirmDelete(@p.Id,'@nJs')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Pois.Any())
            {
                <tr>
                    <td colspan="7" class="empty-state">
                        Chưa có điểm thuyết minh nào.
                        <a href="#" onclick="openModal();return false;">Thêm POI đầu tiên</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ===== MODAL TẠO / SỬA ===== -->
<div id="poiModal" class="modal-backdrop" style="display:none" onclick="handleBackdropClick(event)">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4 id="modalTitle">Thêm điểm thuyết minh</h4>
            <button class="btn btn-ghost btn-icon" onclick="closeModal()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form id="poiForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="fId" value="0" />
            <div class="modal-body">
                <!-- Tabs -->
                <div class="tab-nav">
                    <button type="button" class="tab-btn active" id="btnTabBasic"
                            onclick="showTab('tab-basic','btnTabBasic')">
                        <i class="bi bi-info-circle"></i> Thông tin
                    </button>
                    <button type="button" class="tab-btn" id="btnTabLoc"
                            onclick="showTab('tab-loc','btnTabLoc')">
                        <i class="bi bi-geo-alt"></i> Vị trí
                    </button>

                    <button type="button" class="tab-btn" id="btnTabAudio"
                            onclick="showTab('tab-audio','btnTabAudio')">
                        <i class="bi bi-volume-up"></i> Audio / TTS
                    </button>


                </div>

                <!-- Tab: Thông tin -->
                <div id="tab-basic" class="tab-pane">
                    <div class="form-group">
                        <label class="form-label">Tên điểm <span class="req">*</span></label>
                        <input type="text" name="Name" id="fName" class="form-control"
                               placeholder="VD: Phở Hòa Pasteur" required maxlength="255" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Mô tả</label>
                        <textarea name="Description" id="fDescription" class="form-control"

                                  rows="3"
                                  placeholder="Mô tả ngắn về điểm tham quan..."></textarea>

                                  rows="3" placeholder="Mô tả ngắn về điểm tham quan..."></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Bán kính (m) <span class="req">*</span></label>
                            <input type="number" name="Radius" id="fRadius" class="form-control"
                                   min="5" max="5000" value="80" required />
                            <div class="form-hint">Vùng kích hoạt thuyết minh</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Owner ID</label>
                            <input type="number" name="OwnerId" id="fOwnerId" class="form-control"
                                   placeholder="Để trống = không có" />
                        </div>
                    </div>
                </div>

                <!-- Tab: Vị trí -->
                <div id="tab-loc" class="tab-pane" style="display:none">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Vĩ độ <span class="req">*</span></label>
                            <input type="number" name="Latitude" id="fLat" class="form-control"
                                   step="0.000001" min="-90" max="90"
                                   placeholder="VD: 10.7812" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Kinh độ <span class="req">*</span></label>
                            <input type="number" name="Longitude" id="fLng" class="form-control"
                                   step="0.000001" min="-180" max="180"
                                   placeholder="VD: 106.6880" required />
                        </div>
                    </div>
                    <div class="map-toolbar">
                        <button type="button" class="btn btn-sm btn-outline"
                                onclick="getMyLocation()">
                            <i class="bi bi-crosshair"></i> Vị trí hiện tại
                        </button>
                        <span class="form-hint" style="margin:0">
                            Hoặc click vào bản đồ để chọn tọa độ
                        </span>

                        <span class="form-hint" style="margin:0">Hoặc click vào bản đồ để chọn tọa độ</span>

                    </div>
                    <div id="pickMap"
                         style="height:300px;border-radius:8px;border:1px solid #ddd;
                                margin-top:10px;overflow:hidden"></div>
                    <div class="form-hint" style="margin-top:6px">
                        <i class="bi bi-info-circle"></i>
                        Kéo marker để điều chỉnh vị trí. Vòng xanh = bán kính kích hoạt.
                    </div>
                </div>
                <!-- Tab: Audio / TTS -->
                <div id="tab-audio" class="tab-pane" style="display:none">
                    <div class="form-group">
                        <label class="form-label">Ngôn ngữ thuyết minh</label>
                        <select name="Language" id="fLanguage" class="form-control">
                            <option value="vi-VN">🇻🇳 Tiếng Việt</option>
                            <option value="en-US">🇺🇸 English</option>
                            <option value="zh-CN">🇨🇳 中文</option>
                            <option value="ko-KR">🇰🇷 한국어</option>
                            <option value="ja-JP">🇯🇵 日本語</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Script thuyết minh (TTS)</label>
                        <textarea name="TtsScript" id="fTtsScript" class="form-control" rows="4"
                                  placeholder="Nhập nội dung sẽ được đọc khi khách đến gần điểm này...
VD: Chào mừng bạn đến Nhà thờ Đức Bà, công trình được xây dựng từ năm 1863..."></textarea>
                        <div class="form-hint">
                            <i class="bi bi-info-circle"></i>
                            App mobile sẽ đọc nội dung này bằng TTS khi người dùng vào vùng bán kính.
                        </div>
                    </div>
                    <div style="display:flex;gap:8px;margin-bottom:1rem">
                        <button type="button" class="btn btn-outline btn-sm" onclick="previewTTS()">
                            <i class="bi bi-play-circle"></i> Nghe thử
                        </button>
                        <button type="button" class="btn btn-ghost btn-sm"
                                onclick="window.speechSynthesis && window.speechSynthesis.cancel()">
                            <i class="bi bi-stop-circle"></i> Dừng
                        </button>
                    </div>
                    <div class="form-group">
                        <label class="form-label">URL file Audio (MP3)</label>
                        <input type="text" name="AudioUrl" id="fAudioUrl" class="form-control"
                               placeholder="https://... hoặc để trống nếu dùng TTS" />
                        <div class="form-hint">
                            Nếu có file audio thu sẵn, nhập URL vào đây. App sẽ ưu tiên phát file audio
                            thay vì TTS.
                        </div>
                    </div>
                    <div id="audioPreviewWrap" style="display:none;margin-top:.5rem">
                        <audio id="audioPreview" controls style="width:100%;border-radius:6px"></audio>
                    </div>
                </div>
            </div>

            </div><!-- /modal-body -->
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="bi bi-check-lg"></i> Lưu
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ===== MODAL XEM BẢN ĐỒ ===== -->
<div id="previewModal" class="modal-backdrop" style="display:none" onclick="closePreview()">
    <div class="modal-box modal-lg" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4 id="previewTitle">Xem bản đồ</h4>
            <button class="btn btn-ghost btn-icon" onclick="closePreview()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div id="previewMapDiv"
             style="height:420px;border-radius:0 0 12px 12px;overflow:hidden"></div>
    </div>
</div>

<!-- ===== MODAL XOÁ ===== -->
<div id="deleteModal" class="modal-backdrop" style="display:none" onclick="closeDelete()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4>Xác nhận xoá</h4>
            <button class="btn btn-ghost btn-icon" onclick="closeDelete()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="modal-body">
            <p>Bạn có chắc muốn xoá <strong id="delName"></strong>?</p>
            <p class="text-muted" style="font-size:13px">Thao tác này không thể hoàn tác.</p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeDelete()">Huỷ</button>
            <form method="post" asp-page-handler="Delete" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeleteId" id="fDelId" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Xoá
                </button>
            </form>
        </div>
    </div>
</div>

