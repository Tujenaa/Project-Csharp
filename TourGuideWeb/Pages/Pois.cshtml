<script>

    /* ── TTS Engine ───────────────────────────────────────────── */
    if (window.speechSynthesis) {
        window.speechSynthesis.getVoices();
        window.speechSynthesis.onvoiceschanged = function () {
            window._ttsVoices = window.speechSynthesis.getVoices();
        };
    }

    window.speakText = function (text, lang) {
        if (!window.speechSynthesis) { alert('Trình duyệt không hỗ trợ TTS'); return; }
        window.speechSynthesis.cancel();
        var utter = new SpeechSynthesisUtterance(text);
        utter.lang = lang || 'vi-VN';

        function doSpeak() {
            var voices = window.speechSynthesis.getVoices();
            // Tìm giọng khớp chính xác trước, sau đó khớp theo prefix (vd: "vi")
            var matched = voices.find(function (v) { return v.lang === utter.lang; })
                       || voices.find(function (v) {
                              return v.lang.startsWith(utter.lang.split('-')[0]);
                          });
            if (matched) utter.voice = matched;
            window.speechSynthesis.speak(utter);
        }

        if (window.speechSynthesis.getVoices().length > 0) {
            doSpeak();
        } else {
            window.speechSynthesis.onvoiceschanged = function () { doSpeak(); };
        }
    };

    /* ── Pick map ─────────────────────────────────────────────── */

    /* ── Pick map ─────────────────────────────── */
    var _pm = null, _pmk = null, _pmc = null;

    function initPickMap(lat, lng, radius) {
        if (_pm) { _pm.remove(); _pm = null; _pmk = null; _pmc = null; }
        _pm = L.map('pickMap').setView([lat, lng], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors', maxZoom: 19
        }).addTo(_pm);
        placeMarker(lat, lng, radius);
        _pm.on('click', function (e) {
            placeMarker(e.latlng.lat, e.latlng.lng,
                parseFloat(document.getElementById('fRadius').value) || 80);
        });
        document.getElementById('fRadius').addEventListener('input', function () {

        _pm.on('click', function(e) {
            placeMarker(e.latlng.lat, e.latlng.lng,
                parseFloat(document.getElementById('fRadius').value) || 80);
        });
        document.getElementById('fRadius').addEventListener('input', function() {

            if (_pmk) {
                var ll = _pmk.getLatLng();
                drawCircle(ll.lat, ll.lng, parseFloat(this.value) || 80);
            }
        });
    }

    function placeMarker(lat, lng, radius) {
        if (_pmk) _pm.removeLayer(_pmk);
        drawCircle(lat, lng, radius);
        _pmk = L.marker([lat, lng], { draggable: true }).addTo(_pm);
        document.getElementById('fLat').value = lat.toFixed(6);
        document.getElementById('fLng').value = lng.toFixed(6);
        _pmk.on('dragend', function (e) {
            var p = e.target.getLatLng();
            document.getElementById('fLat').value = p.lat.toFixed(6);
            document.getElementById('fLng').value = p.lng.toFixed(6);
            drawCircle(p.lat, p.lng,
                parseFloat(document.getElementById('fRadius').value) || 80);

        _pmk.on('dragend', function(e) {
            var p = e.target.getLatLng();
            document.getElementById('fLat').value = p.lat.toFixed(6);
            document.getElementById('fLng').value = p.lng.toFixed(6);
            drawCircle(p.lat, p.lng, parseFloat(document.getElementById('fRadius').value) || 80);
        });
    }

    function drawCircle(lat, lng, radius) {
        if (_pmc) _pm.removeLayer(_pmc);
        _pmc = L.circle([lat, lng], {
            radius: radius, color: '#2563eb',
            fillColor: '#93c5fd', fillOpacity: 0.25

            radius: radius, color: '#2563eb', fillColor: '#93c5fd', fillOpacity: 0.25
        }).addTo(_pm);
    }

    function getMyLocation() {
        if (!navigator.geolocation) { alert('Trình duyệt không hỗ trợ định vị.'); return; }
        navigator.geolocation.getCurrentPosition(function (pos) {

        navigator.geolocation.getCurrentPosition(function(pos) {
            var r = parseFloat(document.getElementById('fRadius').value) || 80;
            placeMarker(pos.coords.latitude, pos.coords.longitude, r);
            _pm.setView([pos.coords.latitude, pos.coords.longitude], 16);
            showTab('tab-loc', 'btnTabLoc');
        }, function (err) { alert('Không lấy được vị trí: ' + err.message); });
    }

