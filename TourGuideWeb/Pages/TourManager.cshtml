@page
@model GPSGuide.Web.Pages.TourManagerModel
@{
    ViewData["Title"] = "Quản lý Tour"; ViewData["Active"] = "tours";
}

@section Styles {
    <link rel="stylesheet" href="~/css/tours.css" asp-append-version="true" />
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i> @Model.Error</div>
}

<div class="page-header">
    <div><h2>Quản lý Tour</h2></div>
    <button class="btn btn-primary" onclick="openModal()">
        <i class="bi bi-plus-lg"></i> Thêm Tour
    </button>
</div>

<div class="card">
    @if (!Model.Tours.Any())
    {
        <div style="padding:40px;text-align:center;color:#9ca3af">
            <i class="bi bi-map" style="font-size:40px;display:block;margin-bottom:12px"></i>
            Chưa có tour nào. <a href="#" onclick="openModal();return false">Thêm tour đầu tiên</a>
        </div>
    }
    else
    {
        <table class="tg-table">
            <thead>
                <tr>
                    <th>Tên tour</th>
                    <th>Trạng thái</th>
                    <th style="text-align:center">Số điểm</th>
                    <th>Điểm trong tour</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Tours)
                {
                    <tr>
                        <td class="tour-name">@t.Name</td>
                        <td>
                            @if (t.Status == "PUBLISHED")
                            {
                                <span class="tour-status-badge published">✅ Công khai</span>
                            }
                            else if (t.Status == "DRAFT")
                            {
                                <span class="tour-status-badge draft">📝 Nháp</span>
                            }
                            else
                            {
                                <span class="tour-status-badge archived">🗄️ Lưu trữ</span>
                            }
                        </td>
                        <td class="tour-poi-count">@t.POIs.Count</td>
                        <td>
                            @if (!t.POIs.Any())
                            {
                                <span class="tour-poi-empty">Chưa có điểm nào</span>
                            }
                            else
                            {
                                <ul class="tour-poi-list">
                                    @{
                                        int idx = 1;
                                    }
                                    @foreach (var p in t.POIs)
                                    {
                                        <li>
                                            <span class="poi-num">@idx</span>
                                            <span class="poi-label" title="@p.Name">@p.Name</span>
                                        </li>
                                        idx++;
                                    }
                                </ul>
                            }
                        </td>
                        <td>
                            <div class="action-group">
                                <button class="btn btn-ghost btn-sm btn-icon" title="Sửa"
                                        onclick='editTour(@t.Id, @Html.Raw(System.Text.Json.JsonSerializer.Serialize(t.Name)), @Html.Raw(System.Text.Json.JsonSerializer.Serialize(t.Description ?? "")), "@t.Status", [@string.Join(",", t.POIs.Select(p => p.Id))])'>
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-ghost btn-sm btn-icon text-danger" title="Xóa"
                                        onclick="confirmDelete(@t.Id, '@t.Name')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- ===== MODAL THÊM / SỬA ===== -->
<div id="tourModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)closeModal()">
    <div class="modal-box modal-lg" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4 id="modalTitle">Thêm Tour</h4>
            <button class="btn btn-ghost btn-icon" onclick="closeModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="fId" value="0" />
            <div class="modal-body">

                <!-- TAB NAV -->
                <div class="tab-nav">
                    <button type="button" class="tab-btn active" id="btnTabInfo" onclick="showTab('tab-info','btnTabInfo')">
                        <i class="bi bi-info-circle"></i> Thông tin
                    </button>
                    @if (Model.AllPois.Any())
                    {
                        <button type="button" class="tab-btn" id="btnTabPois" onclick="showTab('tab-pois','btnTabPois')">
                            <i class="bi bi-geo-alt"></i> Điểm thuyết minh
                            <span id="tabPoiBadge" style="display:none;margin-left:4px;background:var(--accent);color:#fff;font-size:10px;padding:1px 7px;border-radius:20px;font-weight:700;font-family:var(--mono)"></span>
                        </button>
                    }
                </div>

                <!-- TAB: THÔNG TIN -->
                <div id="tab-info" class="tab-pane">
                    <div class="form-group">
                        <label class="form-label">Tên tour <span class="req">*</span></label>
                        <input type="text" name="Name" id="fName" class="form-control" required maxlength="255"
                               placeholder="VD: Khám phá ẩm thực Vĩnh Khánh" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Mô tả</label>
                        <textarea name="Description" id="fDesc" class="form-control" rows="3"
                                  placeholder="Mô tả ngắn về tour..."></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Trạng thái</label>
                        <select name="Status" id="fStatus" class="form-control">
                            <option value="PUBLISHED">✅ Công khai</option>
                            <option value="DRAFT">📝 Nháp</option>
                            <option value="ARCHIVED">🗄️ Lưu trữ</option>
                        </select>
                    </div>
                </div>

                <!-- TAB: ĐIỂM THUYẾT MINH -->
                @if (Model.AllPois.Any())
                {
                    <div id="tab-pois" class="tab-pane" style="display:none">

                        <div class="tour-poi-picker">
                            <!-- Thanh search -->
                            <div class="tour-poi-searchbar">
                                <i class="bi bi-search"></i>
                                <input type="text" id="poiSearch"
                                       placeholder="Tìm điểm thuyết minh..."
                                       oninput="filterPoiList(this.value)"
                                       autocomplete="off" />
                                <button type="button" class="clear-btn" onclick="clearSearch()" title="Xóa tìm kiếm">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>

                            <!-- Checklist -->
                            <div class="tour-poi-checklist" id="poiCheckList">
                                @foreach (var p in Model.AllPois)
                                {
                                    <label id="poi-item-@p.Id" class="tour-poi-item" onclick="toggleItem(this)">
                                        <input type="checkbox" name="PoiIds" value="@p.Id" class="poi-check"
                                               onchange="updateCount()" onclick="event.stopPropagation()" />
                                        <span class="poi-item-name" title="@p.Name">@p.Name</span>
                                        <i class="bi bi-check-circle-fill check-icon" data-pid="@p.Id"></i>
                                    </label>
                                }
                            </div>
                        </div>

                        <!-- Footer -->
                        <div class="tour-poi-footer">
                            <span class="count-text">Đã chọn: <strong id="selectedCount">0</strong> điểm</span>
                            <button type="button" class="clear-all-btn" onclick="clearAllPois()">Bỏ chọn tất cả</button>
                        </div>

                        <!-- Preview -->
                        <div class="tour-poi-preview" id="selectedPoiPreview">
                            <div class="tour-poi-preview-title"><i class="bi bi-list-ol"></i> Danh sách đã chọn</div>
                            <ol id="selectedPoiList"></ol>
                        </div>

                    </div>
                }

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="bi bi-check-lg"></i> Lưu
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ===== MODAL XÓA ===== -->
<div id="deleteModal" class="modal-backdrop" style="display:none" onclick="closeDelete()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4>Xác nhận xóa</h4>
            <button class="btn btn-ghost btn-icon" onclick="closeDelete()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="modal-body">
            <p>Xóa tour <strong id="delName"></strong>?</p>
            <p style="font-size:13px;color:#6b7280;margin-top:6px">Các điểm thuyết minh không bị xóa, chỉ xóa tour này.</p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeDelete()">Huỷ</button>
            <form method="post" asp-page-handler="Delete" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeleteId" id="fDelId" />
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Xóa</button>
            </form>
        </div>
    </div>
</div>

<script>
    // ── Tab switching (scoped chỉ trong #tourModal) ──────────────────────
    function showTab(tabId, btnId) {
        document.querySelectorAll('#tourModal .tab-pane').forEach(p => p.style.display = 'none');
        document.querySelectorAll('#tourModal .tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(tabId).style.display = 'block';
        if (btnId) document.getElementById(btnId).classList.add('active');
    }

    // ── Click label → toggle checkbox bên trong ─────────────────────────
    function toggleItem(label) {
        const cb = label.querySelector('input[type=checkbox]');
        if (!cb) return;
        cb.checked = !cb.checked;
        updateCount();
    }

    // ── Đồng bộ class is-checked theo trạng thái checkbox ───────────────
    function syncItemStyle() {
        document.querySelectorAll('.tour-poi-item').forEach(label => {
            const cb = label.querySelector('input[type=checkbox]');
            label.classList.toggle('is-checked', !!(cb && cb.checked));
        });
    }

    // ── Map id → tên POI để dùng trong preview ──────────────────────────
    const POI_NAMES = {
        @foreach (var p in Model.AllPois)
        {
                @Html.Raw($"{p.Id}: {System.Text.Json.JsonSerializer.Serialize(p.Name)},")
        }
    };

    // ── Cập nhật badge + counter + preview ──────────────────────────────
    function updateCount() {
        syncItemStyle();
        const checked = [...document.querySelectorAll('.poi-check:checked')];
        const n = checked.length;

        const badge = document.getElementById('tabPoiBadge');
        if (badge) { badge.textContent = n; badge.style.display = n > 0 ? 'inline' : 'none'; }

        document.getElementById('selectedCount').textContent = n;

        const preview = document.getElementById('selectedPoiPreview');
        const ol      = document.getElementById('selectedPoiList');
        if (n > 0) {
            preview.classList.add('visible');
            ol.innerHTML = checked.map(cb => {
                const name = POI_NAMES[cb.value] || ('POI #' + cb.value);
                return `<li>${name}</li>`;
            }).join('');
        } else {
            preview.classList.remove('visible');
            ol.innerHTML = '';
        }
    }

    // ── Lọc theo tên ─────────────────────────────────────────────────────
    function filterPoiList(q) {
        const nq = q.trim().toLowerCase();
        document.querySelectorAll('.tour-poi-item').forEach(el => {
            const name = el.querySelector('.poi-item-name').textContent.toLowerCase();
            el.style.display = (!nq || name.includes(nq)) ? '' : 'none';
        });
    }

    function clearSearch() {
        document.getElementById('poiSearch').value = '';
        filterPoiList('');
    }

    function clearAllPois() {
        document.querySelectorAll('.poi-check').forEach(cb => cb.checked = false);
        updateCount();
    }

    // ── Mở modal THÊM ────────────────────────────────────────────────────
    function openModal() {
        document.getElementById('fId').value     = '0';
        document.getElementById('fName').value   = '';
        document.getElementById('fDesc').value   = '';
        document.getElementById('fStatus').value = 'PUBLISHED';
        document.querySelectorAll('.poi-check').forEach(cb => cb.checked = false);
        clearSearch();
        updateCount();
        document.getElementById('modalTitle').textContent = 'Thêm Tour';
        document.getElementById('submitBtn').innerHTML    = '<i class="bi bi-check-lg"></i> Lưu';
        showTab('tab-info', 'btnTabInfo');
        document.getElementById('tourModal').style.display = 'flex';
    }

    // ── Mở modal SỬA ─────────────────────────────────────────────────────
    function editTour(id, name, desc, status, poiIds) {
        document.getElementById('fId').value     = id;
        document.getElementById('fName').value   = name;
        document.getElementById('fDesc').value   = desc;
        document.getElementById('fStatus').value = status;
        clearSearch();
        document.querySelectorAll('.poi-check').forEach(cb => {
            cb.checked = poiIds.includes(parseInt(cb.value));
        });
        updateCount();
        document.getElementById('modalTitle').textContent = 'Sửa Tour: ' + name;
        document.getElementById('submitBtn').innerHTML    = '<i class="bi bi-check-lg"></i> Cập nhật';
        showTab('tab-info', 'btnTabInfo');
        document.getElementById('tourModal').style.display = 'flex';
    }

    function closeModal()  { document.getElementById('tourModal').style.display  = 'none'; }
    function closeDelete() { document.getElementById('deleteModal').style.display = 'none'; }

    function confirmDelete(id, name) {
        document.getElementById('fDelId').value   = id;
        document.getElementById('delName').textContent = name;
        document.getElementById('deleteModal').style.display = 'flex';
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { closeModal(); closeDelete(); }
    });
</script>
