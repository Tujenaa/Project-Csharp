@page "/Users/Detail/{id:int}"
@model GPSGuide.Web.Pages.UserDetailModel
@{
    ViewData["Title"] = "Chi tiết người dùng"; ViewData["Active"] = "users";
}

@section Styles {
    <link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />
}

<div class="page-header">
    <div>
        <h2>Chi tiết người dùng</h2>
        <div class="sub">ID #@Model.SelectedUser?.Id</div>
    </div>
    <a href="/Users" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.SelectedUser == null)
{
    <div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i> Không tìm thấy người dùng.</div>
}
else
{
    <div style="display:grid;grid-template-columns:280px 1fr;gap:24px;align-items:start">

        <!-- Avatar card -->
        <div class="profile-avatar-card">
            <div class="profile-avatar">@Model.SelectedUser.Username.Substring(0, 1).ToUpper()</div>
            <div class="profile-uname">@Model.SelectedUser.Username</div>
            @if (Model.SelectedUser.Role == "ADMIN")
            {
                <span class="badge badge-red" style="font-size:12px;padding:4px 12px">ADMIN</span>
            }
            else if (Model.SelectedUser.Role == "OWNER")
            {
                <span class="badge badge-blue" style="font-size:12px;padding:4px 12px">OWNER</span>
            }
            else
            {
                <span class="badge badge-green" style="font-size:12px;padding:4px 12px">CUSTOMER</span>
            }
            @if (!string.IsNullOrEmpty(Model.SelectedUser.Name))
            {
                <div class="profile-displayname">@Model.SelectedUser.Name</div>
            }
            @if (!string.IsNullOrEmpty(Model.SelectedUser.Email))
            {
                <div class="profile-meta"><i class="bi bi-envelope"></i> @Model.SelectedUser.Email</div>
            }
            @if (!string.IsNullOrEmpty(Model.SelectedUser.Phone))
            {
                <div class="profile-meta"><i class="bi bi-telephone"></i> @Model.SelectedUser.Phone</div>
            }
        </div>

        <!-- Thông tin chi tiết -->
        <div>
            <div class="profile-section">
                <div class="profile-section-title"><i class="bi bi-shield-lock"></i> Tài khoản</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                    <div>
                        <div class="form-label">ID</div>
                        <div style="font-size:18px;font-weight:800;color:#111827;font-family:var(--mono)">#@Model.SelectedUser.Id</div>
                    </div>
                    <div>
                        <div class="form-label">Vai trò</div>
                        <div style="font-size:15px;font-weight:700;color:#5b21b6">@Model.SelectedUser.Role</div>
                    </div>
                    <div>
                        <div class="form-label">Tên đăng nhập</div>
                        <div style="font-size:15px;font-weight:700;color:#111827">@Model.SelectedUser.Username</div>
                    </div>
                    <div>
                        <div class="form-label">Mật khẩu</div>
                        <div style="font-size:14px;color:#6b7280;font-family:var(--mono)">••••••••</div>
                    </div>
                </div>
            </div>

            <div class="profile-section">
                <div class="profile-section-title"><i class="bi bi-person"></i> Thông tin cá nhân</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                    <div>
                        <div class="form-label">Tên hiển thị</div>
                        <div style="font-size:15px;font-weight:600;color:#111827">
                            @(string.IsNullOrEmpty(Model.SelectedUser.Name) ? "—" : Model.SelectedUser.Name)
                        </div>
                    </div>
                    <div>
                        <div class="form-label">Email</div>
                        <div style="font-size:15px;font-weight:600;color:#111827">
                            @(string.IsNullOrEmpty(Model.SelectedUser.Email) ? "—" : Model.SelectedUser.Email)
                        </div>
                    </div>
                    <div>
                        <div class="form-label">Số điện thoại</div>
                        <div style="font-size:15px;font-weight:600;color:#111827">
                            @(string.IsNullOrEmpty(Model.SelectedUser.Phone) ? "—" : Model.SelectedUser.Phone)
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.SelectedUser.Role == "OWNER" && Model.OwnerPois.Any())
            {
                <div class="profile-section">
                    <div class="profile-section-title"><i class="bi bi-geo-alt"></i> POI đang quản lý (@Model.OwnerPois.Count điểm)</div>
                    <table class="tg-table">
                        <thead><tr><th>ID</th><th>Tên điểm</th><th>Địa chỉ</th><th>Bán kính</th></tr></thead>
                        <tbody>
                            @foreach (var p in Model.OwnerPois)
                            {
                                <tr>
                                    <td style="color:#6b7280">#@p.Id</td>
                                    <td style="font-weight:600;color:#111827">@p.Name</td>
                                    <td style="color:#374151">@(p.Address ?? "—")</td>
                                    <td style="color:#374151">@p.Radius m</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
