@page
@model GPSGuide.Web.Pages.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký — TourGuide</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #0d1117;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Times New Roman', Times, serif;
            color: #e2e8f0;
        }

        .auth-wrap {
            width: 100%;
            max-width: 420px;
            padding: 20px;
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 32px;
        }

            .auth-logo .icon {
                width: 52px;
                height: 52px;
                background: linear-gradient(135deg, #e94560, #ff6b6b);
                border-radius: 14px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 24px;
                margin-bottom: 12px;
            }

            .auth-logo h1 {
                font-family: 'Space Mono', monospace;
                font-size: 20px;
                font-weight: 700;
            }

            .auth-logo p {
                font-size: 13px;
                color: #8b9ab3;
                margin-top: 4px;
            }

        .auth-card {
            background: #16213e;
            border: 1px solid #1f3460;
            border-radius: 14px;
            padding: 28px;
        }

        .auth-tabs {
            display: flex;
            margin-bottom: 24px;
            background: #0d1117;
            border-radius: 8px;
            padding: 4px;
        }

        .auth-tab {
            flex: 1;
            text-align: center;
            padding: 8px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            color: #8b9ab3;
            text-decoration: none;
            transition: all .15s;
        }

            .auth-tab.active {
                background: #e94560;
                color: #fff;
            }

        .form-group {
            margin-bottom: 16px;
        }

        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: #8b9ab3;
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            background: #1a2744;
            border: 1px solid #1f3460;
            border-radius: 8px;
            padding: 10px 13px;
            color: #e2e8f0;
            font-size: 14px;
            font-family: 'Times New Roman', Times, serif;
            -webkit-text-fill-color: #e2e8f0;
            transition: border-color .15s;
        }

            .form-control:focus {
                outline: none;
                border-color: #e94560;
                box-shadow: 0 0 0 3px rgba(233,69,96,.15);
            }

            .form-control::placeholder {
                color: #8b9ab3;
            }

            .form-control:-webkit-autofill {
                -webkit-box-shadow: 0 0 0 1000px #1a2744 inset !important;
                -webkit-text-fill-color: #e2e8f0 !important;
            }

        .input-icon {
            position: relative;
        }

            .input-icon i {
                position: absolute;
                right: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #8b9ab3;
                cursor: pointer;
                font-size: 15px;
            }

            .input-icon .form-control {
                padding-right: 38px;
            }

        .btn-submit {
            width: 100%;
            padding: 11px;
            background: #e94560;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            font-family: 'Times New Roman', Times, serif;
            cursor: pointer;
            transition: background .15s;
            margin-top: 8px;
        }

            .btn-submit:hover {
                background: #c73652;
            }

        .alert-error {
            background: rgba(233,69,96,.1);
            border: 1px solid rgba(233,69,96,.3);
            color: #e94560;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .role-info {
            background: rgba(233,69,96,.06);
            border: 1px solid rgba(233,69,96,.15);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 12px;
            color: #8b9ab3;
            margin-bottom: 16px;
        }

            .role-info strong {
                color: #e94560;
            }
    </style>
</head>
<body>
    <div class="auth-wrap">
        <div class="auth-logo">
            <div class="icon"><i class="bi bi-broadcast-pin"></i></div>
            <h1>TourGuide CMS</h1>
            <p>Hệ thống quản lý thuyết minh tự động</p>
        </div>
        <div class="auth-card">
            <div class="auth-tabs">
                <a href="/Login" class="auth-tab">Đăng nhập</a>
                <span class="auth-tab active">Đăng ký</span>
            </div>

            <div class="role-info">
                <i class="bi bi-info-circle"></i>
                Tài khoản đăng ký sẽ là <strong>Owner</strong> — chỉ quản lý POI và audio của cửa hàng bạn.
            </div>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert-error">
                    <i class="bi bi-exclamation-triangle"></i> @Model.Error
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Tên đăng nhập</label>
                    <input type="text" name="Username" class="form-control"
                           placeholder="VD: pho_hoa_owner" required autofocus
                           value="@Model.Username" />
                </div>
                <div class="form-group">
                    <label class="form-label">Mật khẩu</label>
                    <div class="input-icon">
                        <input type="password" name="Password" id="pwdInput" class="form-control"
                               placeholder="Tối thiểu 6 ký tự" required minlength="6" />
                        <i class="bi bi-eye" id="eyeIcon" onclick="togglePwd()"></i>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Xác nhận mật khẩu</label>
                    <div class="input-icon">
                        <input type="password" name="ConfirmPassword" id="pwd2Input" class="form-control"
                               placeholder="Nhập lại mật khẩu" required />
                        <i class="bi bi-eye" id="eyeIcon2" onclick="togglePwd2()"></i>
                    </div>
                </div>
                <button type="submit" class="btn-submit">
                    <i class="bi bi-person-plus"></i> Đăng ký
                </button>
            </form>
        </div>
    </div>
    <script>
        function togglePwd()  { const i=document.getElementById('pwdInput');  const e=document.getElementById('eyeIcon');  i.type=i.type==='password'?'text':'password'; e.className=i.type==='password'?'bi bi-eye':'bi bi-eye-slash'; }
        function togglePwd2() { const i=document.getElementById('pwd2Input'); const e=document.getElementById('eyeIcon2'); i.type=i.type==='password'?'text':'password'; e.className=i.type==='password'?'bi bi-eye':'bi bi-eye-slash'; }
    </script>
</body>
</html>
