@page
@model GPSGuide.Web.Pages.AudioManagerModel
@{
    ViewData["Title"] = "Quản lý Audio"; ViewData["Active"] = "audio";
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}

<div class="page-header">
    <div><h2>Quản lý Audio</h2></div>
    <button class="btn btn-primary" onclick="openModal()">
        <i class="bi bi-plus-lg"></i> Thêm Audio
    </button>
</div>

<div class="card">
    <table class="tg-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Điểm</th>
                <th style="width:150px">Kịch bản (Vi)</th>
                <th style="width:150px">Kịch bản (En)</th>
                <th style="width:150px">Kịch bản (Ja)</th>
                <th style="width:150px">Kịch bản (Zh)</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @{
                int stt = 1;
            }
            @foreach (var a in Model.Audios)
            {
                <tr>
                    <td class="text-muted">#@(stt++)</td>

                    <td style="font-weight:600">@(a.PoiName ?? $"#{a.PoiId}")</td>
                    <td class="text-muted text-truncate" style="max-width:120px" title="@a.vi">@a.vi</td>
                    <td class="text-muted text-truncate" style="max-width:120px" title="@a.en">@a.en</td>
                    <td class="text-muted text-truncate" style="max-width:120px" title="@a.ja">@a.ja</td>
                    <td class="text-muted text-truncate" style="max-width:120px" title="@a.zh">@a.zh</td>
                    <td>
                        <div class="action-group">
                            <button type="button" class="btn btn-ghost btn-sm btn-icon" title="Chỉnh sửa"
                                    onclick="editAudio(@a.Id)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-ghost btn-sm btn-icon text-danger" title="Xoá"
                                    onclick="confirmDeleteAudio(@a.Id, '@(a.PoiName ?? $"#{a.PoiId}")')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Audios.Any())
            {
                <tr>
                    <td colspan="5" class="empty-state">
                        Chưa có audio nào.
                        <a href="#" onclick="openModal();return false;">Thêm mới</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ── MODAL THÊM / SỬA ── -->
<div id="audioModal" class="modal-backdrop" style="display:none"
     onclick="if(event.target===this)closeModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4 id="modalTitle">Thêm Audio</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeModal()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="fId" value="0" />
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Điểm <span class="required">*</span></label>
                    <select name="PoiId" id="fPoiId" class="form-control" required>
                        <option value="">-- Chọn điểm --</option>
                        @foreach (var p in Model.Pois)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
                        <label class="form-label">Kịch bản Tiếng Việt <span class="required">*</span></label>
                        <button type="button" class="btn btn-xs btn-outline" onclick="autoTranslateAll()" id="btnAutoTrans">
                            <i class="bi bi-translate"></i> Tự động dịch sang EN, JA, ZH
                        </button>
                    </div>
                    <div style="position:relative">
                        <textarea name="vi" id="fVi" class="form-control" rows="3" placeholder="Nội dung tiếng Việt..." required></textarea>
                        <button type="button" class="btn-listen-mini" onclick="previewTtsModal('vi')" title="Nghe thử"><i class="bi bi-volume-up"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Kịch bản Tiếng Anh (EN)</label>
                    <div style="position:relative">
                        <textarea name="en" id="fEn" class="form-control" rows="2" placeholder="English script..."></textarea>
                        <button type="button" class="btn-listen-mini" onclick="previewTtsModal('en')" title="Nghe thử"><i class="bi bi-volume-up"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Kịch bản Tiếng Nhật (JA)</label>
                    <div style="position:relative">
                        <textarea name="ja" id="fJa" class="form-control" rows="2" placeholder="日本語の台本..."></textarea>
                        <button type="button" class="btn-listen-mini" onclick="previewTtsModal('ja')" title="Nghe thử"><i class="bi bi-volume-up"></i></button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Kịch bản Tiếng Trung (ZH)</label>
                    <div style="position:relative">
                        <textarea name="zh" id="fZh" class="form-control" rows="2" placeholder="中文脚本..."></textarea>
                        <button type="button" class="btn-listen-mini" onclick="previewTtsModal('zh')" title="Nghe thử"><i class="bi bi-volume-up"></i></button>
                    </div>
                </div>
                <div id="stopBtnWrap" style="display:none;text-align:center;margin-top:10px">
                    <button type="button" class="btn btn-sm btn-danger" onclick="stopTts()">
                        <i class="bi bi-stop-fill"></i> Dừng nghe thử
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> <span id="submitLabel">Lưu</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ── MODAL XOÁ ── -->
<div id="deleteModal" class="modal-backdrop" style="display:none"
     onclick="if(event.target===this)closeDelete()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4>Xác nhận xoá</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeDelete()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="modal-body">
            <p>Xoá audio của <strong id="delName"></strong>?</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="closeDelete()">Huỷ</button>
            <form method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeleteId" id="fDeleteId" />
                <button type="submit" asp-page-handler="Delete" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Xoá
                </button>
            </form>
        </div>
    </div>
</div>

@* Data audio trong script tag — an toàn với ký tự đặc biệt tiếng Việt/Nhật/Trung *@
<script id="audioData" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Audios.Select(a => new {
        id = a.Id,
        poiId = a.PoiId,
        poiName = a.PoiName ?? $"#{a.PoiId}",
        vi = a.vi ?? "",
        en = a.en ?? "",
        ja = a.ja ?? "",
        zh = a.zh ?? ""
    })))
</script>

<script>
    const AUDIOS = JSON.parse(document.getElementById('audioData').textContent);

    // ── Modal ──────────────────────────────────────────────────────────────────
    function openModal() {
        document.getElementById('fId').value = '0';
        document.getElementById('fPoiId').value = '';
        document.getElementById('fVi').value = '';
        document.getElementById('fEn').value = '';
        document.getElementById('fJa').value = '';
        document.getElementById('fZh').value = '';
        document.getElementById('modalTitle').textContent = 'Thêm Audio';
        document.getElementById('submitLabel').textContent = 'Lưu';
        document.getElementById('audioModal').style.display = 'flex';
    }
    function closeModal() { stopTts(); document.getElementById('audioModal').style.display = 'none'; }

    function editAudio(id) {
        const a = AUDIOS.find(x => x.id === id);
        if (!a) return;
        document.getElementById('fId').value    = a.id;
        document.getElementById('fPoiId').value = a.poiId;
        document.getElementById('fVi').value    = a.vi;
        document.getElementById('fEn').value    = a.en;
        document.getElementById('fJa').value    = a.ja;
        document.getElementById('fZh').value    = a.zh;
        document.getElementById('modalTitle').textContent  = 'Sửa Audio';
        document.getElementById('submitLabel').textContent = 'Cập nhật';
        document.getElementById('audioModal').style.display = 'flex';
    }

    async function autoTranslateAll() {
        const viText = document.getElementById('fVi').value.trim();
        if (!viText) { alert('Vui lòng nhập kịch bản Tiếng Việt trước.'); return; }
        
        const btn = document.getElementById('btnAutoTrans');
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang dịch...';

        try {
            const [en, ja, zh] = await Promise.all([
                translateText(viText, 'en'),
                translateText(viText, 'ja'),
                translateText(viText, 'zh')
            ]);
            document.getElementById('fEn').value = en;
            document.getElementById('fJa').value = ja;
            document.getElementById('fZh').value = zh;
        } catch (err) {
            alert('Lỗi khi dịch: ' + err.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-translate"></i> Tự động dịch sang EN, JA, ZH';
        }
    }

    function confirmDeleteAudio(id, name) {
        document.getElementById('fDeleteId').value     = id;
        document.getElementById('delName').textContent = name;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDelete() { document.getElementById('deleteModal').style.display = 'none'; }

    document.addEventListener('DOMContentLoaded', () => {
        // Preload voices
        if ('speechSynthesis' in window) {
            window.speechSynthesis.getVoices();
            window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();
        }
    });

    // ── Dịch tự động ──────────────────────────────────────────────────────────
    async function translateText(text, targetLang) {
        try {
            const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=vi&tl=${targetLang}&dt=t&q=${encodeURIComponent(text)}`;
            const res  = await fetch(url);
            const data = await res.json();
            return data[0].map(x => x[0]).join('');
        } catch {
            return ""; 
        }
    }

    // ── TTS ────────────────────────────────────────────────────────────────────
    async function makeTtsUtterance(text, langCode) {
        const u = new SpeechSynthesisUtterance(text);
        const voices = window.speechSynthesis.getVoices();
        
        const prefs = {
            'vi': ['Google Vietnamese', 'vi-VN'],
            'en': ['Google US English', 'en-US'],
            'ja': ['Google 日本語', 'ja-JP'],
            'zh': ['Google 普通话', 'zh-CN']
        };

        const list = prefs[langCode] || ['en-US'];
        const voice = voices.find(v => list.some(p => v.name.includes(p) || v.lang.includes(p)));
        if (voice) u.voice = voice;
        u.lang = list[1] || 'en-US';
        return u;
    }

    let _tts = null;
    async function previewTtsModal(lang) {
        const id = 'f' + lang.charAt(0).toUpperCase() + lang.slice(1);
        const s = document.getElementById(id).value.trim();
        if (!s) { alert('Chưa có kịch bản.'); return; }
        
        stopTts();
        const u = await makeTtsUtterance(s, lang);
        _tts = u;
        u.onstart = () => document.getElementById('stopBtnWrap').style.display = 'block';
        u.onend = u.onerror = () => { document.getElementById('stopBtnWrap').style.display = 'none'; _tts = null; };
        window.speechSynthesis.speak(u);
    }

    function stopTts() {
        window.speechSynthesis.cancel();
        document.getElementById('stopBtnWrap').style.display = 'none';
        _tts = null;
    }

    document.addEventListener('keydown', e => { if (e.key==='Escape') { closeModal(); closeDelete(); } });
</script>
