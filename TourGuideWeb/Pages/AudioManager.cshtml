@page
@model GPSGuide.Web.Pages.AudioManagerModel
@{
    ViewData["Title"] = "Quản lý Audio"; ViewData["Active"] = "audio";
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}

<div class="page-header">
    <div><h2>Quản lý Audio</h2></div>
    <button class="btn btn-primary" onclick="openAddModal()">
        <i class="bi bi-plus-lg"></i> Thêm Audio
    </button>
</div>

<div class="card">
    <table class="tg-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Điểm</th>
                <th>Nghe thử</th>
                <th>Ngôn ngữ</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @{
                int stt = 1;
            }
            @foreach (var a in Model.Audios)
            {
                <tr>
                    <td class="text-muted">#@(stt++)</td>
                    <td style="font-weight:600">@(a.PoiName ?? $"#{a.PoiId}")</td>
                    <td style="white-space:nowrap">
                        <button type="button" id="btn-play-@a.Id" class="btn btn-ghost btn-sm btn-icon" title="Phát" onclick="rowPlay(@a.Id)">
                            <i class="bi bi-play-fill"></i>
                        </button>
                        <button type="button" id="btn-pause-@a.Id" class="btn btn-ghost btn-sm btn-icon" title="Tạm dừng" onclick="rowPause(@a.Id)" style="display:none">
                            <i class="bi bi-pause-fill"></i>
                        </button>
                        <button type="button" id="btn-resume-@a.Id" class="btn btn-ghost btn-sm btn-icon" title="Tiếp tục" onclick="rowResume(@a.Id)" style="display:none">
                            <i class="bi bi-play-circle-fill"></i>
                        </button>
                        <button type="button" id="btn-stop-@a.Id" class="btn btn-ghost btn-sm btn-icon text-danger" title="Dừng" onclick="rowStop(@a.Id)" style="display:none">
                            <i class="bi bi-stop-fill"></i>
                        </button>
                    </td>
                    <td>
                        <select id="lang-@a.Id" class="form-control" style="width:auto;font-size:11px;padding:2px 6px">
                            <option value="vi">🇻🇳 VI</option>
                            <option value="en">🇺🇸 EN</option>
                            <option value="ja">🇯🇵 JA</option>
                            <option value="zh">🇨🇳 ZH</option>
                        </select>
                    </td>
                    <td>
                        <div class="action-group">
                            <button type="button" class="btn btn-ghost btn-sm btn-icon" title="Chỉnh sửa" onclick="openEditModal(@a.Id)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-ghost btn-sm btn-icon text-danger" title="Xoá"
                                    onclick="confirmDeleteAudio(@a.Id, '@(a.PoiName ?? $"#{a.PoiId}")')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Audios.Any())
            {
                <tr>
                    <td colspan="5" class="empty-state">
                        Chưa có audio nào.
                        <a href="#" onclick="openAddModal();return false;">Thêm mới</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .modal-body .form-group { margin-bottom: 22px; }
    .required { color: #dc3545; margin-left: 2px; }
    .modal-lang-selector { 
        display:flex; gap:10px; align-items:center; margin-bottom:20px; padding:12px; 
        background:#f8fafc; border-radius:10px; border:1px solid #e2e8f0;
    }
</style>

<!-- MODAL THÊM -->
<div id="addModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)closeAddModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4>Thêm Audio</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeAddModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        @if (Model.PoisWithoutAudio.Any())
        {
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="0" />
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Điểm <span class="required">*</span></label>
                        <select name="PoiId" id="aPoiId" class="form-control" required>
                            <option value="">-- Chọn điểm --</option>
                            @foreach (var p in Model.PoisWithoutAudio)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                    </div>

                    <div class="modal-lang-selector">
                        <span style="font-size:12px;font-weight:600;color:#475569">Nghe thử:</span>
                        <select id="aTtsLang" class="form-control" style="width:auto;font-size:12px;padding:3px 8px">
                            <option value="vi">🇻🇳 VI</option>
                            <option value="en">🇺🇸 EN</option>
                            <option value="ja">🇯🇵 JA</option>
                            <option value="zh">🇨🇳 ZH</option>
                        </select>
                        <div style="flex-grow:1"></div>
                        <button type="button" id="aBtnPlay" class="btn btn-sm btn-outline" onclick="addTtsPlay()"><i class="bi bi-play-fill"></i> Phát</button>
                        <button type="button" id="aBtnPause" class="btn btn-sm btn-outline" onclick="addTtsPause()" style="display:none"><i class="bi bi-pause-fill"></i> Tạm dừng</button>
                        <button type="button" id="aBtnResume" class="btn btn-sm btn-outline" onclick="addTtsResume()" style="display:none"><i class="bi bi-play-circle-fill"></i> Tiếp tục</button>
                        <button type="button" id="aBtnStop" class="btn btn-sm btn-danger" onclick="addTtsStop()" style="display:none"><i class="bi bi-stop-fill"></i> Dừng</button>
                    </div>

                    <div style="margin-bottom:20px;text-align:right">
                        <button type="button" class="btn btn-xs btn-outline" onclick="autoTranslateAll()" id="btnAutoTrans">
                            <i class="bi bi-translate"></i> Dịch tự động (VI → EN, JA, ZH)
                        </button>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Script Tiếng Việt <span class="required">*</span></label>
                        <textarea name="vi" id="aVi" class="form-control" rows="3" placeholder="Nội dung tiếng Việt..." required></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Script Tiếng Anh (EN) <span class="required">*</span></label>
                        <textarea name="en" id="aEn" class="form-control" rows="2" placeholder="English script..." required></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Script Tiếng Nhật (JA) <span class="required">*</span></label>
                        <textarea name="ja" id="aJa" class="form-control" rows="2" placeholder="日本語の台本..." required></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Script Tiếng Trung (ZH) <span class="required">*</span></label>
                        <textarea name="zh" id="aZh" class="form-control" rows="2" placeholder="中文脚本..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" onclick="closeAddModal()">Huỷ</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu</button>
                </div>
            </form>
        }
        else
        {
            <div class="modal-body" style="padding:40px 20px;text-align:center">
                <div style="font-size:48px;color:#cbd5e1;margin-bottom:16px"><i class="bi bi-check-circle"></i></div>
                <h3 style="margin-bottom:8px">Đã có đủ kịch bản!</h3>
                <p style="color:#64748b">Tất cả các điểm trên bản đồ hiện đều đã được gán kịch bản âm thanh.</p>
                <div style="margin-top:24px">
                    <button type="button" class="btn btn-secondary" onclick="closeAddModal()">Đóng</button>
                </div>
            </div>
        }
    </div>
</div>

<!-- MODAL SỬA -->
<div id="editModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)closeEditModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4 id="editModalTitle">Sửa Audio</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeEditModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="eId" value="0" />
            <input type="hidden" name="PoiId" id="ePoiId" value="0" />
            <div class="modal-body">
                <div class="modal-lang-selector">
                    <span style="font-size:12px;font-weight:600;color:#475569">Nghe thử:</span>
                    <select id="eTtsLang" class="form-control" style="width:auto;font-size:12px;padding:3px 8px">
                        <option value="vi">🇻🇳 VI</option>
                        <option value="en">🇺🇸 EN</option>
                        <option value="ja">🇯🇵 JA</option>
                        <option value="zh">🇨🇳 ZH</option>
                    </select>
                    <div style="flex-grow:1"></div>
                    <button type="button" id="eBtnPlay" class="btn btn-sm btn-outline" onclick="editTtsPlay()"><i class="bi bi-play-fill"></i> Phát</button>
                    <button type="button" id="eBtnPause" class="btn btn-sm btn-outline" onclick="editTtsPause()" style="display:none"><i class="bi bi-pause-fill"></i> Tạm dừng</button>
                    <button type="button" id="eBtnResume" class="btn btn-sm btn-outline" onclick="editTtsResume()" style="display:none"><i class="bi bi-play-circle-fill"></i> Tiếp tục</button>
                    <button type="button" id="eBtnStop" class="btn btn-sm btn-danger" onclick="editTtsStop()" style="display:none"><i class="bi bi-stop-fill"></i> Dừng</button>
                </div>
                
                <div style="margin-bottom:20px;text-align:right">
                    <button type="button" class="btn btn-xs btn-outline" onclick="autoTranslateEdit()" id="btnAutoTransEdit">
                        <i class="bi bi-translate"></i> Dịch tự động (VI → EN, JA, ZH)
                    </button>
                </div>

                <div class="form-group">
                    <label class="form-label">Script Tiếng Việt <span class="required">*</span></label>
                    <textarea name="vi" id="eVi" class="form-control" rows="3" required></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Script Tiếng Anh (EN) <span class="required">*</span></label>
                    <textarea name="en" id="eEn" class="form-control" rows="2" required></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Script Tiếng Nhật (JA) <span class="required">*</span></label>
                    <textarea name="ja" id="eJa" class="form-control" rows="2" required></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Script Tiếng Trung (ZH) <span class="required">*</span></label>
                    <textarea name="zh" id="eZh" class="form-control" rows="2" required></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeEditModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cập nhật</button>
            </div>
        </form>
    </div>
</div>

<!-- MODAL XOÁ -->
<div id="deleteModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)closeDelete()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4>Xác nhận xoá</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeDelete()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="modal-body"><p>Xoá audio của <strong id="delName"></strong>?</p></div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="closeDelete()">Huỷ</button>
            <form method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeleteId" id="fDeleteId" />
                <button type="submit" asp-page-handler="Delete" class="btn btn-danger"><i class="bi bi-trash"></i> Xoá</button>
            </form>
        </div>
    </div>
</div>

<script id="audioData" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Audios.Select(a => new {
        id = a.Id, poiId = a.PoiId,
                poiName = a.PoiName ?? $"#{a.PoiId}",
                vi = a.vi ?? "", en = a.en ?? "", ja = a.ja ?? "", zh = a.zh ?? ""
        })))
</script>

<script>
    const AUDIOS = JSON.parse(document.getElementById('audioData').textContent);
    let _currentUtterance = null;
    let _speakQueue = [];
    let _queueIndex = 0;

    document.addEventListener('DOMContentLoaded', () => {
        if ('speechSynthesis' in window) {
            window.speechSynthesis.getVoices();
            window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();
        }
    });

    function openAddModal() {
        ['aPoiId','aVi','aEn','aJa','aZh'].forEach(id => {
             const el = document.getElementById(id);
             if(el) el.value = '';
        });
        addTtsStop();
        document.getElementById('addModal').style.display = 'flex';
    }
    function closeAddModal() { addTtsStop(); document.getElementById('addModal').style.display = 'none'; }

    function getAddText() {
        const lang = document.getElementById('aTtsLang').value;
        const map  = { vi:'aVi', en:'aEn', ja:'aJa', zh:'aZh' };
        const el = document.getElementById(map[lang]);
        return { text: el ? el.value.trim() : "", lang };
    }
    async function addTtsPlay() {
        const { text, lang } = getAddText();
        if (!text) { alert('Chưa có kịch bản cho ngôn ngữ này.'); return; }
        addTtsStop();
        
        startSpeak(text, lang, () => {
            show('aBtnPause'); show('aBtnStop'); hide('aBtnPlay'); hide('aBtnResume');
            document.getElementById('aTtsLang').disabled = true;
        }, () => {
            addTtsStop();
        });
    }
    function addTtsPause() { window.speechSynthesis.pause(); hide('aBtnPause'); show('aBtnResume'); }
    function addTtsResume() { window.speechSynthesis.resume(); show('aBtnPause'); hide('aBtnResume'); }
    function addTtsStop() {
        window.speechSynthesis.cancel();
        show('aBtnPlay'); hide('aBtnPause'); hide('aBtnResume'); hide('aBtnStop');
        const langSel = document.getElementById('aTtsLang');
        if (langSel) langSel.disabled = false;
        _currentUtterance = null;
    }

    async function autoTranslateAll() {
        const viText = document.getElementById('aVi').value.trim();
        if (!viText) { alert('Vui lòng nhập kịch bản Tiếng Việt trước.'); return; }
        const btn = document.getElementById('btnAutoTrans');
        btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang dịch...';
        try {
            const [en, ja, zh] = await Promise.all([translateText(viText,'en'), translateText(viText,'ja'), translateText(viText,'zh')]);
            document.getElementById('aEn').value = en;
            document.getElementById('aJa').value = ja;
            document.getElementById('aZh').value = zh;
        } catch (err) { alert('Lỗi khi dịch: ' + err.message); }
        finally { btn.disabled = false; btn.innerHTML = '<i class="bi bi-translate"></i> Dịch VI → EN, JA, ZH'; }
    }

    function openEditModal(id) {
        const a = AUDIOS.find(x => x.id === id); if (!a) return;
        document.getElementById('eId').value    = a.id;
        document.getElementById('ePoiId').value = a.poiId;
        document.getElementById('eVi').value    = a.vi;
        document.getElementById('eEn').value    = a.en;
        document.getElementById('eJa').value    = a.ja;
        document.getElementById('eZh').value    = a.zh;
        document.getElementById('editModalTitle').textContent = 'Sửa Audio — ' + a.poiName;
        editTtsStop();
        document.getElementById('editModal').style.display = 'flex';
    }
    function closeEditModal() { editTtsStop(); document.getElementById('editModal').style.display = 'none'; }

    let _editPaused = false;
    function getEditText() {
        const lang = document.getElementById('eTtsLang').value;
        const map  = { vi:'eVi', en:'eEn', ja:'eJa', zh:'eZh' };
        return { text: document.getElementById(map[lang]).value.trim(), lang };
    }
    async function editTtsPlay() {
        const { text, lang } = getEditText();
        if (!text) { alert('Chưa có script cho ngôn ngữ này.'); return; }
        editTtsStop(); _editPaused = false;
        
        startSpeak(text, lang, () => {
            show('eBtnPause'); show('eBtnStop'); hide('eBtnPlay'); hide('eBtnResume');
            document.getElementById('eTtsLang').disabled = true;
        }, () => {
            editTtsStop();
        });
    }
    function editTtsPause() { window.speechSynthesis.pause(); _editPaused = true; hide('eBtnPause'); show('eBtnResume'); }
    function editTtsResume() { window.speechSynthesis.resume(); _editPaused = false; show('eBtnPause'); hide('eBtnResume'); }
    function editTtsStop() {
        window.speechSynthesis.cancel(); _editPaused = false;
        show('eBtnPlay'); hide('eBtnPause'); hide('eBtnResume'); hide('eBtnStop');
        const langSel = document.getElementById('eTtsLang');
        if (langSel) langSel.disabled = false;
        _currentUtterance = null;
    }

    let _rowPlaying = null, _rowPaused = false;
    function rowPlay(id) {
        const a = AUDIOS.find(x => x.id === id); if (!a) return;
        if (_rowPlaying && _rowPlaying !== id) rowStop(_rowPlaying);
        window.speechSynthesis.cancel(); _rowPaused = false;
        
        const langEl = document.getElementById('lang-' + id);
        const lang = langEl ? langEl.value : 'vi';
        const text = a[lang] || a.vi;
        if (!text) { alert('Chưa có script cho ngôn ngữ này.'); return; }

        startSpeak(text, lang, () => {
            _rowPlaying = id; 
            setRow(id, 'playing');
        }, () => {
            _rowPlaying = null; 
            setRow(id, 'idle');
        });
    }

    function rowPause(id) { window.speechSynthesis.pause(); _rowPaused = true; setRow(id, 'paused'); }
    function rowResume(id) { window.speechSynthesis.resume(); _rowPaused = false; setRow(id, 'playing'); }
    function rowStop(id) { window.speechSynthesis.cancel(); _rowPlaying = null; _rowPaused = false; setRow(id, 'idle'); _currentUtterance = null; }
    
    function setRow(id, state) {
        const el = (btnId) => document.getElementById('btn-' + btnId + '-' + id);
        const sel = document.getElementById('lang-' + id);
        
        const playBtn = el('play');
        const pauseBtn = el('pause');
        const resumeBtn = el('resume');
        const stopBtn = el('stop');

        if(playBtn) playBtn.style.display = state === 'idle' ? '' : 'none';
        if(pauseBtn) pauseBtn.style.display = state === 'playing' ? '' : 'none';
        if(resumeBtn) resumeBtn.style.display = state === 'paused' ? '' : 'none';
        if(stopBtn) stopBtn.style.display = state !== 'idle' ? '' : 'none';
        
        if (sel) sel.disabled = (state !== 'idle');
    }

    // --- TTS Engine with Chunking to solve lag ---
    
    function startSpeak(text, lang, onStart, onEnd) {
        _speakQueue = text.split(/(?<=[.!?])\s+/).filter(s => s.trim().length > 0);
        _queueIndex = 0;
        if (_speakQueue.length === 0) {
            onEnd();
            return;
        }
        
        onStart();
        processQueue(lang, onEnd);
    }

    async function processQueue(lang, onEnd) {
        if (_queueIndex >= _speakQueue.length) {
            onEnd();
            return;
        }

        const text = _speakQueue[_queueIndex];
        const u = await makeUtterance(text, lang);
        _currentUtterance = u; 

        u.onend = () => {
            _queueIndex++;
            processQueue(lang, onEnd);
        };
        u.onerror = (e) => {
            console.error('TTS Error:', e);
            onEnd();
        };

        window.speechSynthesis.speak(u);
    }

    async function makeUtterance(text, langCode) {
        const u = new SpeechSynthesisUtterance(text);
        const voices = window.speechSynthesis.getVoices();
        const prefs = {
            vi: ['Google Vietnamese','Microsoft HoaiMy','vi-VN'],
            en: ['Google US English','Microsoft Aria','en-US'],
            ja: ['Google 日本語','Microsoft Nanami','ja-JP'],
            zh: ['Google 普通话','Microsoft Xiaoxiao','zh-CN']
        };
        const list  = prefs[langCode] || ['en-US'];
        const voice = voices.find(v => list.some(p => v.name.includes(p) || v.lang.startsWith(p)));
        if (voice) u.voice = voice;
        u.lang = list[list.length - 1];
        u.rate = 0.95; 
        return u;
    }

    async function translateText(text, targetLang) {
        const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=vi&tl=${targetLang}&dt=t&q=${encodeURIComponent(text)}`;
        try {
            const res  = await fetch(url);
            const data = await res.json();
            return data[0].map(x => x[0]).join('');
        } catch(e) { return ""; }
    }

    function show(id) { const el = document.getElementById(id); if (el) el.style.display = ''; }
    function hide(id) { const el = document.getElementById(id); if (el) el.style.display = 'none'; }

    async function autoTranslateEdit() {
        const viText = document.getElementById('eVi').value.trim();
        if (!viText) { alert('Vui lòng nhập script Tiếng Việt trước.'); return; }
        const btn = document.getElementById('btnAutoTransEdit');
        btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang dịch...';
        try {
            const [en, ja, zh] = await Promise.all([translateText(viText,'en'), translateText(viText,'ja'), translateText(viText,'zh')]);
            document.getElementById('eEn').value = en;
            document.getElementById('eJa').value = ja;
            document.getElementById('eZh').value = zh;
        } catch (err) { alert('Lỗi khi dịch: ' + err.message); }
        finally { btn.disabled = false; btn.innerHTML = '<i class="bi bi-translate"></i> Dịch VI → EN, JA, ZH'; }
    }

    function confirmDeleteAudio(id, name) {
        document.getElementById('fDeleteId').value = id;
        document.getElementById('delName').textContent = name;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDelete() { document.getElementById('deleteModal').style.display = 'none'; }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeAddModal(); closeEditModal(); closeDelete(); } });
</script>
