@page
@model GPSGuide.Web.Pages.AudioManagerModel
@{
    ViewData["Title"] = "Quản lý Audio"; ViewData["Active"] = "audio";
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}

<div class="page-header">
    <div><h2>Quản lý Audio</h2></div>
    <button class="btn btn-primary" onclick="openModal()">
        <i class="bi bi-plus-lg"></i> Thêm Audio
    </button>
</div>

<div class="card">
    <table class="tg-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Điểm</th>
                <th>Ngôn ngữ</th>
                <th>Script</th>
                <th>Audio URL</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Audios)
            {
                <tr>
                    <td class="text-muted">#@a.Id</td>
                    <td style="font-weight:600">@(a.PoiName ?? $"#{a.PoiId}")</td>
                    <td><span class="badge badge-blue">@(a.Language ?? "vi")</span></td>
                    <td class="text-muted"
                        style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                        title="@a.Script">
                        @(string.IsNullOrEmpty(a.Script) ? "—" : a.Script)
                    </td>
                    <td class="text-muted"
                        style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                        @(string.IsNullOrEmpty(a.AudioUrl) ? "—" : a.AudioUrl)
                    </td>
                    <td>
                        <div class="action-group">
                            @if (!string.IsNullOrEmpty(a.Script))
                            {
                                <button class="btn btn-ghost btn-sm btn-icon" title="Nghe thử"
                                        onclick="toggleTts(@a.Id)"
                                        id="ttsBtn-@a.Id">
                                    <i class="bi bi-play-circle"></i>
                                </button>
                            }
                            <button class="btn btn-ghost btn-sm btn-icon" title="Chỉnh sửa"
                                    onclick="editAudio(@a.Id)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-ghost btn-sm btn-icon text-danger" title="Xoá"
                                    onclick="confirmDeleteAudio(@a.Id, '@(a.PoiName ?? $"#{a.PoiId}")')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Audios.Any())
            {
                <tr>
                    <td colspan="6" class="empty-state">
                        Chưa có audio nào.
                        <a href="#" onclick="openModal();return false;">Thêm mới</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ── MODAL THÊM / SỬA ── -->
<div id="audioModal" class="modal-backdrop" style="display:none"
     onclick="if(event.target===this)closeModal()">
    <div class="modal-box" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4 id="modalTitle">Thêm Audio</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeModal()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="fId" value="0" />
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Điểm <span class="required">*</span></label>
                    <select name="PoiId" id="fPoiId" class="form-control" required>
                        <option value="">-- Chọn điểm --</option>
                        @foreach (var p in Model.Pois)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Ngôn ngữ</label>
                    <select name="Language" id="fLanguage" class="form-control">
                        <option value="vi">🇻🇳 Tiếng Việt</option>
                        <option value="en">🇺🇸 English</option>
                        <option value="ja">🇯🇵 日本語</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Script TTS</label>
                    <textarea name="Script" id="fScript" class="form-control" rows="5"
                              placeholder="Nội dung thuyết minh..."></textarea>
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px">
                        <span class="form-hint" style="margin:0">
                            <span id="scriptCount">0</span> ký tự
                        </span>
                        <div style="display:flex;gap:6px">
                            <button type="button" class="btn btn-sm btn-outline" onclick="previewTtsModal()">
                                <i class="bi bi-play-fill"></i> Nghe thử
                            </button>
                            <button type="button" class="btn btn-sm btn-ghost" onclick="stopTts()"
                                    id="stopBtn" style="display:none">
                                <i class="bi bi-stop-fill"></i> Dừng
                            </button>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Audio URL <small class="text-muted">(tuỳ chọn)</small></label>
                    <input type="text" name="AudioUrl" id="fAudioUrl" class="form-control"
                           placeholder="audio/tenfile.mp3" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> <span id="submitLabel">Lưu</span>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ── MODAL XOÁ ── -->
<div id="deleteModal" class="modal-backdrop" style="display:none"
     onclick="if(event.target===this)closeDelete()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4>Xác nhận xoá</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeDelete()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="modal-body">
            <p>Xoá audio của <strong id="delName"></strong>?</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="closeDelete()">Huỷ</button>
            <form method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeleteId" id="fDeleteId" />
                <button type="submit" asp-page-handler="Delete" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Xoá
                </button>
            </form>
        </div>
    </div>
</div>

@* Lưu data audio dưới dạng JSON an toàn trong script tag — tránh HTML encode trong attribute *@
<script id="audioData" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Audios.Select(a => new {
        id = a.Id,
                poiId = a.PoiId,
                poiName = a.PoiName ?? $"#{a.PoiId}",
                lang = a.Language ?? "vi",
                url = a.AudioUrl ?? "",
                script = a.Script ?? ""
        })))
</script>

<script>
    // Load data từ script tag — an toàn với mọi ký tự đặc biệt
    const AUDIOS = JSON.parse(document.getElementById('audioData').textContent);

    // ── Modal ──────────────────────────────────────────────────────────────────
    function openModal() {
        document.getElementById('fId').value = '0';
        document.getElementById('fPoiId').value = '';
        document.getElementById('fLanguage').value = 'vi';
        document.getElementById('fScript').value = '';
        document.getElementById('fAudioUrl').value = '';
        document.getElementById('modalTitle').textContent = 'Thêm Audio';
        document.getElementById('submitLabel').textContent = 'Lưu';
        document.getElementById('scriptCount').textContent = '0';
        document.getElementById('audioModal').style.display = 'flex';
    }
    function closeModal() { stopTts(); document.getElementById('audioModal').style.display = 'none'; }

    function editAudio(id) {
        const a = AUDIOS.find(x => x.id === id);
        if (!a) return;
        document.getElementById('fId').value       = a.id;
        document.getElementById('fPoiId').value    = a.poiId;
        document.getElementById('fLanguage').value = a.lang;
        document.getElementById('fAudioUrl').value = a.url;
        document.getElementById('fScript').value   = a.script;
        document.getElementById('scriptCount').textContent = a.script.length;
        document.getElementById('modalTitle').textContent  = 'Sửa Audio';
        document.getElementById('submitLabel').textContent = 'Cập nhật';
        document.getElementById('audioModal').style.display = 'flex';
    }

    function confirmDeleteAudio(id, name) {
        document.getElementById('fDeleteId').value     = id;
        document.getElementById('delName').textContent = name;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDelete() { document.getElementById('deleteModal').style.display = 'none'; }

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('fScript').addEventListener('input', function () {
            document.getElementById('scriptCount').textContent = this.value.length;
        });
        if ('speechSynthesis' in window) {
            window.speechSynthesis.getVoices();
            window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();
        }
    });

    // ── TTS ────────────────────────────────────────────────────────────────────
    let _tts = null;
    let _playingId = null;

    function pickVoice(langCode) {
        const voices = window.speechSynthesis.getVoices();
        if (!voices.length) return null;
        const prefix = langCode.toLowerCase();
        const matched = voices.filter(v => v.lang.toLowerCase().startsWith(prefix));
        if (matched.length) return matched.find(v => v.localService) || matched[0];
        return null;
    }

    function makeTtsUtterance(text, langCode) {
        const u = new SpeechSynthesisUtterance(text);
        const voice = pickVoice(langCode);
        if (voice) { u.voice = voice; u.lang = voice.lang; }
        else {
            u.lang = langCode==='vi'?'vi-VN':langCode==='en'?'en-US':
                     langCode==='ja'?'ja-JP':langCode==='zh'?'zh-CN':
                     langCode==='ko'?'ko-KR':'vi-VN';
        }
        return u;
    }

    function toggleTts(id) {
        const a = AUDIOS.find(x => x.id === id);
        if (!a) return;
        const btn = document.getElementById('ttsBtn-' + id);

        // Nếu đang play → stop
        if (_playingId === id) { stopAllTts(); return; }
        stopAllTts();

        // Ưu tiên phát file audio URL nếu có
        if (a.url) {
            const audio = new Audio(a.url);
            _playingId = id;
            if (btn) { btn.querySelector('i').className = 'bi bi-stop-circle'; btn.style.color = 'var(--accent)'; }
            audio.play().catch(() => {
                // Nếu file không tồn tại, fallback sang TTS
                playTts(a, btn, id);
            });
            audio.onended = () => {
                if (btn) { btn.querySelector('i').className = 'bi bi-play-circle'; btn.style.color = ''; }
                _playingId = null;
            };
            // Lưu để stop được
            _tts = { cancel: () => { audio.pause(); audio.currentTime = 0; } };
            return;
        }

        // Không có URL → dùng TTS
        playTts(a, btn, id);
    }

    function playTts(a, btn, id) {
        if (!('speechSynthesis' in window)) { alert('Trình duyệt không hỗ trợ TTS.'); return; }
        if (!a.script) return;
        _tts = makeTtsUtterance(a.script, a.lang);
        _playingId = id;
        if (btn) { btn.querySelector('i').className = 'bi bi-stop-circle'; btn.style.color = 'var(--accent)'; }
        _tts.onend = _tts.onerror = () => {
            if (btn) { btn.querySelector('i').className = 'bi bi-play-circle'; btn.style.color = ''; }
            _tts = null; _playingId = null;
        };
        window.speechSynthesis.speak(_tts);
    }

    function stopAllTts() {
        if ('speechSynthesis' in window) window.speechSynthesis.cancel();
        if (_tts && typeof _tts.cancel === 'function') _tts.cancel();
        if (_playingId !== null) {
            const btn = document.getElementById('ttsBtn-' + _playingId);
            if (btn) { btn.querySelector('i').className = 'bi bi-play-circle'; btn.style.color = ''; }
        }
        _tts = null; _playingId = null;
    }

    function previewTtsModal() {
        const s = document.getElementById('fScript').value.trim();
        if (!s) { alert('Chưa có script.'); return; }
        if (!('speechSynthesis' in window)) { alert('Trình duyệt không hỗ trợ TTS.'); return; }
        stopTts();
        const lang = document.getElementById('fLanguage').value || 'vi';
        _tts = makeTtsUtterance(s, lang);
        _tts.onstart = () => document.getElementById('stopBtn').style.display = 'inline-flex';
        _tts.onend = _tts.onerror = () => { document.getElementById('stopBtn').style.display = 'none'; _tts = null; };
        window.speechSynthesis.speak(_tts);
    }

    function stopTts() {
        stopAllTts();
        const s = document.getElementById('stopBtn');
        if (s) s.style.display = 'none';
    }

    document.addEventListener('keydown', e => { if (e.key==='Escape') { closeModal(); closeDelete(); } });
</script>
