@page
@model GPSGuide.Web.Pages.AudioManagerModel
@{
    ViewData["Title"] = "Quản lý Audio"; ViewData["Active"] = "audio";
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-error"><i class="bi bi-exclamation-triangle"></i> @Model.Error</div>
}

<input type="hidden" id="apiBaseUrl" value="@Model.ApiBaseUrl" />

<div class="page-header">
    <div><h2>Quản lý Audio</h2></div>
    <button class="btn btn-primary" onclick="openAddModal()">
        <i class="bi bi-plus-lg"></i> Thêm Audio
    </button>
</div>

<div class="card">
    <div style="padding:12px 16px;border-bottom:1px solid var(--border);display:flex;gap:10px;align-items:center">
        <div style="position:relative;flex:1">
            <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#9ca3af;font-size:13px"></i>
            <input type="text" id="searchPoi" placeholder="Tìm theo tên cửa hàng..."
                   oninput="filterAudio()"
                   style="padding-left:32px;width:100%;border:1px solid var(--border);border-radius:7px;padding-top:7px;padding-bottom:7px;font-size:13px" />
        </div>
        <select id="searchLang" onchange="filterAudio()"
                style="border:1px solid var(--border);border-radius:7px;padding:7px 10px;font-size:13px;background:#fff;min-width:150px">
            <option value="">Tất cả ngôn ngữ</option>
            @foreach (var l in Model.Languages)
            {
                <option value="@l.Code.ToLower()">@l.Code.ToUpper() — @l.Name</option>
            }
        </select>
        <span id="audioCount" style="font-size:12px;color:#9ca3af;white-space:nowrap"></span>
    </div>
    <table class="tg-table" id="audioTable">
        <thead>
            <tr>
                <th>Điểm thuyết minh</th>
                <th>Ngôn ngữ</th>
                <th>Script</th>
                <th>Nghe thử</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Audios.Any())
            {
                <tr>
                    <td colspan="5" class="empty-state">
                        Chưa có audio nào.
                        <a href="#" onclick="openAddModal();return false">Thêm mới</a>
                    </td>
                </tr>
            }
            @foreach (var a in Model.Audios)
            {
                <tr data-poi="@(a.PoiName?.ToLower() ?? "")" data-lang="@(a.LanguageCode?.ToLower() ?? "")">
                    <td style="font-weight:600">@(a.PoiName ?? $"#{a.PoiId}")</td>
                    <td>
                        <span style="background:#ede9fe;color:#5b21b6;font-family:monospace;font-size:12px;font-weight:700;padding:2px 8px;border-radius:8px">
                            @a.LanguageCode?.ToUpper()
                        </span>
                        <span style="font-size:12px;color:#6b7280;margin-left:4px">@a.LanguageName</span>
                    </td>
                    <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#6b7280;font-size:13px"
                        title="@a.Script">
                        @a.Script
                    </td>
                    <td style="white-space:nowrap">
                        <div style="display:flex;align-items:center;gap:2px" id="player-@a.Id">
                            <button type="button" class="btn btn-ghost btn-sm btn-icon" title="Phát"
                                    data-id="@a.Id" data-code="@a.LanguageCode" data-script="@a.Script"
                                    onclick="handlePlayClick(this)"
                                    id="btn-play-@a.Id">
                                <i class="bi bi-play-fill"></i>
                            </button>
                            <button type="button" class="btn btn-ghost btn-sm btn-icon" title="Tạm dừng"
                                    onclick="rowPause(@a.Id)" style="display:none" id="btn-pause-@a.Id">
                                <i class="bi bi-pause-fill"></i>
                            </button>
                            <button type="button" class="btn btn-ghost btn-sm btn-icon" title="Tiếp tục"
                                    onclick="rowResume(@a.Id)" style="display:none" id="btn-resume-@a.Id">
                                <i class="bi bi-play-circle-fill"></i>
                            </button>
                            <button type="button" class="btn btn-ghost btn-sm btn-icon text-danger" title="Dừng"
                                    onclick="rowStop(@a.Id)" style="display:none" id="btn-stop-@a.Id">
                                <i class="bi bi-stop-fill"></i>
                            </button>
                        </div>
                    </td>
                    <td>
                        <div class="action-group">
                            <button type="button" class="btn btn-ghost btn-sm btn-icon" title="Sửa"
                                    data-id="@a.Id"
                                    data-poiid="@a.PoiId"
                                    data-langid="@a.LanguageId"
                                    data-poiname="@(a.PoiName ?? "")"
                                    data-langdisplay="@a.LanguageCode @a.LanguageName"
                                    data-script="@a.Script"
                                    onclick="handleEditClick(this)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-ghost btn-sm btn-icon text-danger" title="Xóa"
                                    onclick="confirmDelete(@a.Id, '@(a.PoiName ?? $"#{a.PoiId}")', '@a.LanguageName')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="addModal" class="modal-backdrop" style="display:none">
    <div class="modal-box">
        <div class="modal-header">
            <h4>Thêm Audio</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeAddModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div id="allCoveredMsg" style="display:none;text-align:center;padding:40px 20px">
            <div style="font-size:48px;color:#cbd5e1;margin-bottom:12px"><i class="bi bi-check-circle"></i></div>
            <h3 style="margin-bottom:8px">Đã có đủ audio!</h3>
            <p style="color:#64748b">Tất cả các điểm thuyết minh đã có audio cho mọi ngôn ngữ đang hoạt động.</p>
            <button type="button" class="btn btn-ghost" style="margin-top:16px" onclick="closeAddModal()">Đóng</button>
        </div>
        <div id="addForm">
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="0" />
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">Điểm thuyết minh <span style="color:#dc3545">*</span></label>
                        <select name="PoiId" id="aPoiId" class="form-control" required onchange="onPoiChange()">
                            <option value="">-- Chọn điểm --</option>
                            @foreach (var p in Model.PoisForAdd)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Ngôn ngữ <span style="color:#dc3545">*</span></label>
                        <select name="LanguageId" id="aLangId" class="form-control" required>
                            <option value="">-- Chọn ngôn ngữ --</option>
                            @foreach (var l in Model.Languages)
                            {
                                <option value="@l.Id" data-code="@l.Code">@l.Code.ToUpper() — @l.Name</option>
                            }
                        </select>
                        <div class="form-hint" id="aLangHint" style="color:#dc2626;display:none">
                            Ngôn ngữ này đã có audio cho điểm này rồi.
                        </div>
                    </div>
                    <div class="form-group">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                            <label class="form-label" style="margin:0">Script <span style="color:#dc3545">*</span></label>
                            <div style="display:flex;gap:6px;align-items:center">
                                <select id="aSourceLang" class="form-control" style="font-size:11px;padding:2px 6px;width:auto;height:auto">
                                    @foreach (var l in Model.Languages)
                                    {
                                        <option value="@l.Code">@l.Code.ToUpper()</option>
                                    }
                                </select>
                                <span style="font-size:11px;color:#9ca3af">→</span>
                                <button type="button" class="btn btn-xs btn-outline" onclick="autoTranslate()" id="aBtnTrans">
                                    <i class="bi bi-translate"></i> Dịch
                                </button>
                                <button type="button" class="btn btn-xs btn-outline" onclick="previewFromTextarea('aScript','aLangId')" id="aBtnPlay">
                                    <i class="bi bi-play-fill"></i> Nghe thử
                                </button>
                            </div>
                        </div>
                        <textarea name="Script" id="aScript" class="form-control" rows="4"
                                  placeholder="Nhập script rồi chọn ngôn ngữ nguồn và bấm Dịch..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" onclick="closeAddModal()">Huỷ</button>
                    <button type="submit" class="btn btn-primary" id="aBtnSubmit"><i class="bi bi-check-lg"></i> Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="editModal" class="modal-backdrop" style="display:none">
    <div class="modal-box">
        <div class="modal-header">
            <h4 id="editModalTitle">Sửa Audio</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeEditModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="eId" />
            <input type="hidden" name="PoiId" id="ePoiId" />
            <input type="hidden" name="LanguageId" id="eLangId" />
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Điểm thuyết minh</label>
                    <input type="text" id="ePoiName" class="form-control" disabled style="opacity:.6" />
                </div>
                <div class="form-group">
                    <label class="form-label">Ngôn ngữ</label>
                    <input type="text" id="eLangName" class="form-control" disabled style="opacity:.6" />
                </div>
                <div class="form-group">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                        <label class="form-label" style="margin:0">Script <span style="color:#dc3545">*</span></label>
                        <div style="display:flex;gap:6px;align-items:center">
                            <select id="eSourceLang" class="form-control" style="font-size:11px;padding:2px 6px;width:auto;height:auto">
                                @foreach (var l in Model.Languages)
                                {
                                    <option value="@l.Code">@l.Code.ToUpper()</option>
                                }
                            </select>
                            <span style="font-size:11px;color:#9ca3af">→</span>
                            <button type="button" class="btn btn-xs btn-outline" onclick="autoTranslateEdit()">
                                <i class="bi bi-translate"></i> Dịch
                            </button>
                            <button type="button" class="btn btn-xs btn-outline" onclick="previewFromTextarea('eScript','eLangIdHidden')">
                                <i class="bi bi-play-fill"></i> Nghe thử
                            </button>
                        </div>
                        <input type="hidden" id="eLangIdHidden" />
                        <input type="hidden" id="eLangCode" />
                    </div>
                    <textarea name="Script" id="eScript" class="form-control" rows="4" required></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeEditModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cập nhật</button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="modal-backdrop" style="display:none" onclick="closeDelete()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4>Xác nhận xóa</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeDelete()"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="modal-body">
            <p>Xóa audio <strong id="delLang"></strong> của <strong id="delPoi"></strong>?</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-ghost" onclick="closeDelete()">Huỷ</button>
            <form method="post" asp-page-handler="Delete" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DeleteId" id="fDelId" />
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Xóa</button>
            </form>
        </div>
    </div>
</div>

<script>
    const API_BASE = document.getElementById('apiBaseUrl').value;
    // Cấu hình danh sách Giọng đọc chuẩn cho tính năng Nghe Thử TTS.
    // Nếu thêm ngôn ngữ mới, hãy khai báo vào đây:
    const VOICE_MAP = {
        vi: ['Microsoft HoaiMy', 'Google Vietnamese', 'vi-VN'],
        en: ['Microsoft Aria', 'Google US English', 'en-US'],
        ja: ['Microsoft Nanami', 'Google 日本語', 'ja-JP'],
        zh: ['Microsoft Xiaoxiao', 'Google 普通话', 'zh-CN'],
        ko: ['Microsoft SunHi', 'Google 한국의', 'ko-KR'],
        fr: ['Microsoft Denise', 'Google français', 'fr-FR'],
        de: ['Microsoft Katja', 'Google Deutsch', 'de-DE'],
        th: ['Google ไทย', 'th-TH']
    };

    // Danh sách audio hiện có để check trùng
    const EXISTING_AUDIOS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                Model.Audios.Select(a => new { poiId = a.PoiId, languageId = a.LanguageId })
                ));

    function onPoiChange() {
        const poiId = parseInt(document.getElementById('aPoiId').value);
        const langSel = document.getElementById('aLangId');
        const usedLangIds = EXISTING_AUDIOS
            .filter(a => a.poiId === poiId)
            .map(a => a.languageId);

        Array.from(langSel.options).forEach(opt => {
            if (!opt.value) return;
            const used = usedLangIds.includes(parseInt(opt.value));
            opt.disabled = used;
            opt.text = used
                ? opt.text.replace(' ✓', '') + ' ✓'
                : opt.text.replace(' ✓', '');
        });

        if (usedLangIds.includes(parseInt(langSel.value))) {
            langSel.value = '';
        }
    }

    const ALL_COVERED = @Html.Raw(Model.AllCovered.ToString().ToLower());

    function openAddModal() {
        if (ALL_COVERED) {
            document.getElementById('allCoveredMsg').style.display = '';
            document.getElementById('addForm').style.display = 'none';
        } else {
            document.getElementById('allCoveredMsg').style.display = 'none';
            document.getElementById('addForm').style.display = '';
            document.getElementById('aPoiId').value = '';
            document.getElementById('aLangId').value = '';
            document.getElementById('aScript').value = '';
            Array.from(document.getElementById('aLangId').options).forEach(o => {
                o.disabled = false;
                o.text = o.text.replace(' ✓', '');
            });
        }
        document.getElementById('addModal').style.display = 'flex';
    }

    // Đã thêm lại cancel() để tắt TTS khi đóng form
    function closeAddModal() {
        window.speechSynthesis.cancel();
        document.getElementById('addModal').style.display = 'none';
    }

    // Các hàm hỗ trợ click an toàn qua thẻ data-*
    function handlePlayClick(btn) {
        rowPlay(btn.dataset.id, btn.dataset.code, btn.dataset.script);
    }

    function handleEditClick(btn) {
        openEditModal(
            btn.dataset.id,
            btn.dataset.poiid,
            btn.dataset.langid,
            btn.dataset.script,
            btn.dataset.poiname,
            btn.dataset.langdisplay
        );
    }

    function openEditModal(id, poiId, langId, script, poiName, langDisplay) {
        document.getElementById('eId').value = id;
        document.getElementById('ePoiId').value = poiId;
        document.getElementById('eLangId').value = langId;
        document.getElementById('eLangIdHidden').value = langId;
        document.getElementById('ePoiName').value = poiName;
        document.getElementById('eLangName').value = langDisplay;
        document.getElementById('eScript').value = script;
        document.getElementById('editModalTitle').textContent = 'Sửa Audio — ' + poiName;

        const opt = document.querySelector(`#aLangId option[value="${langId}"]`);
        document.getElementById('eLangCode').value = opt ? opt.dataset.code : '';

        document.getElementById('editModal').style.display = 'flex';
    }

    // Đã thêm lại cancel() để tắt TTS khi đóng form
    function closeEditModal() {
        window.speechSynthesis.cancel();
        document.getElementById('editModal').style.display = 'none';
    }

    function confirmDelete(id, poiName, langName) {
        document.getElementById('fDelId').value = id;
        document.getElementById('delPoi').textContent = poiName;
        document.getElementById('delLang').textContent = langName;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDelete() { document.getElementById('deleteModal').style.display = 'none'; }

    let _rowId = null, _rowLang = '', _rowSentences = [], _rowSentIdx = 0;
    let _rowSession = 0;

    function rowPlay(id, langCode, text) {
        if (_rowId && _rowId !== id) rowStop(_rowId);
        _rowId = id; _rowLang = langCode;
        _rowSentences = text.match(/[^.!?。！？\n]+[.!?。！？]*/g) || [text];
        _rowSentIdx = 0;
        window.speechSynthesis.cancel();
        _rowSession++;
        _rowSpeakFrom(0, _rowSession);
    }

    function _rowSpeakFrom(idx, session) {
        if (session !== _rowSession) return;
        if (idx >= _rowSentences.length) {
            _setRowState(_rowId, 'idle');
            return;
        }
        _rowSentIdx = idx;
        const u = new SpeechSynthesisUtterance(_rowSentences[idx]);
        _applyVoice(u, _rowLang);
        const capturedId = _rowId;
        u.onend = () => _rowSpeakFrom(idx + 1, session);
        u.onerror = e => {
            if (session !== _rowSession) return;
            if (e.error !== 'interrupted') _setRowState(capturedId, 'idle');
        };
        _setRowState(_rowId, 'playing');
        window.speechSynthesis.speak(u);
    }

    function rowPause(id) {
        window.speechSynthesis.pause();
        _setRowState(id, 'paused');
    }

    function rowResume(id) {
        window.speechSynthesis.resume();
        _setRowState(id, 'playing');
    }

    function rowStop(id) {
        _rowSession++;
        window.speechSynthesis.cancel();
        _rowId = null;
        _setRowState(id, 'idle');
    }

    function _setRowState(id, state) {
        const shown = {
            idle:    ['play'],
            playing: ['pause','stop'],
            paused:  ['resume','stop']
        }[state] || ['play'];
        ['play','pause','resume','stop'].forEach(s => {
            const el = document.getElementById(`btn-${s}-${id}`);
            if (el) el.style.display = shown.includes(s) ? '' : 'none';
        });
    }

    function _applyVoice(u, langCode) {
        const prefs = VOICE_MAP[langCode] || [langCode||'en-US'];
        const voices = window.speechSynthesis.getVoices();
        const voice = voices.find(v => prefs.some(p => v.name.includes(p)||v.lang.startsWith(p)));
        if (voice) u.voice = voice;
        u.lang = prefs[prefs.length-1];
        u.rate = 0.95;
    }

    function previewFromTextarea(textareaId, langSelectId) {
        const text = document.getElementById(textareaId)?.value?.trim();
        if (!text) { alert('Chưa có script.'); return; }
        const sel = document.getElementById(langSelectId);
        let code = '';
        if (sel) {
            if (sel.tagName === 'SELECT') {
                const opt = sel.options[sel.selectedIndex];
                code = opt?.dataset?.code || '';
            } else {
                const langId = sel.value;
                const opt = document.querySelector(`#aLangId option[value="${langId}"]`);
                code = opt?.dataset?.code || '';
            }
        }
        previewTTS(code, text);
    }

    function previewTTS(langCode, text) {
        if (!text) { alert('Chưa có script.'); return; }
        window.speechSynthesis.cancel();
        const u = new SpeechSynthesisUtterance(text);
        _applyVoice(u, langCode);
        window.speechSynthesis.speak(u);
    }

    document.addEventListener('DOMContentLoaded', () => {
        if ('speechSynthesis' in window) {
            window.speechSynthesis.getVoices();
            window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();
        }
    });

    function onLangChange(prefix) { }

    async function autoTranslate() {
        const langId = document.getElementById('aLangId').value;
        if (!langId) { alert('Vui lòng chọn ngôn ngữ đích trước.'); return; }
        const sourceText = document.getElementById('aScript').value.trim();
        if (!sourceText) { alert('Vui lòng nhập script nguồn vào ô Script trước.'); return; }

        const sourceLang = document.getElementById('aSourceLang').value;
        const opt = document.querySelector(`#aLangId option[value="${langId}"]`);
        const targetCode = opt?.dataset?.code || '';
        if (sourceLang === targetCode) { alert('Ngôn ngữ nguồn và đích giống nhau.'); return; }

        const btn = document.getElementById('aBtnTrans');
        btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang dịch...';
        try {
            const translated = await translateText(sourceText, sourceLang, targetCode);
            document.getElementById('aScript').value = translated;
        } catch (e) {
            alert('Lỗi dịch: ' + e.message);
        } finally {
            btn.disabled = false; btn.innerHTML = '<i class="bi bi-translate"></i> Dịch';
        }
    }

    async function autoTranslateEdit() {
        const sourceText = document.getElementById('eScript').value.trim();
        if (!sourceText) { alert('Vui lòng nhập script nguồn trước.'); return; }
        const sourceLang = document.getElementById('eSourceLang').value;
        const targetCode = document.getElementById('eLangCode').value;
        if (!targetCode) { alert('Không xác định được ngôn ngữ đích.'); return; }
        if (sourceLang === targetCode) { alert('Ngôn ngữ nguồn và đích giống nhau.'); return; }
        try {
            const translated = await translateText(sourceText, sourceLang, targetCode);
            document.getElementById('eScript').value = translated;
        } catch (e) {
            alert('Lỗi dịch: ' + e.message);
        }
    }

    async function translateText(text, sourceLang, targetLang) {
        const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=${sourceLang}&tl=${targetLang}&dt=t&q=${encodeURIComponent(text)}`;
        const res = await fetch(url);
        const data = await res.json();
        return data[0].map(x => x[0]).join('');
    }

    function filterAudio() {
        const poi  = document.getElementById('searchPoi').value.trim().toLowerCase();
        const lang = document.getElementById('searchLang').value.toLowerCase();
        const rows = document.querySelectorAll('#audioTable tbody tr[data-poi]');
        let shown = 0;
        rows.forEach(row => {
            const matchPoi  = !poi  || row.dataset.poi.includes(poi);
            const matchLang = !lang || row.dataset.lang === lang;
            const show = matchPoi && matchLang;
            row.style.display = show ? '' : 'none';
            if (show) shown++;
        });
        const cnt = document.getElementById('audioCount');
        if (cnt) cnt.textContent = shown + '/' + rows.length + ' kết quả';
    }

    document.addEventListener('DOMContentLoaded', () => {
        filterAudio();
    });

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') { closeAddModal(); closeEditModal(); closeDelete(); }
    });
</script>