    async function saveEditExtra(id) {
        const script = document.getElementById('eeScript-' + id)?.value || '';
        const res = await fetch(`${API_BASE}audio-extra/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
