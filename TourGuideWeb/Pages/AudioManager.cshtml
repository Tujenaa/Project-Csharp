            }
        } catch (e) { alert('Lỗi kết nối.'); }
        finally { btn.disabled = false; btn.innerHTML = '<i class="bi bi-plus-lg"></i> Thêm ngôn ngữ'; }
    }

    async function saveExtra(id) {
        const script = document.getElementById('script-' + id)?.value || '';
        const res = await fetch(`${API_BASE}audio-extra/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ script })
        });
        if (res.ok) {
            const row = document.getElementById('extra-row-' + id);
            if (row) { row.style.borderColor = '#059669'; setTimeout(() => row.style.borderColor = '#e5e7eb', 1000); }
        } else alert('Lưu thất bại.');
    }

    async function deleteExtra(id) {
        if (!confirm('Xóa ngôn ngữ này?')) return;
        const res = await fetch(`${API_BASE}audio-extra/${id}`, { method: 'DELETE' });
        if (res.ok) await loadExtraList();
        else alert('Xóa thất bại.');
    }

    async function autoTranslateExtra() {
        const code = document.getElementById('newLangCode').value.trim();
        if (!code) { alert('Nhập mã ngôn ngữ trước (vd: ko, fr).'); return; }
        if (!_extraViScript) { alert('Audio chưa có script tiếng Việt.'); return; }
        const btn = document.getElementById('btnTransExtra');
        btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang dịch...';
        try {
            const result = await translateText(_extraViScript, code);
            document.getElementById('newLangScript').value = result;
        } catch (e) { alert('Lỗi dịch.'); }
        finally { btn.disabled = false; btn.innerHTML = '<i class="bi bi-translate"></i> Dịch từ tiếng Việt'; }
    }

    function previewExtra(langCode, script) {
        if (!script) { alert('Chưa có script.'); return; }
        window.speechSynthesis.cancel();
        makeUtterance(script, langCode).then(u => window.speechSynthesis.speak(u));
    }

    document.addEventListener('DOMContentLoaded', async () => {
        for (const a of AUDIOS) {
            try {
                const res = await fetch(`${API_BASE}audio-extra/audio/${a.id}`);
                const list = await res.json();
                if (list.length > 0) updateRowDropdown(a.id, list);
            } catch {}
        }
    });
</script>
