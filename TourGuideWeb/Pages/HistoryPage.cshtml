@page
@model GPSGuide.Web.Pages.HistoryPageModel
@{

    ViewData["Title"] = "Lịch sử phát";
    ViewData["Active"] = "history";

    ViewData["Title"] = "Lịch sử phát"; ViewData["Active"] = "history";
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
<div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}
@if (!string.IsNullOrEmpty(Model.Error))
{
<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> @Model.Error</div>
}


<div class="page-header">
    <div>
        <h2>Lịch sử phát</h2>
        <div class="sub">Toàn bộ lượt thuyết minh đã được kích hoạt</div>
    </div>
    <button class="btn btn-primary" onclick="openModal()">
        <i class="bi bi-plus-lg"></i> Thêm thủ công
    </button>
</div>

<div style="display:flex;gap:16px;margin-bottom:1.5rem">
    <div class="stat-mini">
        <div class="stat-mini-val">@Model.History.Count</div>
        <div class="stat-mini-label">Tổng lượt phát</div>
    </div>
    <div class="stat-mini">
        <div class="stat-mini-val">@Model.History.Select(h => h.PoiId).Distinct().Count()</div>
        <div class="stat-mini-label">POI đã phát</div>
    </div>
    <div class="stat-mini">
    
        <div class="stat-mini-val">
            @(Model.History.Any() ? Model.History.First().PlayTime.ToString("dd/MM/yyyy") : "—")
        </div>
        
        <div class="stat-mini-val">@(Model.History.Any() ? Model.History.First().PlayTime.ToString("dd/MM/yyyy") : "—")</div>
  
        <div class="stat-mini-label">Lần gần nhất</div>
    </div>
</div>

<div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;
                padding:.875rem 1rem;border-bottom:1px solid #e5e7eb">
        
        <div style="display:flex;justify-content:space-between;align-items:center;padding:.875rem 1rem;border-bottom:1px solid #e5e7eb">
        
            <span style="font-weight:500"><i class="bi bi-clock-history"></i> Chi tiết lịch sử</span>
            <input type="text" id="searchInput" class="form-control" style="width:220px"
                   placeholder="Tìm kiếm POI..." oninput="filterTable()" />
        </div>
        <table class="tg-table" id="histTable">
            <thead>
            
                <tr>
                    <th>ID</th>
                    <th>Điểm POI</th>
                    <th>Thời gian phát</th>
                    <th>Hành động</th>
                </tr>
                
                <tr><th>ID</th><th>Điểm POI</th><th>Thời gian phát</th><th>Hành động</th></tr>

            </thead>
            <tbody>
                @foreach (var h in Model.History)
                                {
                <tr data-search="@(h.PoiName?.ToLower() ?? "")">
                    <td class="text-muted">#@h.Id</td>
                    <td style="font-weight:500">@(h.PoiName ?? $"POI #{h.PoiId}")</td>
                    <td class="text-muted">@h.PlayTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>
                        <button class="btn btn-ghost btn-sm btn-icon text-danger" title="Xoá"
                                onclick="confirmDelete(@h.Id)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
                                }
                @if (!Model.History.Any())
                                {
            
                
                
                <tr>
                    <td colspan="4" class="empty-state">Chưa có lịch sử phát.</td>
                </tr>
                                
                                <tr><td colspan="4" class="empty-state">Chưa có lịch sử phát.</td></tr>
                       
                                }
            </tbody>
        </table>
    </div>

  
    <!-- ===== MODAL THÊM THỦ CÔNG ===== -->
    <div id="addModal" class="modal-backdrop" style="display:none"
         onclick="if(event.target===this)closeModal()">
        <div class="modal-box modal-sm" onclick="event.stopPropagation()">
            <div class="modal-header">
                <h4>Thêm lịch sử thủ công</h4>
                <button type="button" class="btn btn-ghost btn-icon" onclick="closeModal()">
                    <i class="bi bi-x-lg"></i>
                </button>
                
                <div id="addModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)closeModal()">
                    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
                        <div class="modal-header">
                            <h4>Thêm lịch sử thủ công</h4>
                            <button type="button" class="btn btn-ghost btn-icon" onclick="closeModal()"><i class="bi bi-x-lg"></i></button>
                         
                        </div>
                        <form method="post">
                            @Html.AntiForgeryToken()
                            <div class="modal-body">
                                <div class="form-group">
                                  
                                    <label class="form-label">Điểm POI <span class="req">*</span></label>
                                    
                                    <label class="form-label">Điểm POI <span class="required">*</span></label>
                                
                                    <select name="PoiId" class="form-control" required>
                                        <option value="">-- Chọn POI --</option>
                                        @foreach (var p in Model.Pois)
                                                                                {
                                        <option value="@p.Id">@p.Name</option>
                                                                                }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Thời gian</label>
                                    <input type="datetime-local" name="PlayTime" class="form-control"
                                           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-ghost" onclick="closeModal()">Huỷ</button>
                                
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-lg"></i> Lưu
                                </button>
                                
                                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu</button>
                               
                            </div>
                        </form>
                    </div>
                </div>

             
                <!-- ===== MODAL XOÁ ===== -->
                <div id="delModal" class="modal-backdrop" style="display:none"
                     onclick="if(event.target===this)closeDelete()">
                    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
                        <div class="modal-header">
                            <h4>Xác nhận xoá</h4>
                            <button type="button" class="btn btn-ghost btn-icon" onclick="closeDelete()">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <div class="modal-body">
                            <p>Xoá bản ghi lịch sử này?</p>
                            <p class="text-muted" style="font-size:13px">Thao tác này không thể hoàn tác.</p>
                        </div>
                        
                        <div id="delModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)closeDelete()">
                            <div class="modal-box modal-sm" onclick="event.stopPropagation()">
                                <div class="modal-header">
                                    <h4>Xác nhận xoá</h4>
                                    <button type="button" class="btn btn-ghost btn-icon" onclick="closeDelete()"><i class="bi bi-x-lg"></i></button>
                                </div>
                                <div class="modal-body"><p>Xoá bản ghi lịch sử này?</p></div>
                           
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-ghost" onclick="closeDelete()">Huỷ</button>
                                    <form method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="DeleteId" id="fDelId" />
                                   
                                        <button type="submit" asp-page-handler="Delete" class="btn btn-danger">
                                            <i class="bi bi-trash"></i> Xoá
                                        </button>
                                        
                                        <button type="submit" asp-page-handler="Delete" class="btn btn-danger"><i class="bi bi-trash"></i> Xoá</button>
                                      
                                    </form>
                                </div>
                            </div>
                        </div>

                        <style>
                            .stat-mini {
                                background: #f9fafb;
                                border: 1px solid #e5e7eb;
                                border-radius: 8px;
                                padding: .75rem 1.25rem;
                                flex: 1;
                                text-align: center
                            }

                            .stat-mini-val {
                                font-size: 22px;
                                font-weight: 600;
                                color: #111
                            }

                            .stat-mini-label {
                                font-size: 12px;
                                color: #888;
                                margin-top: 2px
                            }

                      
                            /* Fix chữ đen trong form */
                            .form-control {
                                color: #212529 !important;
                                background-color: #ffffff !important;
                            }

                            .form-control::placeholder {
                                color: #9ca3af !important;
                                opacity: 1;
                            }
                        </style>

                        <script>
                            function openModal()  { document.getElementById('addModal').style.display = 'flex'; }
                            function closeModal() { document.getElementById('addModal').style.display = 'none'; }

                            function confirmDelete(id) {
                                document.getElementById('fDelId').value = id;
                                document.getElementById('delModal').style.display = 'flex';
                            }
                            function closeDelete() { document.getElementById('delModal').style.display = 'none'; }

                            function filterTable() {
                                const q = document.getElementById('searchInput').value.toLowerCase();
                                document.querySelectorAll('#histTable tbody tr[data-search]').forEach(r => {
                                    r.style.display = r.dataset.search.includes(q) ? '' : 'none';
                                });
                            }

                            document.addEventListener('keydown', e => {
                                if (e.key === 'Escape') { closeModal(); closeDelete(); }
                            });
                        </script>
                        
</style>
                        <script>
                            function openModal(){ document.getElementById('addModal').style.display='flex'; }
                            function closeModal(){ document.getElementById('addModal').style.display='none'; }
                            function confirmDelete(id){ document.getElementById('fDelId').value=id; document.getElementById('delModal').style.display='flex'; }
                            function closeDelete(){ document.getElementById('delModal').style.display='none'; }
                            function filterTable(){
                                const q=document.getElementById('searchInput').value.toLowerCase();
                                document.querySelectorAll('#histTable tbody tr[data-search]').forEach(r=>{
                                    r.style.display=r.dataset.search.includes(q)?'':'none';
                                });
                            }
                            document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeModal();closeDelete();}});
                        </script>
                      
