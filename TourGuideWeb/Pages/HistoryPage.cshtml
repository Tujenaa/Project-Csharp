@page
@model GPSGuide.Web.Pages.HistoryPageModel
@{
    ViewData["Title"] = "Lịch sử phát"; ViewData["Active"] = "history";
    var stats = Model.PoiStats;
    var maxCount = stats.Any() ? stats.First().PlayCount : 1;
    var topPoi = Model.IsAdmin ? stats.FirstOrDefault() : null;
    var allHistorySorted = Model.AllHistory.OrderByDescending(h => h.PlayTime).ToList();

    string FormatDuration(double seconds)
    {
        if (seconds < 60) return $"{(int)seconds}s";
        var m = (int)seconds / 60;
        var s = (int)seconds % 60;
        return s > 0 ? $"{m}ph {s}s" : $"{m}ph";
    }
    string FormatDurationInt(int seconds) => FormatDuration(seconds);
}

@section Styles {
    <link rel="stylesheet" href="~/css/history.css" asp-append-version="true" />
}

<div class="page-header">
    <div><h2>Lịch sử phát</h2></div>
</div>

@* ── Summary strip ── *@
<div class="hs-strip">
    <div class="hs-item">
        <span class="hs-val">@Model.TotalCount</span>
        <span class="hs-lbl"><i class="bi bi-play-circle-fill"></i> Tổng lượt phát</span>
    </div>
    <div class="hs-sep"></div>
    <div class="hs-item">
        <span class="hs-val">@FormatDurationInt(Model.TotalDuration)</span>
        <span class="hs-lbl"><i class="bi bi-hourglass-split"></i> Tổng thời gian nghe</span>
    </div>
    <div class="hs-sep"></div>
    <div class="hs-item">
        <span class="hs-val">@FormatDuration(Model.AverageDuration)</span>
        <span class="hs-lbl"><i class="bi bi-stopwatch"></i> Nghe trung bình</span>
    </div>
    <div class="hs-sep"></div>
    <div class="hs-item">
        <span class="hs-val">@(Model.LatestHistory.Any() ? Model.LatestHistory.First().PlayTime.ToString("dd/MM") : "—")</span>
        <span class="hs-lbl"><i class="bi bi-calendar3"></i> Lần gần nhất</span>
    </div>
    @if (Model.IsAdmin && topPoi != null)
    {
        <div class="hs-sep"></div>
        <div class="hs-item hs-item--top">
            <span class="hs-val hs-val--top" title="@topPoi.Name">@topPoi.Name</span>
            <span class="hs-lbl"><i class="bi bi-trophy-fill"></i> POI phổ biến nhất · @topPoi.PlayCount lượt</span>
        </div>
    }
    @if (!Model.IsAdmin && Model.OwnerTopRank.HasValue)
    {
        var otr = Model.OwnerTopRank.Value;
        var oRankIcon = otr.Rank == 1 ? "bi-trophy-fill" : otr.Rank == 2 ? "bi-award-fill" : otr.Rank == 3 ? "bi-patch-check-fill" : "bi-bar-chart-line-fill";
        var oRankColor = otr.Rank == 1 ? "#b45309" : otr.Rank == 2 ? "#475569" : otr.Rank == 3 ? "#c2410c" : "#7c3aed";
        <div class="hs-sep"></div>
        <div class="hs-item hs-item--top">
            <span class="hs-val hs-val--top" title="@otr.Poi.Name">
                <i class="bi @oRankIcon" style="color:@oRankColor;margin-right:3px"></i>#@otr.Rank · @otr.Poi.Name
            </span>
            <span class="hs-lbl"><i class="bi bi-bar-chart-line-fill"></i> POI xếp hạng cao nhất · @otr.Poi.PlayCount lượt</span>
        </div>
    }
</div>

@* ── Tab bar ── *@
<div class="hist-tabs">
    <button class="hist-tab active" id="tab-all" onclick="switchTab('all')">
        <i class="bi bi-clock-history"></i> Tất cả lịch sử
    </button>
    <button class="hist-tab" id="tab-rank" onclick="switchTab('rank')">
        <i class="bi bi-bar-chart-line-fill"></i> Xếp hạng địa điểm
    </button>
</div>

@* ── TAB 1: Tất cả lịch sử ── *@
<div class="card hist-card" id="panel-all">
    <div class="hist-card-hd">
        <span><i class="bi bi-clock-history"></i> Tất cả lịch sử phát</span>
        <input type="text" id="searchAll" class="form-control hist-search"
               placeholder="Tìm kiếm..." oninput="filterAll()" />
    </div>

    @if (!allHistorySorted.Any())
    {
        <div class="hist-empty">
            <i class="bi bi-inbox"></i>
            <p>Chưa có lịch sử phát.</p>
        </div>
    }
    else
    {
        <table class="poi-detail-table" id="allList">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Điểm POI</th>
                    @if (Model.IsAdmin)
                    {
                        <th>Người dùng</th>
                    }
                    <th>Thời điểm phát</th>
                    <th>Thời lượng</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < allHistorySorted.Count; i++)
                {
                    var h = allHistorySorted[i];
                    <tr data-search="@((h.PoiName?.ToLower() ?? "") + " " + (h.UserFullName?.ToLower() ?? "") + " " + (h.UserLogin?.ToLower() ?? ""))">
                        <td class="text-muted" style="font-size:12px;width:36px">@(i + 1)</td>
                        <td>
                            <span class="poi-name" style="font-size:13px">@(h.PoiName ?? $"POI #{h.PoiId}")</span>
                            <span class="poi-id text-muted">#@h.PoiId</span>
                        </td>
                        @if (Model.IsAdmin)
                        {
                            <td>
                                <span class="det-user">@(h.UserFullName ?? "—")</span>
                                <span class="text-muted det-login">@(h.UserLogin != null ? "@" + h.UserLogin : "")</span>
                            </td>
                        }
                        <td class="text-muted" style="font-size:12px;white-space:nowrap">@h.PlayTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td><span class="duration-badge"><i class="bi bi-stopwatch"></i> @FormatDurationInt(h.ListenDuration)</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@* ── TAB 2: Xếp hạng ── *@
<div class="card hist-card" id="panel-rank" style="display:none">
    <div class="hist-card-hd">
        <span><i class="bi bi-bar-chart-line-fill"></i> Xếp hạng địa điểm theo lượt nghe</span>
        <input type="text" id="searchRank" class="form-control hist-search"
               placeholder="Tìm kiếm..." oninput="filterRank()" />
    </div>

    @if (!stats.Any())
    {
        <div class="hist-empty">
            <i class="bi bi-inbox"></i>
            <p>Chưa có dữ liệu xếp hạng.</p>
        </div>
    }
    else
    {
        <ul class="poi-list" id="rankList">
            @for (int i = 0; i < stats.Count; i++)
            {
                var poi = stats[i];
                var rawPct = maxCount > 0 ? (poi.PlayCount * 100.0 / maxCount) : 0;
                var pct = rawPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                var rankClass = i == 0 ? "rank--gold" : i == 1 ? "rank--silver" : i == 2 ? "rank--bronze" : "rank--default";
                var rankIcon = i == 0 ? "bi-trophy-fill" : i == 1 ? "bi-award-fill" : i == 2 ? "bi-patch-check-fill" : "bi-headphones";

                <li class="poi-item" data-search="@poi.Name.ToLower()">
                    <div class="poi-row">
                        <div class="poi-rank @rankClass">
                            <i class="bi @rankIcon"></i>
                            <span>@(i + 1)</span>
                        </div>
                        <div class="poi-info">
                            <div class="poi-name-row">
                                <span class="poi-name">@poi.Name</span>
                                <span class="poi-id text-muted">#@poi.PoiId</span>
                            </div>
                            <div class="poi-bar-wrap">
                                <div class="poi-bar @(i == 0 ? "poi-bar--gold" : "")" style="width:@(pct)%"></div>
                            </div>
                            <div class="poi-meta">
                                <i class="bi bi-clock"></i> Lần cuối: @poi.LastPlay.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                        <div class="poi-stat-col">
                            <span class="poi-stat-val @(i == 0 ? "poi-stat-val--gold" : "")">@poi.PlayCount</span>
                            <span class="poi-stat-lbl">Lượt phát</span>
                        </div>
                        <div class="poi-stat-col poi-stat-col--avg">
                            <span class="poi-stat-val poi-stat-val--indigo">@poi.AvgInterval</span>
                            <span class="poi-stat-lbl">Nghe TB</span>
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</div>

<script>
    function switchTab(tab) {
        document.getElementById('panel-all').style.display  = tab === 'all'  ? '' : 'none';
        document.getElementById('panel-rank').style.display = tab === 'rank' ? '' : 'none';
        document.getElementById('tab-all').classList.toggle('active',  tab === 'all');
        document.getElementById('tab-rank').classList.toggle('active', tab === 'rank');
    }

    function filterAll() {
        const q = document.getElementById('searchAll').value.toLowerCase();
        document.querySelectorAll('#allList tbody tr[data-search]').forEach(el => {
            el.style.display = el.dataset.search.includes(q) ? '' : 'none';
        });
    }

    function filterRank() {
        const q = document.getElementById('searchRank').value.toLowerCase();
        document.querySelectorAll('#rankList li[data-search]').forEach(el => {
            el.style.display = el.dataset.search.includes(q) ? '' : 'none';
        });
    }
</script>
