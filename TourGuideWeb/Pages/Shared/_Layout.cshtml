<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GPSGuide CMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f1f5f9;
            color: #1e293b;
            display: flex;
            min-height: 100vh;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 240px;
            min-width: 240px;
            background: #0f172a;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
        }

        .sidebar-logo {
            padding: 20px 18px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid #1e293b;
            margin-bottom: 8px;
        }

        .sidebar-logo-icon {
            width: 36px;
            height: 36px;
            background: #3b82f6;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: white;
            flex-shrink: 0;
        }

        .sidebar-logo-text {
            line-height: 1.2;
        }

        .sidebar-logo-title {
            font-size: 15px;
            font-weight: 700;
            color: #f1f5f9;
        }

        .sidebar-logo-sub {
            font-size: 11px;
            color: #64748b;
        }

        .sidebar-section {
            padding: 6px 10px 2px;
            font-size: 10px;
            font-weight: 600;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: .08em;
            margin-top: 8px;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 14px;
            margin: 1px 8px;
            border-radius: 7px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            color: #94a3b8;
            transition: background .15s, color .15s;
        }

            .sidebar a:hover {
                background: #1e293b;
                color: #e2e8f0;
            }

            .sidebar a.active {
                background: #1d4ed8;
                color: #ffffff;
            }

                .sidebar a.active i {
                    color: #ffffff;
                }

            .sidebar a i {
                font-size: 16px;
                color: #64748b;
                transition: color .15s;
            }

            .sidebar a:hover i {
                color: #e2e8f0;
            }

        .sidebar-footer {
            margin-top: auto;
            padding: 14px 18px;
            border-top: 1px solid #1e293b;
            font-size: 12px;
            color: #475569;
        }

        /* ── Main ── */
        .main-wrap {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .topbar {
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            padding: 0 24px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .topbar-title {
            font-size: 15px;
            font-weight: 600;
            color: #1e293b;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .topbar-badge {
            background: #dbeafe;
            color: #1d4ed8;
            font-size: 12px;
            font-weight: 600;
            padding: 3px 10px;
            border-radius: 20px;
        }

        .topbar-avatar {
            width: 32px;
            height: 32px;
            background: #1d4ed8;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 13px;
            font-weight: 700;
        }

        .main-content {
            padding: 28px;
            flex: 1;
        }

        /* ── Card / Table chung ── */
        .card {
            background: #fff;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 3px rgba(0,0,0,.06);
            overflow: hidden;
        }

        .tg-table {
            width: 100%;
            border-collapse: collapse;
        }

            .tg-table th {
                background: #f8fafc;
                font-size: 12px;
                font-weight: 600;
                color: #64748b;
                text-transform: uppercase;
                letter-spacing: .05em;
                padding: 10px 14px;
                border-bottom: 1px solid #e2e8f0;
                text-align: left;
            }

            .tg-table td {
                padding: 11px 14px;
                border-bottom: 1px solid #f1f5f9;
                font-size: 14px;
            }

            .tg-table tbody tr:last-child td {
                border-bottom: none;
            }

            .tg-table tbody tr:hover td {
                background: #f8fafc;
            }

        /* ── Form controls ── */
        .form-control,
        .form-select,
        input.form-control,
        textarea.form-control,
        select.form-control {
            color: #1e293b !important;
            background-color: #ffffff !important;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 14px;
            padding: .45rem .75rem;
            width: 100%;
        }

            .form-control:focus, .form-select:focus {
                color: #1e293b !important;
                background-color: #ffffff !important;
                border-color: #3b82f6 !important;
                outline: none;
                box-shadow: 0 0 0 3px rgba(59,130,246,.15);
            }

            .form-control::placeholder {
                color: #9ca3af !important;
                opacity: 1;
            }

        /* ── Buttons chung ── */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: .45rem .9rem;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid transparent;
            transition: background .15s;
        }

        .btn-primary {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }

            .btn-primary:hover {
                background: #1d4ed8;
            }

        .btn-ghost {
            background: none;
            border-color: #d1d5db;
            color: #374151;
        }

            .btn-ghost:hover {
                background: #f3f4f6;
            }

        .btn-outline {
            background: none;
            border-color: #2563eb;
            color: #2563eb;
        }

            .btn-outline:hover {
                background: #eff6ff;
            }

        .btn-danger {
            background: #dc2626;
            color: #fff;
            border-color: #dc2626;
        }

            .btn-danger:hover {
                background: #b91c1c;
            }

        .btn-sm {
            padding: .3rem .65rem;
            font-size: 13px;
        }

        .btn-icon {
            padding: .35rem;
            border: none;
        }

            .btn-icon:hover {
                background: #f3f4f6;
                border-radius: 6px;
            }

        /* ── Alert ── */
        .alert {
            padding: .75rem 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        .alert-success {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            color: #166534;
        }

        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
        }

        /* ── Modal ── */
        .modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .modal-box {
            background: #fff;
            border-radius: 12px;
            width: 100%;
            max-width: 600px;
            max-height: 90vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 60px rgba(0,0,0,.2);
        }

            .modal-box.modal-lg {
                max-width: 740px;
            }

            .modal-box.modal-sm {
                max-width: 420px;
            }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid #e5e7eb;
            flex-shrink: 0;
        }

            .modal-header h4 {
                margin: 0;
                font-size: 16px;
                font-weight: 600;
            }

        .modal-body {
            padding: 1.25rem;
            overflow-y: auto;
            flex: 1;
        }

        .modal-footer {
            padding: .875rem 1.25rem;
            border-top: 1px solid #e5e7eb;
            display: flex;
            justify-content: flex-end;
            gap: .5rem;
            flex-shrink: 0;
        }

        /* ── Misc ── */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.5rem;
        }

            .page-header h2 {
                margin: 0;
                font-size: 20px;
                font-weight: 700;
            }

            .page-header .sub {
                color: #64748b;
                font-size: 13px;
                margin-top: 4px;
            }

        .text-muted {
            color: #64748b;
        }

        .text-danger {
            color: #dc2626;
        }

        .empty-state {
            text-align: center;
            padding: 2.5rem 1rem;
            color: #94a3b8;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 5px;
        }

        .form-hint {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 4px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .req {
            color: #e03;
        }

        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .badge-red {
            background: #fee2e2;
            color: #b91c1c;
        }
    </style>
</head>
<body>

    <!-- ── Sidebar ── -->
    <div class="sidebar">
        <div class="sidebar-logo">
            <div class="sidebar-logo-icon"><i class="bi bi-map-fill"></i></div>
            <div class="sidebar-logo-text">
                <div class="sidebar-logo-title">GPSGuide</div>
                <div class="sidebar-logo-sub">CMS Admin</div>
            </div>
        </div>

        <div class="sidebar-section">Tổng quan</div>
        <a href="/" class="@(ViewData["Active"]?.ToString() == "home" ? "active" : "")">
            <i class="bi bi-grid-1x2"></i> Dashboard
        </a>

        <div class="sidebar-section">Nội dung</div>
        <a href="/Pois" class="@(ViewData["Active"]?.ToString() == "pois" ? "active" : "")">
            <i class="bi bi-geo-alt"></i> Điểm thuyết minh
        </a>

        <div class="sidebar-section">Hệ thống</div>
        <a href="/HistoryPage" class="@(ViewData["Active"]?.ToString() == "history" ? "active" : "")">
            <i class="bi bi-clock-history"></i> Lịch sử phát
        </a>
        <a href="/Users" class="@(ViewData["Active"]?.ToString() == "users" ? "active" : "")">
            <i class="bi bi-people"></i> Người dùng
        </a>

        <div class="sidebar-footer">
            <div style="font-size:11px;color:#334155">v1.0.0 · GPSGuide CMS</div>
        </div>
    </div>

    <!-- ── Main ── -->
    <div class="main-wrap">
        <div class="topbar">
            <div class="topbar-title">
                <i class="bi bi-map me-2" style="color:#3b82f6"></i>
                @(ViewData["Title"]?.ToString() ?? "GPSGuide CMS")
            </div>
            <div class="topbar-right">
                <span class="topbar-badge"><i class="bi bi-shield-check me-1"></i>Admin</span>
                <div class="topbar-avatar">A</div>
            </div>
        </div>

        <div class="main-content">
            @RenderBody()
        </div>
    </div>

    <!-- ── TTS Engine ── -->
    <script>
        if (window.speechSynthesis) {
            window.speechSynthesis.getVoices();
            window.speechSynthesis.onvoiceschanged = function () {
                window._ttsVoices = window.speechSynthesis.getVoices();
            };
        }
        window.speakText = function (text, lang) {
            if (!window.speechSynthesis) { alert('Trình duyệt không hỗ trợ TTS'); return; }
            window.speechSynthesis.cancel();
            var utter = new SpeechSynthesisUtterance(text);
            utter.lang = lang || 'vi-VN';
            function doSpeak() {
                var voices = window.speechSynthesis.getVoices();
                var matched = voices.find(function(v){ return v.lang === utter.lang; })
                           || voices.find(function(v){ return v.lang.startsWith(utter.lang.split('-')[0]); });
                if (matched) utter.voice = matched;
                window.speechSynthesis.speak(utter);
            }
            if (window.speechSynthesis.getVoices().length > 0) doSpeak();
            else window.speechSynthesis.onvoiceschanged = function(){ doSpeak(); };
        };
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>