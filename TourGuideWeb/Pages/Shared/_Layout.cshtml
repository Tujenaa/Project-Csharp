@{
    var sessionUser = Context.Session.GetString("Username") ?? "";
    var sessionRole = Context.Session.GetString("Role") ?? "";
    var isAdmin = sessionRole == "ADMIN";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TourGuide CMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/site.css?v=15" rel="stylesheet" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <span class="logo-icon"><i class="bi bi-broadcast-pin"></i></span>
                <span class="logo-text">TourGuide</span>
            </div>
            <nav class="sidebar-nav">
                <a href="/" class="nav-item @(ViewData["Active"]?.ToString() == "home" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i><span>Trang chủ</span>
                </a>

                <div class="nav-section">ĐỊA ĐIỂM & TOUR</div>
                <a href="/Pois" class="nav-item @(ViewData["Active"]?.ToString() == "pois" ? "active" : "")">
                    <i class="bi bi-geo-alt"></i><span>Điểm thuyết minh</span>
                </a>
                @if (isAdmin)
                {
                    <a href="/TourManager" class="nav-item @(ViewData["Active"]?.ToString() == "tours" ? "active" : "")">
                        <i class="bi bi-map"></i><span>Quản lý Tour</span>
                    </a>
                }

                <div class="nav-section">NỘI DUNG AUDIO</div>
                <a href="/AudioManager" class="nav-item @(ViewData["Active"]?.ToString() == "audio" ? "active" : "")">
                    <i class="bi bi-music-note-beamed"></i><span>Quản lý Audio</span>
                </a>
                @if (isAdmin)
                {
                    <a href="/LanguageManager" class="nav-item @(ViewData["Active"]?.ToString() == "languages" ? "active" : "")">
                        <i class="bi bi-translate"></i><span>Ngôn ngữ</span>
                    </a>
                }

                <div class="nav-section">QUẢN TRỊ</div>
                <a href="/HistoryPage" class="nav-item @(ViewData["Active"]?.ToString() == "history" ? "active" : "")">
                    <i class="bi bi-clock-history"></i><span>Lịch sử phát</span>
                </a>
                @if (isAdmin)
                {
                    <a href="/Users" class="nav-item @(ViewData["Active"]?.ToString() == "users" ? "active" : "")">
                        <i class="bi bi-people"></i><span>Người dùng</span>
                    </a>
                    <a href="/Approval" class="nav-item @(ViewData["Active"]?.ToString() == "approval" ? "active" : "")">
                        <i class="bi bi-clipboard-check"></i>
                        <span>Phê duyệt</span>
                        @{
                            var pendingCount = ViewData["PendingCount"] as int? ?? 0;
                        }
                        @if (pendingCount > 0)
                        {
                            <span class="nav-badge">@pendingCount</span>
                        }
                    </a>
                }
                <a href="/Profile" class="nav-item @(ViewData["Active"]?.ToString() == "profile" ? "active" : "")">
                    <i class="bi bi-person-circle"></i><span>Thông tin cá nhân</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <span>API: <code>:5266</code></span>
            </div>
        </aside>
        <main class="main-area">
            <header class="top-bar">
                <div class="page-title">@ViewData["Title"]</div>
                <div class="top-actions">
                    <span class="status-dot"></span>
                    <span class="status-text">API Online</span>
                    <div class="user-chip" style="margin-left:12px">
                        <span class="u-name">@sessionUser</span>
                        <span class="u-role @(isAdmin ? "role-admin" : "role-owner")">@sessionRole</span>
                    </div>
                    <form method="post" action="/Auth?handler=Logout" style="margin-left:8px;display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </header>
            <div class="page-body">
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.alert').forEach(el => {
                setTimeout(() => el.remove(), 3400);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
