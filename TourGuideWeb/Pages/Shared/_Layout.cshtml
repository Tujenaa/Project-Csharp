@{
    var sessionUser = Context.Session.GetString("Username") ?? "";
    var sessionRole = Context.Session.GetString("Role") ?? "";
    var isAdmin = sessionRole == "ADMIN";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TourGuide CMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/site.css?v=12" rel="stylesheet" />
    <style>
        input, select, textarea,
        input.form-control, select.form-control, textarea.form-control {
            color: #e2e8f0 !important;
            background-color: #1A1035 !important;
            font-family: 'Times New Roman', Times, serif !important;
        }

            input::placeholder, textarea::placeholder {
                color: #9B7FEA !important;
                opacity: 1 !important;
            }

            input:-webkit-autofill, input:-webkit-autofill:focus {
                -webkit-box-shadow: 0 0 0 1000px #1A1035 inset !important;
                -webkit-text-fill-color: #e2e8f0 !important;
            }

        * {
            font-family: 'Times New Roman', Times, serif;
        }

        .stat-value, code, pre, .mono, .coord, .time-chip, .rank-badge, .play-badge {
            font-family: 'Space Mono', monospace !important;
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: #8b9ab3;
        }

            .user-chip .u-name {
                color: #e2e8f0;
                font-weight: 600;
            }

            .user-chip .u-role {
                font-size: 10px;
                padding: 2px 7px;
                border-radius: 20px;
                font-family: 'Space Mono', monospace;
            }

        .role-admin {
            background: rgba(239,68,68,.15);
            color: #ef4444;
        }

        .role-owner {
            background: rgba(59,130,246,.15);
            color: #60a5fa;
        }

        .btn-logout {
            background: transparent;
            border: 1px solid #1f3460;
            color: #8b9ab3;
            padding: 5px 10px;
            border-radius: 7px;
            cursor: pointer;
            font-size: 12px;
            font-family: 'Times New Roman', Times, serif;
            transition: all .15s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

            .btn-logout:hover {
                border-color: #e94560;
                color: #e94560;
            }
    </style>
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <span class="logo-icon"><i class="bi bi-broadcast-pin"></i></span>
                <span class="logo-text">TourGuide</span>
            </div>
            <nav class="sidebar-nav">
                <a href="/" class="nav-item @(ViewData["Active"]?.ToString() == "home" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i><span>Trang chủ</span>
                </a>
                <div class="nav-section">NỘI DUNG</div>
                <a href="/Pois" class="nav-item @(ViewData["Active"]?.ToString() == "pois" ? "active" : "")">
                    <i class="bi bi-geo-alt"></i><span>Điểm thuyết minh</span>
                </a>
                <a href="/AudioManager" class="nav-item @(ViewData["Active"]?.ToString() == "audio" ? "active" : "")">
                    <i class="bi bi-music-note-beamed"></i><span>Quản lý Audio</span>
                </a>
                <div class="nav-section">DỮ LIỆU</div>
                <a href="/HistoryPage" class="nav-item @(ViewData["Active"]?.ToString() == "history" ? "active" : "")">
                    <i class="bi bi-clock-history"></i><span>Lịch sử phát</span>
                </a>
                @if (isAdmin)
                {
                    <a href="/Users" class="nav-item @(ViewData["Active"]?.ToString() == "users" ? "active" : "")">
                        <i class="bi bi-people"></i><span>Người dùng</span>
                    </a>
                }
            </nav>
            <div class="sidebar-footer">
                <span>API: <code>:5266</code></span>
            </div>
        </aside>
        <main class="main-area">
            <header class="top-bar">
                <div class="page-title">@ViewData["Title"]</div>
                <div class="top-actions">
                    <span class="status-dot"></span>
                    <span class="status-text">API Online</span>
                    <div class="user-chip" style="margin-left:12px">
                        <span class="u-name">@sessionUser</span>
                        <span class="u-role @(isAdmin ? "role-admin" : "role-owner")">@sessionRole</span>
                    </div>
                    <form method="post" action="/Auth?handler=Logout" style="margin-left:8px;display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </header>
            <div class="page-body">
                @RenderBody()
            </div>
        </main>
    </div>
    @await RenderSectionAsync("Styles", required: false)
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.alert').forEach(el => {
                setTimeout(() => el.remove(), 3400);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
