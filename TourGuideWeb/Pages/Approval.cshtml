@page
@model GPSGuide.Web.Pages.ApprovalModel
@{
    ViewData["Title"] = "Phê duyệt"; ViewData["Active"] = "approval";
    var pendingTourPois = Model.PendingTourPois.Count + Model.RemovePendingTourPois.Count;
}

@section Styles {
    <link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />
    <style>
        #approvalTable td, #approvalTable th {
            padding: 14px 16px;
        }

        #approvalTable tbody tr {
            border-bottom: 1px solid #f3f4f6;
        }

            #approvalTable tbody tr:hover {
                background: #faf9ff;
            }

        .poi-meta {
            font-size: 12px;
            color: #6b7280;
            margin-top: 3px;
            line-height: 1.5;
        }

        .approval-actions {
            display: flex;
            gap: 6px;
            align-items: center;
        }

        .tour-req-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            border-bottom: 1px solid #f3f4f6;
            transition: background .15s;
        }

            .tour-req-card:hover {
                background: #faf9ff;
            }

            .tour-req-card:last-child {
                border-bottom: none;
            }
        /* Số đỏ cho pending */
        .utab-count-red {
            background: #dc2626;
            color: #fff;
            border-radius: 20px;
            padding: 1px 7px;
            font-size: 11px;
            font-family: var(--mono);
            font-weight: 700;
        }
    </style>
}

@if (!string.IsNullOrEmpty(Model.Msg))
{
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> @Model.Msg</div>
}

<div class="page-header">
    <div>
        <h2>Phê duyệt</h2>
    </div>
    @if (Model.AllPois.Any(p => p.Status == "REJECTED"))
    {
        <form method="post" asp-page-handler="DeleteRejected" onsubmit="return confirm('Xóa tất cả POI bị từ chối?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="bi bi-trash"></i> Xóa tất cả POI bị từ chối
            </button>
        </form>
    }
</div>

<!-- Tab chính -->
<div class="user-tabs" style="margin-bottom:28px">
    <button class="utab active" id="mainTabPoi" onclick="switchMainTab('poi', this)">
        <i class="bi bi-geo-alt"></i> Điểm thuyết minh
        @{
            var pendingPoi = Model.AllPois.Count(p => p.Status == "PENDING");
        }
        @if (pendingPoi > 0)
        {
            <span class="utab-count-red">@pendingPoi</span>
        }
        else
        {
            <span class="utab-count">@Model.AllPois.Count(p => p.Status == "PENDING")</span>
        }
    </button>
    <button class="utab" id="mainTabTour" onclick="switchMainTab('tour', this)">
        <i class="bi bi-map"></i> Yêu cầu tham gia Tour
        @if (pendingTourPois > 0)
        {
            <span class="utab-count-red">@pendingTourPois</span>
        }
    </button>
</div>

<!-- ── TAB POI ── -->
<div id="sectionPoi">
    <div class="user-tabs" style="margin-bottom:16px">
        <button class="utab active" onclick="filterStatus('PENDING', this)">
            ⏳ Chờ duyệt
            <span class="utab-count">@Model.AllPois.Count(p => p.Status == "PENDING")</span>
        </button>
        <button class="utab" onclick="filterStatus('APPROVED', this)">
            ✅ Đã duyệt
            <span class="utab-count">@Model.AllPois.Count(p => p.Status == "APPROVED")</span>
        </button>
        <button class="utab" onclick="filterStatus('REJECTED', this)">
            ❌ Từ chối
            <span class="utab-count">@Model.AllPois.Count(p => p.Status == "REJECTED")</span>
        </button>
    </div>
    <div class="card">
        <table class="tg-table" id="approvalTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên POI</th>
                    <th>Chủ sở hữu</th>
                    <th>Toạ độ</th>
                    <th>Bán kính</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.AllPois.OrderByDescending(x => x.Id))
                {
                    <tr data-status="@p.Status">
                        <td style="color:#9ca3af;font-size:12px;font-family:var(--mono)">#@p.Id</td>
                        <td>
                            <div style="font-weight:600;color:#111827">@p.Name</div>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div class="poi-meta">@(p.Description.Length > 80 ? p.Description[..80] + "…" : p.Description)</div>
                            }
                        </td>
                        <td>
                            <div style="font-weight:500;color:#374151">@(p.OwnerName ?? $"#{p.OwnerId}")</div>
                        </td>
                        <td>
                            <div style="font-family:var(--mono);font-size:12px;color:#5b21b6;line-height:1.8">
                                <div>@p.Latitude.ToString("F5")</div>
                                <div>@p.Longitude.ToString("F5")</div>
                            </div>
                        </td>
                        <td>
                            <span style="background:#f5f3ff;color:#5b21b6;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600">
                                @p.Radius m
                            </span>
                        </td>
                        <td>
                            @if (p.Status == "PENDING")
                            {
                                <span class="badge badge-yellow" style="padding:4px 10px;font-size:12px">⏳ Chờ duyệt</span>
                            }
                            else if (p.Status == "APPROVED")
                            {
                                <span class="badge badge-green" style="padding:4px 10px;font-size:12px">✅ Đã duyệt</span>
                            }
                            else
                            {
                                <span class="badge badge-red" title="@p.RejectReason" style="padding:4px 10px;font-size:12px;cursor:help">❌ Từ chối</span>
                            }
                        </td>
                        <td>
                            <div class="approval-actions">
                                @if (p.Status == "PENDING")
                                {
                                    <form method="post" asp-page-handler="Approve" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="PoiId" value="@p.Id" />
                                        <button type="submit" class="btn btn-sm" style="background:#dcfce7;color:#166534;border:1px solid #86efac;font-weight:600;white-space:nowrap">
                                            <i class="bi bi-check-lg"></i> Duyệt
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="openReject(@p.Id, '@p.Name')" style="white-space:nowrap">
                                        <i class="bi bi-x-lg"></i> Từ chối
                                    </button>
                                }
                                else if (p.Status == "REJECTED")
                                {
                                    <form method="post" asp-page-handler="Approve" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="PoiId" value="@p.Id" />
                                        <button type="submit" class="btn btn-sm" style="background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd;font-weight:600;white-space:nowrap">
                                            <i class="bi bi-arrow-counterclockwise"></i> Duyệt lại
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Revoke" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="PoiId" value="@p.Id" />
                                        <button type="submit" class="btn btn-ghost btn-sm" style="white-space:nowrap">
                                            <i class="bi bi-arrow-counterclockwise"></i> Rút duyệt
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.AllPois.Any())
                {
                    <tr><td colspan="7" class="empty-state">Không có POI nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ── TAB TOUR POI ── -->
<div id="sectionTour" style="display:none">

    <!-- Sub-tabs Tour -->
    <div class="user-tabs" style="margin-bottom:16px;display:flex;justify-content:space-between;align-items:center">
        <div style="display:flex;gap:0">
            <button class="utab active" id="tourSubTabPending" onclick="switchTourTab('pending', this)">
                ⏳ Xin vào tour
                @if (Model.PendingTourPois.Count > 0)
                {
                    <span class="utab-count-red">@Model.PendingTourPois.Count</span>
                }
                else
                {
                    <span class="utab-count">0</span>
                }
            </button>
            <button class="utab" id="tourSubTabRemove" onclick="switchTourTab('remove', this)">
                🚪 Xin rời tour
                @if (Model.RemovePendingTourPois.Count > 0)
                {
                    <span class="utab-count-red">@Model.RemovePendingTourPois.Count</span>
                }
                else
                {
                    <span class="utab-count">0</span>
                }
            </button>
            <button class="utab" id="tourSubTabApproved" onclick="switchTourTab('approved', this)">
                ✅ Đã duyệt
                <span class="utab-count">@Model.ApprovedTourPois.Count</span>
            </button>
            <button class="utab" id="tourSubTabRejected" onclick="switchTourTab('rejected', this)">
                ❌ Từ chối
                <span class="utab-count">@Model.RejectedTourPois.Count</span>
            </button>
        </div>
        @if (Model.RejectedTourPois.Any())
        {
            <form method="post" asp-page-handler="DeleteRejectedTourPois"
                  id="deleteTourRejectedForm"
                  onsubmit="return confirm('Xóa tất cả yêu cầu bị từ chối?')"
                  style="display:none">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash"></i> Xóa tất cả bị từ chối
                </button>
            </form>
        }
    </div>

    <!-- Pending -->
    <div id="tourSectionPending" class="card" style="overflow:hidden">
        @if (!Model.PendingTourPois.Any())
        {
            <div style="padding:48px;text-align:center;color:#9ca3af">
                <i class="bi bi-check2-all" style="font-size:40px;display:block;margin-bottom:12px;color:#c4b5fd"></i>
                <div style="font-weight:600;font-size:15px;color:#6b7280">Không có yêu cầu nào đang chờ duyệt</div>
            </div>
        }
        else
        {
            <table class="tg-table" id="approvalTourTable">
                <thead>
                    <tr>
                        <th>Điểm thuyết minh</th>
                        <th>Yêu cầu</th>
                        <th>Tour</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tp in Model.PendingTourPois)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:12px">
                                    <div style="width:36px;height:36px;border-radius:8px;background:#ede9fe;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                        <i class="bi bi-geo-alt-fill" style="color:#7c3aed;font-size:16px"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight:600;font-size:14px;color:#111827">@tp.PoiName</div>
                                        @if (!string.IsNullOrEmpty(tp.Address))
                                        {
                                            <div style="font-size:12px;color:#9ca3af;margin-top:2px"><i class="bi bi-pin-map"></i> @tp.Address</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><span style="background:#fef3c7;color:#92400e;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600">⏳ Xin vào tour</span></td>
                            <td><span style="background:#ede9fe;color:#5b21b6;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600"><i class="bi bi-map"></i> @tp.TourName</span></td>
                            <td>
                                <div style="display:flex;gap:6px">
                                    <form method="post" asp-page-handler="ApproveTourPoi" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="TourPOIId" value="@tp.TourPOIId" />
                                        <input type="hidden" name="TourId" value="@tp.TourId" />
                                        <button type="submit" class="btn btn-sm" style="background:#dcfce7;color:#166534;border:1px solid #86efac;font-weight:600">
                                            <i class="bi bi-check-lg"></i> Duyệt
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="RejectTourPoi" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="TourPOIId" value="@tp.TourPOIId" />
                                        <input type="hidden" name="TourId" value="@tp.TourId" />
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Từ chối yêu cầu này?')">
                                            <i class="bi bi-x-lg"></i> Từ chối
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div id="tourSectionRemove" class="card" style="overflow:hidden;display:none">
        @if (!Model.RemovePendingTourPois.Any())
        {
            <div style="padding:48px;text-align:center;color:#9ca3af">
                <i class="bi bi-door-open" style="font-size:40px;display:block;margin-bottom:12px;color:#c4b5fd"></i>
                <div style="font-weight:600;font-size:15px;color:#6b7280">Không có yêu cầu rời tour nào</div>
            </div>
        }
        else
        {
            <table class="tg-table">
                <thead>
                    <tr><th>Điểm thuyết minh</th><th>Yêu cầu</th><th>Tour</th><th>Hành động</th></tr>
                </thead>
                <tbody>
                    @foreach (var tp in Model.RemovePendingTourPois)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:12px">
                                    <div style="width:36px;height:36px;border-radius:8px;background:#fef3c7;display:flex;align-items:center;justify-content:center;flex-shrink:0"><i class="bi bi-box-arrow-right" style="color:#d97706;font-size:16px"></i></div>
                                    <div>
                                        <div style="font-weight:600;font-size:14px;color:#111827">@tp.PoiName</div>
                                        @if (!string.IsNullOrEmpty(tp.Address))
                                        {
                                            <div style="font-size:12px;color:#9ca3af;margin-top:2px"><i class="bi bi-pin-map"></i> @tp.Address</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><span style="background:#fff7ed;color:#c2410c;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600">🚪 Xin rời tour</span></td>
                            <td><span style="background:#fef3c7;color:#92400e;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600"><i class="bi bi-map"></i> @tp.TourName</span></td>
                            <td>
                                <div style="display:flex;gap:6px">
                                    <form method="post" asp-page-handler="ApproveTourPoi" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="TourPOIId" value="@tp.TourPOIId" />
                                        <input type="hidden" name="TourId" value="@tp.TourId" />
                                        <button type="submit" class="btn btn-sm" style="background:#dcfce7;color:#166534;border:1px solid #86efac;font-weight:600" onclick="return confirm('Đồng ý cho POI rời khỏi tour này?')">
                                            <i class="bi bi-check-lg"></i> Đồng ý xóa
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="RejectTourPoi" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="TourPOIId" value="@tp.TourPOIId" />
                                        <input type="hidden" name="TourId" value="@tp.TourId" />
                                        <button type="submit" class="btn btn-ghost btn-sm" onclick="return confirm('Từ chối — POI sẽ được giữ lại trong tour?')">
                                            <i class="bi bi-arrow-counterclockwise"></i> Giữ lại
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div id="tourSectionApproved" class="card" style="overflow:hidden;display:none">
        @if (!Model.ApprovedTourPois.Any())
        {
            <div style="padding:48px;text-align:center;color:#9ca3af">
                <i class="bi bi-map" style="font-size:40px;display:block;margin-bottom:12px;color:#86efac"></i>
                <div style="font-weight:600;font-size:15px;color:#6b7280">Chưa có yêu cầu nào được duyệt</div>
            </div>
        }
        else
        {
            <table class="tg-table">
                <thead>
                    <tr><th>Điểm thuyết minh</th><th>Trạng thái</th><th>Tour</th><th>Hành động</th></tr>
                </thead>
                <tbody>
                    @foreach (var tp in Model.ApprovedTourPois)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:12px">
                                    <div style="width:36px;height:36px;border-radius:8px;background:#dcfce7;display:flex;align-items:center;justify-content:center;flex-shrink:0"><i class="bi bi-geo-alt-fill" style="color:#16a34a;font-size:16px"></i></div>
                                    <div>
                                        <div style="font-weight:600;font-size:14px;color:#111827">@tp.PoiName</div>
                                        @if (!string.IsNullOrEmpty(tp.Address))
                                        {
                                            <div style="font-size:12px;color:#9ca3af;margin-top:2px"><i class="bi bi-pin-map"></i> @tp.Address</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><span style="background:#dcfce7;color:#166534;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600">✅ Thành viên</span></td>
                            <td><span style="background:#dcfce7;color:#166534;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600"><i class="bi bi-map"></i> @tp.TourName</span></td>
                            <td><span class="badge badge-green" style="padding:6px 12px;font-size:12px">✅ Đã duyệt</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div id="tourSectionRejected" class="card" style="overflow:hidden;display:none">
        @if (!Model.RejectedTourPois.Any())
        {
            <div style="padding:48px;text-align:center;color:#9ca3af">
                <i class="bi bi-x-circle" style="font-size:40px;display:block;margin-bottom:12px;color:#fca5a5"></i>
                <div style="font-weight:600;font-size:15px;color:#6b7280">Không có yêu cầu nào bị từ chối</div>
            </div>
        }
        else
        {
            <table class="tg-table">
                <thead>
                    <tr><th>Điểm thuyết minh</th><th>Trạng thái</th><th>Tour</th><th>Hành động</th></tr>
                </thead>
                <tbody>
                    @foreach (var tp in Model.RejectedTourPois)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:12px">
                                    <div style="width:36px;height:36px;border-radius:8px;background:#fee2e2;display:flex;align-items:center;justify-content:center;flex-shrink:0"><i class="bi bi-geo-alt-fill" style="color:#dc2626;font-size:16px"></i></div>
                                    <div>
                                        <div style="font-weight:600;font-size:14px;color:#111827">@tp.PoiName</div>
                                        @if (!string.IsNullOrEmpty(tp.Address))
                                        {
                                            <div style="font-size:12px;color:#9ca3af;margin-top:2px"><i class="bi bi-pin-map"></i> @tp.Address</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><span style="background:#fee2e2;color:#991b1b;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600">❌ Từ chối</span></td>
                            <td><span style="background:#fee2e2;color:#991b1b;font-size:12px;padding:4px 10px;border-radius:20px;font-weight:600"><i class="bi bi-map"></i> @tp.TourName</span></td>
                            <td><span class="badge badge-red" style="padding:6px 12px;font-size:12px">❌ Từ chối</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Remove Pending (xin rời tour) -->
    <div id="tourSectionRemove" class="card" style="overflow:hidden;display:none">
        @if (!Model.RemovePendingTourPois.Any())
        {
            <div style="padding:48px;text-align:center;color:#9ca3af">
                <i class="bi bi-door-open" style="font-size:40px;display:block;margin-bottom:12px;color:#c4b5fd"></i>
                <div style="font-weight:600;font-size:15px;color:#6b7280">Không có yêu cầu rời tour nào</div>
            </div>
        }
        else
        {
            @foreach (var tp in Model.RemovePendingTourPois)
            {
                <div class="tour-req-card">
                    <div style="display:flex;align-items:center;gap:14px;flex:1">
                        <div style="width:40px;height:40px;border-radius:10px;background:#fef3c7;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="bi bi-box-arrow-right" style="color:#d97706;font-size:16px"></i>
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:14px;color:#111827">@tp.PoiName</div>
                            @if (!string.IsNullOrEmpty(tp.Address))
                            {
                                <div style="font-size:12px;color:#9ca3af;margin-top:2px">
                                    <i class="bi bi-pin-map"></i> @tp.Address
                                </div>
                            }
                        </div>
                        <div style="margin-left:8px;padding:0 16px;border-left:2px solid #f3f4f6">
                            <div style="font-size:11px;color:#9ca3af;margin-bottom:3px">Xin rời khỏi tour</div>
                            <span style="background:#fef3c7;color:#92400e;font-size:12px;padding:3px 10px;border-radius:20px;font-weight:600">
                                <i class="bi bi-map"></i> @tp.TourName
                            </span>
                        </div>
                    </div>
                    <div style="display:flex;gap:8px;flex-shrink:0">
                        <form method="post" asp-page-handler="ApproveTourPoi" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="TourPOIId" value="@tp.TourPOIId" />
                            <input type="hidden" name="TourId" value="@tp.TourId" />
                            <button type="submit" class="btn btn-sm"
                                    style="background:#dcfce7;color:#166534;border:1px solid #86efac;font-weight:600"
                                    onclick="return confirm('Đồng ý cho POI rời khỏi tour này?')">
                                <i class="bi bi-check-lg"></i> Đồng ý xóa
                            </button>
                        </form>
                        <form method="post" asp-page-handler="RejectTourPoi" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="TourPOIId" value="@tp.TourPOIId" />
                            <input type="hidden" name="TourId" value="@tp.TourId" />
                            <button type="submit" class="btn btn-ghost btn-sm"
                                    onclick="return confirm('Từ chối — POI sẽ được giữ lại trong tour?')">
                                <i class="bi bi-arrow-counterclockwise"></i> Giữ lại
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Approved -->
    <div id="tourSectionApproved" class="card" style="overflow:hidden;display:none">
        @if (!Model.ApprovedTourPois.Any())
        {
            <div style="padding:48px;text-align:center;color:#9ca3af">
                <i class="bi bi-map" style="font-size:40px;display:block;margin-bottom:12px;color:#86efac"></i>
                <div style="font-weight:600;font-size:15px;color:#6b7280">Chưa có yêu cầu nào được duyệt</div>
            </div>
        }
        else
        {
            @foreach (var tp in Model.ApprovedTourPois)
            {
                <div class="tour-req-card">
                    <div style="display:flex;align-items:center;gap:14px;flex:1">
                        <div style="width:40px;height:40px;border-radius:10px;background:#dcfce7;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="bi bi-geo-alt-fill" style="color:#16a34a;font-size:16px"></i>
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:14px;color:#111827">@tp.PoiName</div>
                            @if (!string.IsNullOrEmpty(tp.Address))
                            {
                                <div style="font-size:12px;color:#9ca3af;margin-top:2px">
                                    <i class="bi bi-pin-map"></i> @tp.Address
                                </div>
                            }
                        </div>
                        <div style="margin-left:8px;padding:0 16px;border-left:2px solid #f3f4f6">
                            <div style="font-size:11px;color:#9ca3af;margin-bottom:3px">Thuộc tour</div>
                            <span style="background:#dcfce7;color:#166534;font-size:12px;padding:3px 10px;border-radius:20px;font-weight:600">
                                <i class="bi bi-map"></i> @tp.TourName
                            </span>
                        </div>
                        <div style="margin-left:auto">
                            <span class="badge badge-green" style="padding:4px 10px;font-size:12px">✅ Đã duyệt</span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Rejected -->
    <div id="tourSectionRejected" class="card" style="overflow:hidden;display:none">
        @if (!Model.RejectedTourPois.Any())
        {
            <div style="padding:48px;text-align:center;color:#9ca3af">
                <i class="bi bi-x-circle" style="font-size:40px;display:block;margin-bottom:12px;color:#fca5a5"></i>
                <div style="font-weight:600;font-size:15px;color:#6b7280">Không có yêu cầu nào bị từ chối</div>
            </div>
        }
        else
        {
            @foreach (var tp in Model.RejectedTourPois)
            {
                <div class="tour-req-card">
                    <div style="display:flex;align-items:center;gap:14px;flex:1">
                        <div style="width:40px;height:40px;border-radius:10px;background:#fee2e2;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="bi bi-geo-alt-fill" style="color:#dc2626;font-size:16px"></i>
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:14px;color:#111827">@tp.PoiName</div>
                            @if (!string.IsNullOrEmpty(tp.Address))
                            {
                                <div style="font-size:12px;color:#9ca3af;margin-top:2px">
                                    <i class="bi bi-pin-map"></i> @tp.Address
                                </div>
                            }
                        </div>
                        <div style="margin-left:8px;padding:0 16px;border-left:2px solid #f3f4f6">
                            <div style="font-size:11px;color:#9ca3af;margin-bottom:3px">Tour</div>
                            <span style="background:#fee2e2;color:#991b1b;font-size:12px;padding:3px 10px;border-radius:20px;font-weight:600">
                                <i class="bi bi-map"></i> @tp.TourName
                            </span>
                        </div>
                        <div style="margin-left:auto;display:flex;align-items:center;gap:8px">
                            <span class="badge badge-red" style="padding:4px 10px;font-size:12px">❌ Từ chối</span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Modal từ chối POI -->
<div id="rejectModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)closeReject()">
    <div class="modal-box modal-sm" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h4>Từ chối POI</h4>
            <button type="button" class="btn btn-ghost btn-icon" onclick="closeReject()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <form method="post" asp-page-handler="Reject">
            @Html.AntiForgeryToken()
            <div class="modal-body">
                <p style="color:#374151;margin-bottom:12px">
                    Từ chối POI: <strong id="rejectPoiName"></strong>
                </p>
                <input type="hidden" name="PoiId" id="rejectPoiId" />
                <div class="form-group">
                    <label class="form-label">Lý do từ chối</label>
                    <textarea name="Reason" class="form-control" rows="3"
                              placeholder="VD: Toạ độ không chính xác, thiếu mô tả..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" onclick="closeReject()">Huỷ</button>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-x-lg"></i> Xác nhận từ chối
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openReject(id, name) {
        document.getElementById('rejectPoiId').value = id;
        document.getElementById('rejectPoiName').textContent = name;
        document.getElementById('rejectModal').style.display = 'flex';
    }
    function closeReject() { document.getElementById('rejectModal').style.display = 'none'; }

    function filterStatus(status, btn) {
        btn.closest('.user-tabs').querySelectorAll('.utab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('#approvalTable tbody tr[data-status]').forEach(row => {
            row.style.display = (row.dataset.status === status) ? '' : 'none';
        });
    }

    function switchMainTab(tab, btn) {
        document.querySelectorAll('#mainTabPoi, #mainTabTour').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('sectionPoi').style.display  = tab === 'poi'  ? '' : 'none';
        document.getElementById('sectionTour').style.display = tab === 'tour' ? '' : 'none';
    }

    function switchTourTab(tab, btn) {
        btn.closest('.user-tabs').querySelectorAll('.utab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tourSectionPending').style.display  = tab === 'pending' ? '' : 'none';
        document.getElementById('tourSectionRemove').style.display   = tab === 'remove'  ? '' : 'none';
        document.getElementById('tourSectionApproved').style.display = tab === 'approved'? '' : 'none';
        document.getElementById('tourSectionRejected').style.display = tab === 'rejected'? '' : 'none';

        const deleteBtn = document.getElementById('deleteTourRejectedForm');
        if (deleteBtn) deleteBtn.style.display = tab === 'rejected' ? '' : 'none';
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('#approvalTable tbody tr[data-status]').forEach(row => {
            if (row.dataset.status !== 'PENDING') row.style.display = 'none';
        });
    });
</script>
