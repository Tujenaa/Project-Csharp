@page
@model GPSGuide.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
    ViewData["Active"] = "home";
}

@if (Model.ApiError)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle"></i>
        Không kết nối được API tại <code>@Model.ApiUrl</code> — kiểm tra TourGuideAPI có đang chạy không.
    </div>
}

<!-- Stat Cards -->
<div class="stat-grid">
    <div class="stat-card blue">
        <div>
            <div class="stat-label">Điểm thuyết minh</div>
            <div class="stat-value">@Model.TotalPoi</div>
            <div class="stat-trend trend-blue">
                <i class="bi bi-geo-alt-fill"></i> POI active
            </div>
        </div>
        <div class="stat-icon-wrap icon-blue">
            <i class="bi bi-geo-alt"></i>
        </div>
    </div>
    <div class="stat-card cyan">
        <div>
            <div class="stat-label">File Audio / Script</div>
            <div class="stat-value">@Model.TotalAudio</div>
            <div class="stat-trend trend-cyan">
                <i class="bi bi-music-note"></i> scripts
            </div>
        </div>
        <div class="stat-icon-wrap icon-cyan">
            <i class="bi bi-music-note-beamed"></i>
        </div>
    </div>
    <div class="stat-card green">
        <div>
            <div class="stat-label">Lượt phát tổng</div>
            <div class="stat-value">@Model.TotalHistory</div>
            <div class="stat-trend trend-green">
                <i class="bi bi-arrow-up"></i> all time
            </div>
        </div>
        <div class="stat-icon-wrap icon-green">
            <i class="bi bi-play-circle"></i>
        </div>
    </div>
    <div class="stat-card yellow">
        <div>
            <div class="stat-label">Người dùng</div>
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-trend trend-yellow">
                <i class="bi bi-people"></i> accounts
            </div>
        </div>
        <div class="stat-icon-wrap icon-yellow">
            <i class="bi bi-people"></i>
        </div>
    </div>
</div>

<!-- Bottom Grid -->
<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:4px">
    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-clock-history me-2"></i>Lịch sử phát gần đây</span>
            <a href="/HistoryPage" class="btn btn-ghost btn-sm">Xem tất cả</a>
        </div>
        <table class="tg-table">
            <thead>
                <tr><th>Điểm POI</th><th>Thời gian</th></tr>
            </thead>
            <tbody>
                @foreach (var h in Model.RecentHistory)
                {
                    <tr>
                        <td>
                            <span class="poi-dot"></span>
                            @h.PoiName
                        </td>
                        <td>
                            <span class="time-chip">@h.PlayTime.ToString("dd/MM HH:mm")</span>
                        </td>
                    </tr>
                }
                @if (!Model.RecentHistory.Any())
                {
                    <tr><td colspan="2" class="empty-state">Chưa có lịch sử</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-trophy me-2"></i>Top POI được phát nhiều nhất</span>
        </div>
        <table class="tg-table">
            <thead>
                <tr><th>Điểm</th><th>Lượt phát</th></tr>
            </thead>
            <tbody>
                @{
                    int rank = 1;
                }
                @foreach (var p in Model.TopPoi)
                {
                    <tr>
                        <td>
                            <span class="rank-badge @(rank == 1 ? "rank-gold" : rank == 2 ? "rank-silver" : "rank-bronze")">#@rank</span>
                            <span class="ms-2">@p.Key</span>
                        </td>
                        <td><span class="play-badge"><i class="bi bi-play-fill"></i> @p.Value lượt</span></td>
                    </tr>
                    rank++;
                }
                @if (!Model.TopPoi.Any())
                {
                    <tr><td colspan="2" class="empty-state">Chưa có dữ liệu</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    /* ── Stat card nâng cấp ── */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 20px;
    }

    .stat-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px 18px 16px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        position: relative;
        overflow: hidden;
        transition: transform .15s, border-color .2s;
    }

        .stat-card:hover {
            transform: translateY(-2px);
        }

        /* Thanh màu trên cùng */
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            border-radius: 12px 12px 0 0;
        }

        .stat-card.blue::before {
            background: linear-gradient(90deg,#3b82f6,#60a5fa);
        }

        .stat-card.cyan::before {
            background: linear-gradient(90deg,#06b6d4,#22d3ee);
        }

        .stat-card.green::before {
            background: linear-gradient(90deg,#10b981,#34d399);
        }

        .stat-card.yellow::before {
            background: linear-gradient(90deg,#f59e0b,#fbbf24);
        }

        .stat-card .stat-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: var(--text2);
            margin-bottom: 6px;
            font-family: var(--font);
        }

        .stat-card .stat-value {
            font-size: 34px;
            font-weight: 700;
            font-family: var(--mono);
            line-height: 1;
            margin-bottom: 8px;
        }

        .stat-card.blue .stat-value {
            color: #60a5fa;
        }

        .stat-card.cyan .stat-value {
            color: #22d3ee;
        }

        .stat-card.green .stat-value {
            color: #34d399;
        }

        .stat-card.yellow .stat-value {
            color: #fbbf24;
        }

    /* Trend badge kế số */
    .stat-trend {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 20px;
        font-family: var(--mono);
    }

    .trend-blue {
        background: rgba(59,130,246,.12);
        color: #60a5fa;
    }

    .trend-cyan {
        background: rgba(6,182,212,.12);
        color: #22d3ee;
    }

    .trend-green {
        background: rgba(16,185,129,.12);
        color: #34d399;
    }

    .trend-yellow {
        background: rgba(245,158,11,.12);
        color: #fbbf24;
    }

    /* Icon box góc phải */
    .stat-icon-wrap {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .icon-blue {
        background: rgba(59,130,246,.15);
        color: #60a5fa;
    }

    .icon-cyan {
        background: rgba(6,182,212,.15);
        color: #22d3ee;
    }

    .icon-green {
        background: rgba(16,185,129,.15);
        color: #34d399;
    }

    .icon-yellow {
        background: rgba(245,158,11,.15);
        color: #fbbf24;
    }

    /* Table enhancements */
    .poi-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent);
        margin-right: 8px;
        vertical-align: middle;
    }

    .time-chip {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--text2);
        background: var(--bg3);
        padding: 2px 8px;
        border-radius: 6px;
        border: 1px solid var(--border);
    }

    .rank-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        font-size: 11px;
        font-family: var(--mono);
        font-weight: 700;
    }

    .rank-gold {
        background: rgba(245,158,11,.2);
        color: #fbbf24;
    }

    .rank-silver {
        background: rgba(148,163,184,.15);
        color: #94a3b8;
    }

    .rank-bronze {
        background: rgba(107,127,163,.1);
        color: #64748b;
    }

    .play-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        font-family: var(--mono);
        background: rgba(16,185,129,.12);
        color: #34d399;
        padding: 3px 9px;
        border-radius: 20px;
    }
</style>
