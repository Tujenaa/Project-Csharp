@page
@model GPSGuide.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Active"] = "home";
}

@if (Model.ApiError)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i>
        Không kết nối được API tại <code>@Model.ApiUrl</code> — kiểm tra TourGuideAPI có đang chạy không.
    </div>
}

<div class="stat-grid">
    <div class="stat-card blue">
        <div>
            <div class="stat-value">@Model.TotalPoi</div>
            <div class="stat-label">Điểm thuyết minh</div>
        </div>
        <i class="bi bi-geo-alt stat-icon"></i>
    </div>
    <div class="stat-card cyan">
        <div>
            <div class="stat-value">@Model.TotalAudio</div>
            <div class="stat-label">File Audio / Script</div>
        </div>
        <i class="bi bi-music-note stat-icon"></i>
    </div>
    <div class="stat-card green">
        <div>
            <div class="stat-value">@Model.TotalHistory</div>
            <div class="stat-label">Lượt phát tổng</div>
        </div>
        <i class="bi bi-play-circle stat-icon"></i>
    </div>
    <div class="stat-card yellow">
        <div>
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-label">Người dùng</div>
        </div>
        <i class="bi bi-people stat-icon"></i>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:20px">
    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-clock-history me-2"></i>Lịch sử phát gần đây</span>
            <a href="/HistoryPage" class="btn btn-ghost btn-sm">Xem tất cả</a>
        </div>
        <table class="tg-table">
            <thead>
                <tr><th>Điểm POI</th><th>Thời gian</th></tr>
            </thead>
            <tbody>
                @foreach (var h in Model.RecentHistory)
                {
                    <tr>
                        <td>@h.PoiName</td>
                        <td class="text-muted">@h.PlayTime.ToString("dd/MM HH:mm")</td>
                    </tr>
                }
                @if (!Model.RecentHistory.Any())
                {
                    <tr><td colspan="2" class="empty-state">Chưa có lịch sử</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-trophy me-2"></i>Top POI được phát nhiều nhất</span>
        </div>
        <table class="tg-table">
            <thead>
                <tr><th>Điểm</th><th>Lượt phát</th></tr>
            </thead>
            <tbody>
                @{
                    int rank = 1;
                }
                @foreach (var p in Model.TopPoi)
                {
                    <tr>
                        <td>
                            <span class="badge @(rank == 1 ? "badge-yellow" : "badge-blue")">#@rank</span>
                            <span class="ms-2">@p.Key</span>
                        </td>
                        <td><span class="badge badge-green">@p.Value lượt</span></td>
                    </tr>
                    rank++;
                }
                @if (!Model.TopPoi.Any())
                {
                    <tr><td colspan="2" class="empty-state">Chưa có dữ liệu</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
