@page
@model GPSGuide.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
    ViewData["Active"] = "home";
    var isAdmin = Model.IsAdmin;
}

@section Styles {
    <link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
}

@if (Model.ApiError)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle"></i>
        Không kết nối được API tại <code>@Model.ApiUrl</code> — kiểm tra TourGuideAPI có đang chạy không.
    </div>
}

<!-- Stat Cards -->
<div class="stat-grid">
    <div class="stat-card blue">
        <div>
            <div class="stat-label">Điểm thuyết minh</div>
            <div class="stat-value">@Model.TotalPoi</div>
            <div class="stat-trend trend-blue"><i class="bi bi-geo-alt-fill"></i> POI active</div>
        </div>
        <div class="stat-icon-wrap icon-blue"><i class="bi bi-geo-alt"></i></div>
    </div>
    <div class="stat-card cyan">
        <div>
            <div class="stat-label">File Audio / Script</div>
            <div class="stat-value">@Model.TotalAudio</div>
            <div class="stat-trend trend-cyan"><i class="bi bi-music-note"></i> scripts</div>
        </div>
        <div class="stat-icon-wrap icon-cyan"><i class="bi bi-music-note-beamed"></i></div>
    </div>
    <div class="stat-card green">
        <div>
            <div class="stat-label">Lượt phát tổng</div>
            <div class="stat-value">@Model.TotalHistory</div>
            <div class="stat-trend trend-green"><i class="bi bi-arrow-up"></i> all time</div>
        </div>
        <div class="stat-icon-wrap icon-green"><i class="bi bi-play-circle"></i></div>
    </div>
    @if (isAdmin)
    {
        <div class="stat-card yellow">
            <div>
                <div class="stat-label">Người dùng</div>
                <div class="stat-value">@Model.TotalUsers</div>
                <div class="stat-trend trend-yellow"><i class="bi bi-people"></i> accounts</div>
            </div>
            <div class="stat-icon-wrap icon-yellow"><i class="bi bi-people"></i></div>
        </div>
    }
</div>

<!-- Bottom Grid -->
<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:4px">
    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-clock-history me-2"></i>Lịch sử phát gần đây</span>
            <a href="/HistoryPage" class="link-all">Xem tất cả →</a>
        </div>
        <table class="tg-table">
            <thead><tr><th>Điểm POI</th><th>Thời gian</th></tr></thead>
            <tbody>
                @foreach (var h in Model.RecentHistory)
                {
                    <tr>
                        <td><span class="poi-dot"></span>@h.PoiName</td>
                        <td><span class="time-chip">@h.PlayTime.ToString("dd/MM HH:mm")</span></td>
                    </tr>
                }
                @if (!Model.RecentHistory.Any())
                {
                    <tr><td colspan="2" class="empty-state">Chưa có lịch sử</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-header">
            <span><i class="bi bi-trophy me-2"></i>Top POI được phát nhiều nhất</span>
        </div>
        <table class="tg-table">
            <thead><tr><th>Điểm</th><th>Lượt phát</th></tr></thead>
            <tbody>
                @{
                    int rank = 1;
                }
                @foreach (var p in Model.TopPoi)
                {
                    <tr>
                        <td>
                            <span class="rank-badge @(rank == 1 ? "rank-gold" : rank == 2 ? "rank-silver" : "rank-bronze")">#@rank</span>
                            <span class="ms-2">@p.Key</span>
                        </td>
                        <td><span class="play-badge"><i class="bi bi-play-fill"></i> @p.Value lượt</span></td>
                    </tr>
                    rank++;
                }
                @if (!Model.TopPoi.Any())
                {
                    <tr><td colspan="2" class="empty-state">Chưa có dữ liệu</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
